{
  "name": "myapp",
  "version": "0.1.0",
  "description": "skeleton-parallel Node.js project",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "test": "jest --runInBand",
    "lint": "eslint src/ tests/ contracts/ database/"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js", "contracts/**/*.js", "database/**/*.js"]
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  }
}

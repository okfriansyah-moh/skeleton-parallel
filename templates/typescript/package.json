{
  "name": "{{PROJECT_NAME}}",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/main.js",
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "test": "jest --verbose",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "moduleNameMapper": {
      "^@contracts/(.*)$": "<rootDir>/contracts/$1",
      "^@modules/(.*)$": "<rootDir>/src/modules/$1",
      "^@database/(.*)$": "<rootDir>/database/$1"
    }
  }
}

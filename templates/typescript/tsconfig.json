{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@contracts/*": ["./contracts/*"],
      "@modules/*": ["./src/modules/*"],
      "@database/*": ["./database/*"]
    }
  },
  "include": ["src/**/*", "contracts/**/*", "database/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}

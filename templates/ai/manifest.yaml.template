# .ai/manifest.yaml — Project identity for skeleton-parallel
# ─────────────────────────────────────────────────────────────────────────────
# IDENTITY ONLY: This file defines WHO this project is and WHAT it does.
# Runtime configuration (driver, router, retries, hooks) belongs in
# config/skeleton.yaml, NOT here.
#
# Copy this file to your project as .ai/manifest.yaml and fill in the values.
# Generated by: skeleton integrate | skeleton init
# ─────────────────────────────────────────────────────────────────────────────

version: "2.0"

# ── Project identity ──────────────────────────────────────────────────────────
project:
  name: <project-name>          # e.g., my-api-service
  domain: <domain>              # e.g., backend | data-pipeline | fullstack | cli
  description: <one-line description>  # e.g., REST API for user management

# ── Execution defaults ────────────────────────────────────────────────────────
defaults:
  # Target provider for `ars compose --target <provider>`
  # VALID VALUES: copilot | claude | codex | cursor
  provider: copilot

  # Default agent to invoke when no per-task agent is specified
  agent: task-runner

  # Path to the active PLAN.md (relative to PROJECT_ROOT)
  plan: docs/PLAN.md

# ── Skills always loaded ──────────────────────────────────────────────────────
# These skills are injected into every agent invocation in addition to
# FRAMEWORK_SKILLS. Add domain-specific or project-specific skills here.
skills:
  always:
    - plan-management
    # - <your-domain-skill>   # e.g., payment-processing, supabase-rls-patterns

# ── Knowledge plane ───────────────────────────────────────────────────────────
knowledge:
  # Controls when `ars import` runs during Stage -1 sync.
  # VALID VALUES:
  #   never           — Never auto-import; require explicit 'skeleton sync --import'
  #   on_missing      — Import only when .ai/ directory is absent
  #   merge_on_stale  — Import when legacy provider files are newer than .ai/ (default)
  #   always          — Always import on every 'skeleton run'
  import_policy: merge_on_stale

#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# skeleton — CLI for the skeleton-parallel framework
# ─────────────────────────────────────────────────────────────────────────────
# Initialize, upgrade, and manage projects using the skeleton-parallel
# modular monolith framework with AI-assisted parallel development.
#
# Usage:
#   skeleton init <language> [--name=NAME] [--dir=DIR]
#   skeleton upgrade [--dir=DIR]
#   skeleton doctor [--dir=DIR]
#   skeleton add skill <name> [--dir=DIR]
#   skeleton add agent <name> [--dir=DIR]
#   skeleton list [skills|agents|templates]
#   skeleton sync [--dir=DIR]
#   skeleton version
#   skeleton help
#
# Supported languages: go, python, typescript, nodejs, rust, java
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

VERSION="1.1.0"

# ── Resolve skeleton-parallel root ───────────────────────────────────────────
SKELETON_BIN="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKELETON_ROOT="$(cd "${SKELETON_BIN}/.." && pwd)"
TEMPLATES_DIR="${SKELETON_ROOT}/templates"

# ── Copilot Agent Configuration ─────────────────────────────────────────────
COPILOT_MODEL="${COPILOT_MODEL:-claude-sonnet-4.6}"
COPILOT_LOG_DIR=".parallel-dev/agent-logs"
# All 28 skills — injected into every agent prompt
COPILOT_SKILLS="dto, pipeline, modularity, determinism, idempotency, failure, config-validation, code-quality, coding-standards, database-portability, docs-sync, conflict-resolution, token-optimization, running-prompt, security-audit, test-generation, vertical-slice, api-design, project-scaffold, dependency-analysis, migration-management, performance-optimization, caveman, brainstorming, writing-plans, subagent-driven-development, test-driven-development, rtk"
# Workspace constraint — prevent agents from writing outside project
COPILOT_WORKSPACE_CONSTRAINT="WORKSPACE CONSTRAINT: NEVER write files outside this project directory. Use .parallel-dev/ for temporary artifacts and output/ for generated files."

# ── Colors ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# ── Logging ──────────────────────────────────────────────────────────────────
log_info()  { echo -e "${BLUE}[INFO]${NC}  $*"; }
log_ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }
log_step()  { echo -e "${CYAN}[STEP]${NC}  $*"; }

# ── Helpers ──────────────────────────────────────────────────────────────────
die() { log_error "$@"; exit 1; }

confirm() {
    local prompt="${1:-Continue?}"
    read -rp "$(echo -e "${YELLOW}${prompt} [y/N]${NC} ")" answer
    [[ "${answer}" =~ ^[Yy]$ ]]
}

# Escape a string for safe use in sed replacement patterns
# Handles /, &, \, and newlines
_sed_escape() {
    printf '%s' "$1" | sed -e 's/[\/&\\]/\\&/g'
}

# Validate project name — only allow safe characters
_validate_project_name() {
    local name="$1"
    if [[ ${#name} -gt 255 ]]; then
        die "Project name too long (max 255 chars)"
    fi
    if [[ ! "${name}" =~ ^[a-zA-Z][a-zA-Z0-9._-]*$ ]]; then
        die "Invalid project name '${name}'. Must start with a letter, contain only [a-zA-Z0-9._-]"
    fi
}

# ── Copilot Agent Helpers ────────────────────────────────────────────────────

# Check if Copilot CLI is available — required for agent-first workflow
_check_copilot_available() {
    if command -v copilot &>/dev/null; then
        return 0
    fi
    return 1
}

# Require Copilot CLI — die if not found
_require_copilot() {
    if ! _check_copilot_available; then
        die "Copilot CLI is required. Install with: npm install -g @githubnext/github-copilot-cli\nAlternative: use --no-agent to skip agent validation."
    fi
}

# Spawn a Copilot agent in foreground (blocking — waits for completion)
# Usage: _spawn_copilot_agent <work_dir> <agent_name> <prompt> [log_label]
_spawn_copilot_agent() {
    local work_dir="$1"
    local agent_name="$2"
    local prompt="$3"
    local log_label="${4:-${agent_name}}"

    if [[ "${SKIP_AGENT:-false}" == "true" ]]; then
        log_info "Agent spawning skipped (--no-agent)"
        return 0
    fi

    _require_copilot

    local log_dir="${work_dir}/${COPILOT_LOG_DIR}"
    mkdir -p "${log_dir}"
    local log_file="${log_dir}/${log_label}-$(date +%Y%m%d-%H%M%S).log"

    log_step "Spawning agent: ${BOLD}${agent_name}${NC} (model: ${COPILOT_MODEL})"

    (
        cd "${work_dir}"
        copilot \
            -p "${prompt} MANDATORY: Use skills as primary knowledge source (${COPILOT_SKILLS}). Follow all constraints in .github/copilot-instructions.md. ${COPILOT_WORKSPACE_CONSTRAINT}" \
            --agent="${agent_name}" \
            --model="${COPILOT_MODEL}" \
            --no-ask-user \
            --allow-all-tools \
            --autopilot \
            2>&1 | tee "${log_file}"
    )
    local exit_code=${PIPESTATUS[0]:-$?}

    if [[ ${exit_code} -eq 0 ]]; then
        log_ok "Agent ${agent_name} completed successfully"
    else
        log_error "Agent ${agent_name} failed (exit ${exit_code}). Log: ${log_file}"
    fi
    return ${exit_code}
}

# Spawn a Copilot agent in background (non-blocking — returns immediately)
# Usage: _spawn_copilot_agent_bg <work_dir> <agent_name> <prompt> [log_label]
_spawn_copilot_agent_bg() {
    local work_dir="$1"
    local agent_name="$2"
    local prompt="$3"
    local log_label="${4:-${agent_name}}"

    if [[ "${SKIP_AGENT:-false}" == "true" ]]; then
        return 0
    fi

    if ! _check_copilot_available; then
        log_warn "Copilot CLI not found — skipping background agent"
        return 0
    fi

    local log_dir="${work_dir}/${COPILOT_LOG_DIR}"
    mkdir -p "${log_dir}"
    local log_file="${log_dir}/${log_label}-$(date +%Y%m%d-%H%M%S).log"

    log_info "Spawning background agent: ${agent_name} (log: ${log_file})"

    (
        cd "${work_dir}"
        copilot \
            -p "${prompt} MANDATORY: Use skills as primary knowledge source (${COPILOT_SKILLS}). Follow all constraints in .github/copilot-instructions.md. ${COPILOT_WORKSPACE_CONSTRAINT}" \
            --agent="${agent_name}" \
            --model="${COPILOT_MODEL}" \
            --no-ask-user \
            --allow-all-tools \
            --autopilot \
            &>"${log_file}"
    ) &
    local bg_pid=$!
    log_info "Background agent PID: ${bg_pid}"
}

# Detect existing skeleton-parallel mechanisms in a directory
# Returns space-separated list of found mechanisms
_detect_existing_mechanisms() {
    local dir="$1"
    local found=()

    [[ -f "${dir}/.github/copilot-instructions.md" ]] && found+=("copilot-instructions")
    [[ -d "${dir}/.github/skills" ]] && found+=("skills")
    [[ -d "${dir}/.github/agents" ]] && found+=("agents")
    [[ -d "${dir}/.github/prompts" ]] && found+=("prompts")
    [[ -f "${dir}/scripts/run_parallel.sh" ]] && found+=("run_parallel")
    [[ -f "${dir}/config/phases.yaml" ]] && found+=("phases_config")

    # Check for spec docs
    for doc in architecture.md implementation_roadmap.md orchestrator_spec.md dto_contracts.md db_adapter_spec.md; do
        if [[ -f "${dir}/docs/${doc}" ]]; then
            found+=("docs_templates")
            break
        fi
    done

    echo "${found[*]}"
}

# Detect missing skeleton-parallel files in a directory
# Prints each missing path (relative to dir), one per line
_detect_missing_files() {
    local dir="$1"

    # .github components
    [[ ! -f "${dir}/.github/copilot-instructions.md" ]] && echo ".github/copilot-instructions.md"
    [[ ! -d "${dir}/.github/skills" ]]                   && echo ".github/skills/"
    [[ ! -d "${dir}/.github/agents" ]]                   && echo ".github/agents/"
    [[ ! -d "${dir}/.github/prompts" ]]                  && echo ".github/prompts/"

    # Scripts
    [[ ! -f "${dir}/scripts/run_parallel.sh" ]] && echo "scripts/run_parallel.sh"

    # Config
    [[ ! -f "${dir}/config/phases.yaml" ]] && echo "config/phases.yaml"

    # Docs
    for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
               dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
               AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
        [[ ! -f "${dir}/docs/${doc}" ]] && echo "docs/${doc}"
    done
}

# Prompt user for upgrade mode when existing mechanisms are detected
# Returns: "replace", "hybrid", or "skip"
_prompt_upgrade_mode() {
    local dir="$1"
    local mechanisms="$2"

    echo "" >&2
    echo -e "${YELLOW}[WARN]${NC}  Existing skeleton-parallel mechanisms detected:" >&2
    for mech in ${mechanisms}; do
        echo -e "    ${YELLOW}●${NC} ${mech}" >&2
    done
    echo "" >&2
    echo -e "${BOLD}Choose upgrade mode:${NC}" >&2
    echo -e "  ${GREEN}[R]eplace${NC}  — Remove existing mechanisms, install fresh from skeleton-parallel" >&2
    echo -e "  ${CYAN}[H]ybrid${NC}   — Merge additively (add missing, preserve existing custom files)" >&2
    echo -e "  ${YELLOW}[S]kip${NC}     — Don't touch existing mechanisms, install only new components" >&2
    echo "" >&2
    read -rp "$(echo -e "${BOLD}Mode [R/H/S]: ${NC}")" mode_choice
    # Normalize input
    case "${mode_choice,,}" in
        r|replace)  printf 'replace' ;;
        h|hybrid)   printf 'hybrid' ;;
        s|skip)     printf 'skip' ;;
        *)          printf 'hybrid' ;;  # Default to hybrid (safest)
    esac
}

# Substitute template placeholders in a file
# Usage: substitute_placeholders <file> <project_name> <module_name>
substitute_placeholders() {
    local file="$1"
    local project_name="$2"
    local module_name="${3:-app}"

    # Derive common names
    local project_snake
    project_snake="$(echo "${project_name}" | tr '-' '_' | tr '[:upper:]' '[:lower:]')"
    local project_pascal
    project_pascal="$(echo "${project_name}" | sed -E 's/(^|[-_ ])([a-z])/\U\2/g')"

    # Escape all values for safe sed usage
    local esc_name esc_snake esc_pascal esc_module esc_year
    esc_name="$(_sed_escape "${project_name}")"
    esc_snake="$(_sed_escape "${project_snake}")"
    esc_pascal="$(_sed_escape "${project_pascal}")"
    esc_module="$(_sed_escape "${module_name}")"
    esc_year="$(date +%Y)"

    if [[ -f "${file}" ]]; then
        sed -i.bak \
            -e "s/{{PROJECT_NAME}}/${esc_name}/g" \
            -e "s/{{PROJECT_SNAKE}}/${esc_snake}/g" \
            -e "s/{{PROJECT_PASCAL}}/${esc_pascal}/g" \
            -e "s/{{MODULE_NAME}}/${esc_module}/g" \
            -e "s/{{YEAR}}/${esc_year}/g" \
            -e "s|example\.com/myapp|${esc_name}|g" \
            "${file}"
        rm -f "${file}.bak"
    fi
}

# Recursively substitute placeholders in all files in a directory
substitute_all() {
    local dir="$1"
    local project_name="$2"
    local module_name="${3:-app}"

    find "${dir}" -type f \( -name '*.go' -o -name '*.py' -o -name '*.ts' -o -name '*.js' \
        -o -name '*.rs' -o -name '*.java' -o -name '*.md' -o -name '*.yaml' -o -name '*.yml' \
        -o -name '*.json' -o -name '*.toml' -o -name '*.mod' -o -name '*.xml' \
        -o -name 'Makefile' -o -name '*.txt' -o -name '*.cfg' -o -name '*.sh' \) | while read -r f; do
        substitute_placeholders "${f}" "${project_name}" "${module_name}"
    done
}

# ── Available resources ──────────────────────────────────────────────────────
SUPPORTED_LANGUAGES=("go" "python" "typescript" "nodejs" "rust" "java")

get_available_skills() {
    local skills_dir="${SKELETON_ROOT}/.github/skills"
    if [[ -d "${skills_dir}" ]]; then
        find "${skills_dir}" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort
    fi
}

get_available_agents() {
    local agents_dir="${SKELETON_ROOT}/.github/agents"
    if [[ -d "${agents_dir}" ]]; then
        find "${agents_dir}" -name '*.agent.md' -exec basename {} .agent.md \; | sort
    fi
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: init
# ═════════════════════════════════════════════════════════════════════════════
cmd_init() {
    local language=""
    local project_name=""
    local target_dir=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name=*) project_name="${1#*=}"; shift ;;
            --dir=*)  target_dir="${1#*=}"; shift ;;
            --name)   project_name="${2}"; shift 2 ;;
            --dir)    target_dir="${2}"; shift 2 ;;
            --no-agent) SKIP_AGENT=true; shift ;;
            -*)       die "Unknown option: $1" ;;
            *)
                if [[ -z "${language}" ]]; then
                    language="$1"
                else
                    die "Unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    # Validate language
    if [[ -z "${language}" ]]; then
        die "Usage: skeleton init <language> [--name=NAME] [--dir=DIR]\nSupported: ${SUPPORTED_LANGUAGES[*]}"
    fi

    local lang_found=false
    for l in "${SUPPORTED_LANGUAGES[@]}"; do
        [[ "${language}" == "${l}" ]] && lang_found=true
    done
    if ! ${lang_found}; then
        die "Unsupported language: ${language}\nSupported: ${SUPPORTED_LANGUAGES[*]}"
    fi

    # Default project name from current directory
    if [[ -z "${project_name}" ]]; then
        if [[ -n "${target_dir}" ]]; then
            project_name="$(basename "${target_dir}")"
        else
            read -rp "$(echo -e "${CYAN}Project name: ${NC}")" project_name
            [[ -z "${project_name}" ]] && die "Project name is required"
        fi
    fi

    # Validate project name for safety
    _validate_project_name "${project_name}"

    # Default target directory
    if [[ -z "${target_dir}" ]]; then
        target_dir="./${project_name}"
    fi

    # Resolve absolute path
    target_dir="$(cd "$(dirname "${target_dir}")" 2>/dev/null && pwd)/$(basename "${target_dir}")" || target_dir="$(pwd)/${project_name}"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton init                               ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    log_info "Language:     ${BOLD}${language}${NC}"
    log_info "Project:      ${BOLD}${project_name}${NC}"
    log_info "Directory:    ${BOLD}${target_dir}${NC}"
    echo ""

    if [[ -d "${target_dir}" ]]; then
        local file_count
        file_count="$(find "${target_dir}" -maxdepth 1 -not -name '.' | wc -l | tr -d ' ')"
        if [[ "${file_count}" -gt 0 ]]; then
            log_warn "Directory ${target_dir} already exists and is not empty."
            confirm "Overwrite?" || die "Aborted."
        fi
    fi

    mkdir -p "${target_dir}"

    # ── Step 1: Copy common files ─────────────────────────────────────────
    log_step "Copying common framework files..."
    _copy_common "${target_dir}"

    # ── Step 2: Copy language-specific template ───────────────────────────
    log_step "Applying ${language} template..."
    local lang_template="${TEMPLATES_DIR}/${language}"
    if [[ -d "${lang_template}" ]]; then
        cp -R "${lang_template}/." "${target_dir}/"
    else
        die "Template not found: ${lang_template}"
    fi

    # ── Step 3: Substitute placeholders ───────────────────────────────────
    log_step "Customizing project files..."
    substitute_all "${target_dir}" "${project_name}"

    # ── Step 4: Initialize git ────────────────────────────────────────────
    log_step "Initializing Git repository..."
    (
        cd "${target_dir}"
        if [[ ! -d ".git" ]]; then
            git init -q
            git add -A
            git commit -q -m "Initial commit: skeleton-parallel ${language} project (${project_name})"
        fi
    )

    # ── Step 5: Post-init setup ───────────────────────────────────────────
    log_step "Running post-init setup for ${language}..."
    _post_init_setup "${language}" "${target_dir}" "${project_name}"

    # ── Step 6: Spawn Copilot agent for project validation ────────────────
    log_step "Spawning Copilot agent for project validation..."
    _spawn_copilot_agent "${target_dir}" "scaffold" \
        "You are validating a newly initialized ${language} project named '${project_name}'. Perform a complete validation: 1) All docs/ templates exist (architecture.md, dto_contracts.md, orchestrator_spec.md, db_adapter_spec.md, implementation_roadmap.md, PARALLEL_DEV.md, AGENTS_AND_SKILLS.md, STARTER_GUIDE.md, PROGRESS_REPORT.md). 2) config/phases.yaml is present and properly structured. 3) scripts/run_parallel.sh is present and executable. 4) .github/ has all 28 skills, 14 agents, 5 prompts, and copilot-instructions.md. 5) Language-specific structure (${language}) matches skeleton-parallel modular monolith standards — contracts/ for DTOs, database/ for adapter, app/modules/ or src/modules/ for domain modules. 6) Health module reference implementation exists and is properly wired. 7) Ensure the project can seamlessly run parallel development via run_parallel.sh. Fix any issues found. After fixing, commit changes with message 'chore: post-init validation fixes'." \
        "init-validation"

    echo ""
    log_ok "Project ${BOLD}${project_name}${NC} initialized successfully!"
    echo ""
    echo -e "  ${CYAN}Next steps:${NC}"
    echo -e "    cd ${target_dir}"
    echo -e "    # Generate architecture:  @workspace Use .github/prompts/architecture.prompt.md"
    echo -e "    # Generate roadmap:       @workspace Use .github/prompts/roadmap.prompt.md"
    echo -e "    # Run doctor:             skeleton doctor"
    echo -e "    # Start parallel dev:     ./scripts/run_parallel.sh start --mode=3 1 2 3"
    echo ""
}

_copy_common() {
    local dest="$1"

    # .github directory (skills, agents, prompts, copilot-instructions)
    mkdir -p "${dest}/.github"
    if [[ -d "${SKELETON_ROOT}/.github/skills" ]]; then
        cp -R "${SKELETON_ROOT}/.github/skills" "${dest}/.github/"
    fi
    if [[ -d "${SKELETON_ROOT}/.github/agents" ]]; then
        cp -R "${SKELETON_ROOT}/.github/agents" "${dest}/.github/"
    fi
    if [[ -d "${SKELETON_ROOT}/.github/prompts" ]]; then
        cp -R "${SKELETON_ROOT}/.github/prompts" "${dest}/.github/"
    fi
    if [[ -f "${SKELETON_ROOT}/.github/copilot-instructions.md" ]]; then
        cp "${SKELETON_ROOT}/.github/copilot-instructions.md" "${dest}/.github/"
    fi

    # Scripts
    mkdir -p "${dest}/scripts"
    if [[ -f "${SKELETON_ROOT}/scripts/run_parallel.sh" ]]; then
        cp "${SKELETON_ROOT}/scripts/run_parallel.sh" "${dest}/scripts/"
        chmod +x "${dest}/scripts/run_parallel.sh"
    fi

    # Config
    mkdir -p "${dest}/config"
    if [[ -f "${SKELETON_ROOT}/config/phases.yaml" ]]; then
        cp "${SKELETON_ROOT}/config/phases.yaml" "${dest}/config/"
    fi

    # Docs templates
    mkdir -p "${dest}/docs"
    for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
               dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
               AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
        if [[ -f "${SKELETON_ROOT}/docs/${doc}" ]]; then
            cp "${SKELETON_ROOT}/docs/${doc}" "${dest}/docs/"
        fi
    done

    # Output directory
    mkdir -p "${dest}/output"
    echo '*' > "${dest}/output/.gitignore"
}

_post_init_setup() {
    local language="$1"
    local target_dir="$2"
    local project_name="$3"

    case "${language}" in
        go)
            log_info "Tip: Run 'go mod tidy' to install dependencies."
            ;;
        python)
            log_info "Tip: Run 'python -m venv .venv && pip install -r requirements.txt' to set up."
            ;;
        typescript)
            log_info "Tip: Run 'npm install' to install dependencies."
            ;;
        nodejs)
            log_info "Tip: Run 'npm install' to install dependencies, then 'npm test' to run tests."
            ;;
        rust)
            log_info "Tip: Run 'cargo build' to compile the project."
            ;;
        java)
            log_info "Tip: Run 'mvn compile' or 'gradle build' to compile."
            ;;
    esac
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: upgrade — helper: spawn Explore to analyze project before install
# Writes .parallel-dev/upgrade-context.md for use by upgrade-manager
# ═════════════════════════════════════════════════════════════════════════════
_upgrade_analyze_context() {
    local target_dir="$1"
    local detected_lang="$2"
    local context_file="${target_dir}/.parallel-dev/upgrade-context.md"

    mkdir -p "${target_dir}/.parallel-dev/agent-logs"

    # Ensure Explore agent exists in target project (may not be installed yet)
    local explore_agent_dst="${target_dir}/.github/agents/Explore.agent.md"
    local explore_agent_src="${SKELETON_ROOT}/.github/agents/Explore.agent.md"
    if [[ ! -f "${explore_agent_dst}" ]] && [[ -f "${explore_agent_src}" ]]; then
        mkdir -p "${target_dir}/.github/agents"
        cp "${explore_agent_src}" "${explore_agent_dst}"
        log_info "Installed Explore agent to target project (for pre-upgrade analysis)"
    fi

    _spawn_copilot_agent "${target_dir}" "Explore" \
        "Analyze this ${detected_lang:-unknown} project BEFORE skeleton-parallel installation. Write a structured report to .parallel-dev/upgrade-context.md covering:

## 1. Project Structure
- Actual source layout (module/package directories, entry points)
- Detected domains/features — list each as a potential parallel-dev phase
- Language version and key runtime dependencies

## 2. Database
- Database engine (postgres, sqlite, mysql, etc.) if any
- Migration tool in use (flyway, alembic, goose, liquibase, etc.)
- ORM or query builder in use

## 3. Testing
- Test framework(s) and test runner commands
- Location of test files
- CI configuration (GitHub Actions, CircleCI, Jenkins, etc.)

## 4. Git & Collaboration
- Git remote URL and platform (GitHub, GitLab, Bitbucket)
- Default branch name (main, master, etc.)
- Existing branch naming conventions
- PR/MR label conventions if any

## 5. Existing Scripts & Automation
- Makefile targets or scripts that overlap with run_parallel.sh
- Any existing parallel/concurrent task runners or CI pipeline definitions

## 6. Phase Candidates
- List 3-8 concrete phase names derived from the actual codebase structure
- Each entry: phase name, what it implements, rough dependency order
- Example: 'phase-auth: JWT authentication layer, depends on phase-db'

## 7. config/phases.yaml Suggestions
- Propose the phases.yaml 'phases:' block tailored to this project's domains
- Use actual module names, not generic placeholders

## 8. scripts/run_parallel.sh Adaptation Notes
- Any env vars that need to change (PR_LABEL, DEFAULT_BRANCH, etc.)
- Integration branch naming that fits the project's conventions

## 9. Upgrade Risks
- Files or patterns that might conflict with skeleton-parallel conventions
- Any non-standard structures that need special handling during upgrade

Write the complete report to: .parallel-dev/upgrade-context.md
Do NOT modify any other project files." \
        "upgrade-context-analysis"
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: upgrade
# ═════════════════════════════════════════════════════════════════════════════
# ── Preview what an upgrade mode will change (dry-run, no writes) ────────
_upgrade_preview() {
    local target_dir="$1"
    local upgrade_mode="$2"

    echo ""
    log_step "Preview — changes that will be applied (${BOLD}${upgrade_mode}${NC} mode):"
    echo ""

    local skills_count
    skills_count="$(get_available_skills | wc -l | tr -d ' ')"
    local agents_count
    agents_count="$(get_available_agents | wc -l | tr -d ' ')"

    case "${upgrade_mode}" in
        replace)
            echo -e "  ${RED}[replace]${NC}  .github/skills/        (${skills_count} skills — all overwritten)"
            echo -e "  ${RED}[replace]${NC}  .github/agents/        (${agents_count} agents — all overwritten)"
            echo -e "  ${RED}[replace]${NC}  .github/prompts/"
            echo -e "  ${RED}[replace]${NC}  .github/copilot-instructions.md"
            echo -e "  ${RED}[replace]${NC}  scripts/run_parallel.sh"
            echo -e "  ${RED}[replace]${NC}  config/phases.yaml"
            for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
                       dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
                       AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
                echo -e "  ${RED}[replace]${NC}  docs/${doc}"
            done
            ;;
        hybrid)
            echo -e "  ${GREEN}[update]${NC}   .github/skills/        (${skills_count} skills — always synced)"
            echo -e "  ${GREEN}[update]${NC}   .github/agents/        (${agents_count} agents — always synced)"
            echo -e "  ${GREEN}[update]${NC}   .github/prompts/       (always synced)"
            echo -e "  ${GREEN}[update]${NC}   scripts/run_parallel.sh"
            if [[ -f "${target_dir}/.github/copilot-instructions.md" ]]; then
                echo -e "  ${CYAN}[preserve]${NC} .github/copilot-instructions.md (exists — kept as-is)"
            else
                echo -e "  ${GREEN}[install]${NC}  .github/copilot-instructions.md (missing — will install)"
            fi
            if [[ -f "${target_dir}/config/phases.yaml" ]]; then
                echo -e "  ${CYAN}[preserve]${NC} config/phases.yaml (exists — kept as-is)"
            else
                echo -e "  ${GREEN}[install]${NC}  config/phases.yaml (missing — will install)"
            fi
            for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
                       dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
                       AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
                if [[ -f "${target_dir}/docs/${doc}" ]]; then
                    echo -e "  ${CYAN}[preserve]${NC} docs/${doc} (exists — kept as-is)"
                else
                    echo -e "  ${GREEN}[install]${NC}  docs/${doc} (missing — will install)"
                fi
            done
            ;;
        skip)
            for item in ".github/skills" ".github/agents" ".github/prompts"; do
                if [[ -d "${target_dir}/${item}" ]]; then
                    echo -e "  ${YELLOW}[skip]${NC}     ${item}/ (exists — no changes)"
                else
                    echo -e "  ${GREEN}[install]${NC}  ${item}/ (missing — will install)"
                fi
            done
            if [[ -f "${target_dir}/.github/copilot-instructions.md" ]]; then
                echo -e "  ${YELLOW}[skip]${NC}     .github/copilot-instructions.md (exists — no changes)"
            else
                echo -e "  ${GREEN}[install]${NC}  .github/copilot-instructions.md (missing — will install)"
            fi
            if [[ -f "${target_dir}/scripts/run_parallel.sh" ]]; then
                echo -e "  ${YELLOW}[skip]${NC}     scripts/run_parallel.sh (exists — no changes)"
            else
                echo -e "  ${GREEN}[install]${NC}  scripts/run_parallel.sh (missing — will install)"
            fi
            if [[ -f "${target_dir}/config/phases.yaml" ]]; then
                echo -e "  ${YELLOW}[skip]${NC}     config/phases.yaml (exists — no changes)"
            else
                echo -e "  ${GREEN}[install]${NC}  config/phases.yaml (missing — will install)"
            fi
            for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
                       dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
                       AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
                if [[ -f "${target_dir}/docs/${doc}" ]]; then
                    echo -e "  ${YELLOW}[skip]${NC}     docs/${doc} (exists — no changes)"
                else
                    echo -e "  ${GREEN}[install]${NC}  docs/${doc} (missing — will install)"
                fi
            done
            ;;
    esac
    echo ""
    echo -e "  ${GREEN}[update]${NC}   = overwrite with latest skeleton version"
    echo -e "  ${GREEN}[install]${NC}  = copy from skeleton (file does not exist yet)"
    echo -e "  ${CYAN}[preserve]${NC} = keep your existing file unchanged"
    echo -e "  ${RED}[replace]${NC}  = remove existing and install fresh skeleton version"
    echo -e "  ${YELLOW}[skip]${NC}     = file exists, no action taken"
    echo ""
}

cmd_upgrade() {
    local target_dir="."
    local force_mode=""
    local no_analyze=false
    local auto_yes=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*)      target_dir="${1#*=}"; shift ;;
            --dir)        target_dir="${2}"; shift 2 ;;
            --mode=*)     force_mode="${1#*=}"; shift ;;
            --no-agent)   SKIP_AGENT=true; shift ;;
            --no-analyze) no_analyze=true; shift ;;
            -y|--yes)     auto_yes=true; shift ;;
            -*)           die "Unknown option: $1" ;;
            *)            target_dir="$1"; shift ;;
        esac
    done

    target_dir="$(cd "${target_dir}" 2>/dev/null && pwd)" || die "Directory not found: ${target_dir}"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton upgrade                            ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    log_info "Target: ${BOLD}${target_dir}${NC}"
    echo ""

    # ── Step 0: Detect language ────────────────────────────────────────────
    log_step "Detecting project language..."
    local detected_lang
    detected_lang="$(_detect_language "${target_dir}")"
    if [[ -n "${detected_lang}" ]]; then
        log_ok "Detected language: ${BOLD}${detected_lang}${NC}"
    else
        log_warn "Could not auto-detect language."
    fi
    echo ""

    # ── Step 1: Pre-upgrade analysis (Explore agent) ──────────────────────
    local context_file="${target_dir}/.parallel-dev/upgrade-context.md"
    if _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]] && [[ "${no_analyze}" != "true" ]]; then
        if [[ -f "${context_file}" ]]; then
            log_info "Pre-upgrade analysis already exists — skipping (use --no-analyze to skip, or delete .parallel-dev/upgrade-context.md to re-run)"
        else
            log_step "Spawning Explore agent to analyze project before installing..."
            log_info "The agent will explore the project and write a context report."
            echo ""
            _upgrade_analyze_context "${target_dir}" "${detected_lang}" || true
        fi
    elif [[ "${no_analyze}" == "true" ]]; then
        log_info "Pre-upgrade analysis skipped (--no-analyze)"
    fi
    echo ""

    # ── Step 2: Detect existing mechanisms ────────────────────────────────
    log_step "Detecting existing skeleton-parallel mechanisms..."
    local existing_mechanisms
    existing_mechanisms="$(_detect_existing_mechanisms "${target_dir}")"

    # Report missing files before deciding upgrade mode
    local missing_files=()
    while IFS= read -r line; do
        [[ -n "${line}" ]] && missing_files+=("${line}")
    done < <(_detect_missing_files "${target_dir}")

    if [[ ${#missing_files[@]} -gt 0 ]]; then
        echo ""
        log_warn "Missing skeleton-parallel files detected (${#missing_files[@]} item(s)):"
        for f in "${missing_files[@]}"; do
            echo -e "    ${RED}✗${NC} ${f}"
        done
        echo ""
    else
        log_ok "All skeleton-parallel files present"
    fi

    local upgrade_mode="replace"
    if [[ -n "${existing_mechanisms}" ]]; then
        if [[ -n "${force_mode}" ]]; then
            upgrade_mode="${force_mode}"
            log_info "Using forced mode: ${upgrade_mode}"
        else
            upgrade_mode="$(_prompt_upgrade_mode "${target_dir}" "${existing_mechanisms}")"
        fi
        log_info "Upgrade mode: ${BOLD}${upgrade_mode}${NC}"
    else
        log_ok "No existing mechanisms found — full install"
    fi
    echo ""

    # ── Step 2: Preview changes + confirm before writing anything ─────────
    _upgrade_preview "${target_dir}" "${upgrade_mode}"

    if [[ "${auto_yes}" != true ]]; then
        printf "%b" "${BOLD}Apply these changes? [y/N]: ${NC}"
        read -r proceed_choice
        echo ""
        if [[ "${proceed_choice,,}" != "y" && "${proceed_choice,,}" != "yes" ]]; then
            log_info "Aborted. No files were modified."
            echo ""
            return 0
        fi
    fi

    # ── Step 3: Apply upgrade based on mode ───────────────────────────────
    case "${upgrade_mode}" in
        replace)
            _upgrade_replace "${target_dir}"
            ;;
        hybrid)
            _upgrade_hybrid "${target_dir}"
            ;;
        skip)
            _upgrade_skip "${target_dir}"
            ;;
    esac

    # ── Step 2b: Confirm no missing files remain ──────────────────────────
    local remaining_missing=()
    while IFS= read -r line; do
        [[ -n "${line}" ]] && remaining_missing+=("${line}")
    done < <(_detect_missing_files "${target_dir}")

    if [[ ${#remaining_missing[@]} -eq 0 ]]; then
        log_ok "All skeleton-parallel files are now present"
    else
        log_warn "${#remaining_missing[@]} file(s) still missing after upgrade:"
        for f in "${remaining_missing[@]}"; do
            echo -e "    ${RED}✗${NC} ${f}"
        done
    fi
    echo ""

    # ── Step 3: Spawn upgrade-manager for context-aware post-upgrade adaptation ──
    log_step "Spawning upgrade-manager agent for context-aware adaptation..."
    local context_hint=""
    if [[ -f "${context_file}" ]]; then
        context_hint="A pre-upgrade analysis report is available at .parallel-dev/upgrade-context.md — READ IT FIRST before making any decisions. Use the Phase Candidates, config/phases.yaml Suggestions, and Adaptation Notes sections to customize installed files for this specific project."
    else
        context_hint="No pre-upgrade analysis report was generated. Analyze the project structure yourself before making changes."
    fi
    _spawn_copilot_agent "${target_dir}" "upgrade-manager" \
        "The skeleton-parallel framework files have just been installed into this ${detected_lang:-unknown} project. ${context_hint}

Your job:
1) READ .parallel-dev/upgrade-context.md (if present) to understand the actual project structure.
2) Adapt config/phases.yaml — replace generic phase placeholders with the actual phase names and dependencies found in the codebase. Use the 'Phase Candidates' and 'config/phases.yaml Suggestions' sections from the context report.
3) Adapt scripts/run_parallel.sh env vars — set DEFAULT_BRANCH, PR_LABEL, and any other vars to match the project's Git conventions from the context report.
4) Verify all installed files are correct (.github/skills, .github/agents, .github/prompts, copilot-instructions.md, run_parallel.sh, phases.yaml, docs/ templates).
5) Check that the project's existing code follows skeleton-parallel modular monolith standards (contracts/ for DTOs, database/ for adapter, app/modules/ or src/modules/ or internal/modules/ for domain modules).
6) Fix any structural violations — move files to correct locations, add missing boilerplate.
7) Validate that scripts/run_parallel.sh would run successfully end-to-end: correct branch names, valid phase config, working git remote, gh CLI available for PR creation.
8) Commit all adaptations with message 'chore: post-upgrade adaptation (context-aware)'.
9) Run 'skeleton doctor' to confirm all checks pass." \
        "upgrade-adaptation" || \
        log_warn "Post-upgrade agent skipped — agents not yet available in this context. Run 'skeleton doctor --dir=${target_dir}' after opening the project in VS Code."

    echo ""
    log_ok "Upgrade complete!"
    echo ""
    echo -e "  ${CYAN}Next steps:${NC}"
    echo -e "    skeleton doctor --dir=${target_dir}"
    echo -e "    # Review and customize .github/copilot-instructions.md"
    echo -e "    # Configure config/phases.yaml for your phases"
    echo ""
}

# ── Upgrade mode: Replace ─────────────────────────────────────────────────
# Remove existing mechanisms, install fresh from skeleton-parallel
_upgrade_replace() {
    local target_dir="$1"

    log_step "Mode: REPLACE — Installing fresh skeleton-parallel mechanisms..."

    # Remove existing and reinstall
    log_step "Upgrading .github/ (skills, agents, prompts, instructions)..."
    mkdir -p "${target_dir}/.github"

    # Force overwrite all .github components
    [[ -d "${target_dir}/.github/skills" ]] && rm -rf "${target_dir}/.github/skills"
    [[ -d "${target_dir}/.github/agents" ]] && rm -rf "${target_dir}/.github/agents"
    [[ -d "${target_dir}/.github/prompts" ]] && rm -rf "${target_dir}/.github/prompts"

    cp -R "${SKELETON_ROOT}/.github/skills" "${target_dir}/.github/"
    log_ok "Skills replaced ($(get_available_skills | wc -l | tr -d ' ') skills)"
    cp -R "${SKELETON_ROOT}/.github/agents" "${target_dir}/.github/"
    log_ok "Agents replaced ($(get_available_agents | wc -l | tr -d ' ') agents)"
    [[ -d "${SKELETON_ROOT}/.github/prompts" ]] && cp -R "${SKELETON_ROOT}/.github/prompts" "${target_dir}/.github/"
    log_ok "Prompts replaced"

    # Force overwrite copilot-instructions
    cp "${SKELETON_ROOT}/.github/copilot-instructions.md" "${target_dir}/.github/"
    log_ok "copilot-instructions.md replaced"

    # Scripts — force overwrite
    log_step "Replacing scripts/..."
    mkdir -p "${target_dir}/scripts"
    cp "${SKELETON_ROOT}/scripts/run_parallel.sh" "${target_dir}/scripts/"
    chmod +x "${target_dir}/scripts/run_parallel.sh"
    log_ok "run_parallel.sh replaced"

    # Config — force overwrite
    log_step "Replacing config/..."
    mkdir -p "${target_dir}/config"
    cp "${SKELETON_ROOT}/config/phases.yaml" "${target_dir}/config/"
    log_ok "phases.yaml replaced"

    # Docs — install all templates (overwrite existing)
    log_step "Replacing doc templates..."
    mkdir -p "${target_dir}/docs"
    local docs_installed=0
    for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
               dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
               AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
        if [[ -f "${SKELETON_ROOT}/docs/${doc}" ]]; then
            cp "${SKELETON_ROOT}/docs/${doc}" "${target_dir}/docs/"
            ((docs_installed++))
        fi
    done
    log_ok "Installed ${docs_installed} doc templates"

    # Output directory
    mkdir -p "${target_dir}/output"
    [[ ! -f "${target_dir}/output/.gitignore" ]] && echo '*' > "${target_dir}/output/.gitignore"
}

# ── Upgrade mode: Hybrid ──────────────────────────────────────────────────
# Merge additively — add missing components, preserve existing custom files
_upgrade_hybrid() {
    local target_dir="$1"

    log_step "Mode: HYBRID — Merging additively (preserving custom files)..."

    # .github — always update skills and agents (these should be current)
    log_step "Upgrading .github/ (skills, agents, prompts)..."
    mkdir -p "${target_dir}/.github"

    if [[ -d "${SKELETON_ROOT}/.github/skills" ]]; then
        cp -R "${SKELETON_ROOT}/.github/skills" "${target_dir}/.github/"
        log_ok "Skills updated ($(get_available_skills | wc -l | tr -d ' ') skills)"
    fi
    if [[ -d "${SKELETON_ROOT}/.github/agents" ]]; then
        cp -R "${SKELETON_ROOT}/.github/agents" "${target_dir}/.github/"
        log_ok "Agents updated ($(get_available_agents | wc -l | tr -d ' ') agents)"
    fi
    if [[ -d "${SKELETON_ROOT}/.github/prompts" ]]; then
        cp -R "${SKELETON_ROOT}/.github/prompts" "${target_dir}/.github/"
        log_ok "Prompts updated"
    fi

    # Copilot instructions — preserve if exists
    if [[ ! -f "${target_dir}/.github/copilot-instructions.md" ]]; then
        cp "${SKELETON_ROOT}/.github/copilot-instructions.md" "${target_dir}/.github/"
        log_ok "copilot-instructions.md installed"
    else
        log_warn "copilot-instructions.md exists — preserved (use 'skeleton sync' to force update)"
    fi

    # Scripts — always update (executable, not customized)
    log_step "Upgrading scripts/..."
    mkdir -p "${target_dir}/scripts"
    cp "${SKELETON_ROOT}/scripts/run_parallel.sh" "${target_dir}/scripts/"
    chmod +x "${target_dir}/scripts/run_parallel.sh"
    log_ok "run_parallel.sh updated"

    # Config — preserve existing, add missing
    log_step "Upgrading config/..."
    mkdir -p "${target_dir}/config"
    if [[ ! -f "${target_dir}/config/phases.yaml" ]]; then
        cp "${SKELETON_ROOT}/config/phases.yaml" "${target_dir}/config/"
        log_ok "phases.yaml installed"
    else
        log_warn "phases.yaml exists — preserved"
    fi

    # Docs — only install missing
    log_step "Installing missing doc templates..."
    mkdir -p "${target_dir}/docs"
    local docs_installed=0
    for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
               dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
               AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
        if [[ ! -f "${target_dir}/docs/${doc}" ]] && [[ -f "${SKELETON_ROOT}/docs/${doc}" ]]; then
            cp "${SKELETON_ROOT}/docs/${doc}" "${target_dir}/docs/"
            log_ok "Installed docs/${doc}"
            ((docs_installed++))
        fi
    done
    [[ ${docs_installed} -eq 0 ]] && log_warn "All doc templates already present — nothing to install"

    # Output directory
    mkdir -p "${target_dir}/output"
    [[ ! -f "${target_dir}/output/.gitignore" ]] && echo '*' > "${target_dir}/output/.gitignore"
}

# ── Upgrade mode: Skip ────────────────────────────────────────────────────
# Install only new components that don't exist yet
_upgrade_skip() {
    local target_dir="$1"

    log_step "Mode: SKIP — Installing only new components..."

    # .github — only add if directory doesn't exist
    mkdir -p "${target_dir}/.github"

    if [[ ! -d "${target_dir}/.github/skills" ]]; then
        cp -R "${SKELETON_ROOT}/.github/skills" "${target_dir}/.github/"
        log_ok "Skills installed (new)"
    else
        log_warn "Skills directory exists — skipped"
    fi
    if [[ ! -d "${target_dir}/.github/agents" ]]; then
        cp -R "${SKELETON_ROOT}/.github/agents" "${target_dir}/.github/"
        log_ok "Agents installed (new)"
    else
        log_warn "Agents directory exists — skipped"
    fi
    if [[ ! -d "${target_dir}/.github/prompts" ]]; then
        [[ -d "${SKELETON_ROOT}/.github/prompts" ]] && cp -R "${SKELETON_ROOT}/.github/prompts" "${target_dir}/.github/"
        log_ok "Prompts installed (new)"
    else
        log_warn "Prompts directory exists — skipped"
    fi

    if [[ ! -f "${target_dir}/.github/copilot-instructions.md" ]]; then
        cp "${SKELETON_ROOT}/.github/copilot-instructions.md" "${target_dir}/.github/"
        log_ok "copilot-instructions.md installed (new)"
    else
        log_warn "copilot-instructions.md exists — skipped"
    fi

    # Scripts — only if missing
    if [[ ! -f "${target_dir}/scripts/run_parallel.sh" ]]; then
        mkdir -p "${target_dir}/scripts"
        cp "${SKELETON_ROOT}/scripts/run_parallel.sh" "${target_dir}/scripts/"
        chmod +x "${target_dir}/scripts/run_parallel.sh"
        log_ok "run_parallel.sh installed (new)"
    else
        log_warn "run_parallel.sh exists — skipped"
    fi

    # Config — only if missing
    if [[ ! -f "${target_dir}/config/phases.yaml" ]]; then
        mkdir -p "${target_dir}/config"
        cp "${SKELETON_ROOT}/config/phases.yaml" "${target_dir}/config/"
        log_ok "phases.yaml installed (new)"
    else
        log_warn "phases.yaml exists — skipped"
    fi

    # Docs — only missing
    mkdir -p "${target_dir}/docs"
    local docs_installed=0
    for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
               dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
               AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
        if [[ ! -f "${target_dir}/docs/${doc}" ]] && [[ -f "${SKELETON_ROOT}/docs/${doc}" ]]; then
            cp "${SKELETON_ROOT}/docs/${doc}" "${target_dir}/docs/"
            log_ok "Installed docs/${doc}"
            ((docs_installed++))
        fi
    done
    [[ ${docs_installed} -eq 0 ]] && log_warn "All doc templates already present — nothing to install"

    # Output directory
    mkdir -p "${target_dir}/output"
    [[ ! -f "${target_dir}/output/.gitignore" ]] && echo '*' > "${target_dir}/output/.gitignore"
}

_detect_language() {
    local dir="$1"
    if [[ -f "${dir}/go.mod" ]]; then echo "go"
    elif [[ -f "${dir}/pyproject.toml" ]] || [[ -f "${dir}/requirements.txt" ]] || [[ -f "${dir}/setup.py" ]]; then echo "python"
    elif [[ -f "${dir}/package.json" ]] && [[ -f "${dir}/tsconfig.json" ]]; then echo "typescript"
    elif [[ -f "${dir}/package.json" ]]; then echo "nodejs"
    elif [[ -f "${dir}/Cargo.toml" ]]; then echo "rust"
    elif [[ -f "${dir}/pom.xml" ]] || [[ -f "${dir}/build.gradle" ]]; then echo "java"
    else echo ""
    fi
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: doctor
# ═════════════════════════════════════════════════════════════════════════════
cmd_doctor() {
    local target_dir="."

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*) target_dir="${1#*=}"; shift ;;
            --dir)   target_dir="${2}"; shift 2 ;;
            --no-agent) SKIP_AGENT=true; shift ;;
            -*)      die "Unknown option: $1" ;;
            *)       target_dir="$1"; shift ;;
        esac
    done

    target_dir="$(cd "${target_dir}" 2>/dev/null && pwd)" || die "Directory not found: ${target_dir}"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton doctor                             ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    log_info "Checking: ${BOLD}${target_dir}${NC}"
    echo ""

    local issues=0
    local warnings=0

    # ── Framework files ───────────────────────────────────────────────────
    log_step "Checking framework files..."

    _check_exists() {
        local path="$1" label="$2" severity="${3:-error}"
        if [[ -e "${target_dir}/${path}" ]]; then
            log_ok "${label}"
        elif [[ "${severity}" == "warn" ]]; then
            log_warn "${label} — MISSING (optional)"
            ((warnings++))
        else
            log_error "${label} — MISSING"
            ((issues++))
        fi
    }

    _check_exists ".github/copilot-instructions.md" "copilot-instructions.md"
    _check_exists "scripts/run_parallel.sh" "run_parallel.sh"
    _check_exists "config/phases.yaml" "phases.yaml"
    _check_exists ".github/skills" "Skills directory"
    _check_exists ".github/agents" "Agents directory"
    _check_exists ".github/prompts" "Prompts directory" "warn"

    # ── Skills inventory ──────────────────────────────────────────────────
    echo ""
    log_step "Checking skills..."
    local core_skills=("dto" "pipeline" "modularity" "determinism" "idempotency"
                       "failure" "config-validation" "code-quality" "coding-standards"
                       "database-portability" "docs-sync" "conflict-resolution"
                       "token-optimization" "running-prompt" "security-audit"
                       "test-generation" "vertical-slice" "api-design"
                       "project-scaffold" "dependency-analysis" "migration-management"
                       "performance-optimization" "caveman" "brainstorming"
                       "writing-plans" "subagent-driven-development"
                       "test-driven-development" "rtk")
    local skill_count=0
    local missing_skills=()
    for skill in "${core_skills[@]}"; do
        if [[ -f "${target_dir}/.github/skills/${skill}/SKILL.md" ]]; then
            ((skill_count++))
        else
            missing_skills+=("${skill}")
        fi
    done
    log_ok "Skills present: ${skill_count}/${#core_skills[@]}"
    if [[ ${#missing_skills[@]} -gt 0 ]]; then
        log_warn "Missing skills: ${missing_skills[*]}"
        ((warnings++))
    fi

    # ── Agents inventory ──────────────────────────────────────────────────
    echo ""
    log_step "Checking agents..."
    local core_agents=("phase-builder" "dto-guardian" "integration" "refactor"
                       "orchestrator" "module-builder" "conflict-resolver"
                       "merge-reviewer" "task-sync" "scaffold" "security-auditor"
                       "test-builder" "upgrade-manager" "doctor")
    local agent_count=0
    local missing_agents=()
    for agent in "${core_agents[@]}"; do
        if [[ -f "${target_dir}/.github/agents/${agent}.agent.md" ]]; then
            ((agent_count++))
        else
            missing_agents+=("${agent}")
        fi
    done
    log_ok "Agents present: ${agent_count}/${#core_agents[@]}"
    if [[ ${#missing_agents[@]} -gt 0 ]]; then
        log_warn "Missing agents: ${missing_agents[*]}"
        ((warnings++))
    fi

    # ── Project structure ─────────────────────────────────────────────────
    echo ""
    log_step "Checking project structure..."
    local detected_lang
    detected_lang="$(_detect_language "${target_dir}")"
    if [[ -n "${detected_lang}" ]]; then
        log_ok "Language detected: ${detected_lang}"
        _check_lang_structure "${detected_lang}" "${target_dir}"
    else
        log_warn "Could not detect project language"
        ((warnings++))
    fi

    # ── Doc templates ─────────────────────────────────────────────────────
    echo ""
    log_step "Checking documentation..."
    local doc_files=("architecture.md" "implementation_roadmap.md" "orchestrator_spec.md"
                     "dto_contracts.md" "db_adapter_spec.md")
    for doc in "${doc_files[@]}"; do
        _check_exists "docs/${doc}" "docs/${doc}" "warn"
    done

    # ── Git health ────────────────────────────────────────────────────────
    echo ""
    log_step "Checking Git setup..."
    if [[ -d "${target_dir}/.git" ]]; then
        log_ok "Git repository initialized"
    else
        log_warn "Not a Git repository"
        ((warnings++))
    fi

    # ── Summary ───────────────────────────────────────────────────────────
    echo ""
    echo -e "${BOLD}────────────────────────────────────────────────${NC}"
    if [[ ${issues} -eq 0 ]] && [[ ${warnings} -eq 0 ]]; then
        log_ok "${BOLD}All checks passed!${NC}"
    elif [[ ${issues} -eq 0 ]]; then
        log_ok "${BOLD}No critical issues. ${warnings} warning(s).${NC}"
    else
        log_error "${BOLD}${issues} issue(s), ${warnings} warning(s).${NC}"
    fi
    echo ""

    # ── Deep agent health check ───────────────────────────────────────────
    if [[ ${issues} -gt 0 ]] || [[ ${warnings} -gt 0 ]]; then
        log_step "Spawning Copilot agent for deep health check and auto-fix..."
        _spawn_copilot_agent "${target_dir}" "doctor" \
            "Run a deep health check on this project. Found ${issues} issues and ${warnings} warnings. Validate and fix: 1) All module boundaries (no cross-module imports). 2) DTO contracts are immutable and properly defined in contracts/. 3) Database adapter is the sole DB access point (no raw SQL in modules). 4) All config is YAML-driven (no hardcoded values in code). 5) Tests are deterministic and network-free. 6) All missing skills, agents, or prompts should be installed. 7) Missing docs templates should be created from skeleton-parallel defaults. Fix all issues found. After fixing, commit with message 'chore: doctor auto-fix'." \
            "doctor-deep-check"
    else
        # Background validation even when checks pass
        _spawn_copilot_agent_bg "${target_dir}" "doctor" \
            "All basic checks passed. Run a deep validation: 1) Verify module boundaries. 2) Check DTO immutability. 3) Validate database adapter isolation. 4) Check for hardcoded config values. 5) Ensure parallel dev readiness (phases.yaml + run_parallel.sh). Report findings in .parallel-dev/agent-logs/." \
            "doctor-bg-validation"
    fi

    return ${issues}
}

_check_lang_structure() {
    local lang="$1" dir="$2"

    case "${lang}" in
        go)
            _check_exists "cmd" "cmd/ (entry points)" "warn"
            _check_exists "internal/modules" "internal/modules/ (domain modules)" "warn"
            _check_exists "contracts" "contracts/ (DTO interfaces)" "warn"
            ;;
        python)
            _check_exists "app/main.py" "app/main.py (entry point)" "warn"
            _check_exists "app/modules" "app/modules/ (domain modules)" "warn"
            _check_exists "contracts" "contracts/ (DTOs)" "warn"
            _check_exists "database" "database/ (adapter)" "warn"
            ;;
        typescript)
            _check_exists "src" "src/ (source directory)" "warn"
            _check_exists "contracts" "contracts/ (DTOs)" "warn"
            ;;
        nodejs)
            _check_exists "src" "src/ (source directory)" "warn"
            _check_exists "src/modules" "src/modules/ (domain modules)" "warn"
            _check_exists "contracts" "contracts/ (DTOs)" "warn"
            _check_exists "database" "database/ (adapter)" "warn"
            ;;
        rust)
            _check_exists "src/main.rs" "src/main.rs (entry point)" "warn"
            _check_exists "src/modules" "src/modules/ (domain modules)" "warn"
            ;;
        java)
            _check_exists "src/main/java" "src/main/java/ (source)" "warn"
            ;;
    esac
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: add
# ═════════════════════════════════════════════════════════════════════════════
cmd_add() {
    local resource_type=""
    local resource_name=""
    local target_dir="."

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*) target_dir="${1#*=}"; shift ;;
            --dir)   target_dir="${2}"; shift 2 ;;
            --no-agent) SKIP_AGENT=true; shift ;;
            -*)      die "Unknown option: $1" ;;
            *)
                if [[ -z "${resource_type}" ]]; then
                    resource_type="$1"
                elif [[ -z "${resource_name}" ]]; then
                    resource_name="$1"
                fi
                shift
                ;;
        esac
    done

    target_dir="$(cd "${target_dir}" 2>/dev/null && pwd)" || die "Directory not found: ${target_dir}"

    case "${resource_type}" in
        skill)
            [[ -z "${resource_name}" ]] && die "Usage: skeleton add skill <name>"
            _add_skill "${resource_name}" "${target_dir}"
            # Background agent validates the newly added skill
            _spawn_copilot_agent_bg "${target_dir}" "doctor" \
                "Validate the newly installed skill '${resource_name}': 1) SKILL.md follows correct format (frontmatter with name, type, description + Purpose, Rules, Inputs, Outputs, Examples, Checklist sections). 2) Skill is referenced in relevant agent files that need it. 3) No conflicts with existing skills. Report findings in .parallel-dev/agent-logs/." \
                "add-skill-${resource_name}"
            ;;
        agent)
            [[ -z "${resource_name}" ]] && die "Usage: skeleton add agent <name>"
            _add_agent "${resource_name}" "${target_dir}"
            # Background agent validates the newly added agent
            _spawn_copilot_agent_bg "${target_dir}" "doctor" \
                "Validate the newly installed agent '${resource_name}': 1) Agent file follows correct format (description, skills, instructions). 2) All referenced skills exist in .github/skills/. 3) No conflicts with existing agents. Report findings in .parallel-dev/agent-logs/." \
                "add-agent-${resource_name}"
            ;;
        *)
            die "Usage: skeleton add <skill|agent> <name>"
            ;;
    esac
}

_add_skill() {
    local name="$1" dest="$2"
    local src="${SKELETON_ROOT}/.github/skills/${name}"

    if [[ ! -d "${src}" ]]; then
        die "Skill '${name}' not found.\nAvailable: $(get_available_skills | tr '\n' ' ')"
    fi

    mkdir -p "${dest}/.github/skills"
    cp -R "${src}" "${dest}/.github/skills/"
    log_ok "Skill '${name}' installed to ${dest}/.github/skills/${name}/"
}

_add_agent() {
    local name="$1" dest="$2"
    local src="${SKELETON_ROOT}/.github/agents/${name}.agent.md"

    if [[ ! -f "${src}" ]]; then
        die "Agent '${name}' not found.\nAvailable: $(get_available_agents | tr '\n' ' ')"
    fi

    mkdir -p "${dest}/.github/agents"
    cp "${src}" "${dest}/.github/agents/"
    log_ok "Agent '${name}' installed to ${dest}/.github/agents/${name}.agent.md"
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: list
# ═════════════════════════════════════════════════════════════════════════════
cmd_list() {
    local filter="${1:-all}"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton list                               ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""

    if [[ "${filter}" == "all" ]] || [[ "${filter}" == "templates" ]]; then
        echo -e "${BOLD}Templates:${NC}"
        for lang in "${SUPPORTED_LANGUAGES[@]}"; do
            if [[ -d "${TEMPLATES_DIR}/${lang}" ]]; then
                echo -e "  ${GREEN}●${NC} ${lang}"
            else
                echo -e "  ${RED}○${NC} ${lang} (not installed)"
            fi
        done
        echo ""
    fi

    if [[ "${filter}" == "all" ]] || [[ "${filter}" == "skills" ]]; then
        echo -e "${BOLD}Skills:${NC}"
        get_available_skills | while read -r skill; do
            local desc=""
            local skill_file="${SKELETON_ROOT}/.github/skills/${skill}/SKILL.md"
            if [[ -f "${skill_file}" ]]; then
                desc="$(grep -m1 '^description:' "${skill_file}" 2>/dev/null | sed 's/^description:[[:space:]]*//' | tr -d '"' || true)"
            fi
            echo -e "  ${GREEN}●${NC} ${skill}${desc:+ — ${desc}}"
        done
        echo ""
    fi

    if [[ "${filter}" == "all" ]] || [[ "${filter}" == "agents" ]]; then
        echo -e "${BOLD}Agents:${NC}"
        get_available_agents | while read -r agent; do
            local desc=""
            local agent_file="${SKELETON_ROOT}/.github/agents/${agent}.agent.md"
            if [[ -f "${agent_file}" ]]; then
                desc="$(grep -m1 '^description:' "${agent_file}" 2>/dev/null | sed 's/^description:[[:space:]]*//' | tr -d '"' || true)"
            fi
            echo -e "  ${GREEN}●${NC} ${agent}${desc:+ — ${desc}}"
        done
        echo ""
    fi
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: sync
# ═════════════════════════════════════════════════════════════════════════════
cmd_sync() {
    local target_dir="."

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*) target_dir="${1#*=}"; shift ;;
            --dir)   target_dir="${2}"; shift 2 ;;
            --no-agent) SKIP_AGENT=true; shift ;;
            -*)      die "Unknown option: $1" ;;
            *)       target_dir="$1"; shift ;;
        esac
    done

    target_dir="$(cd "${target_dir}" 2>/dev/null && pwd)" || die "Directory not found: ${target_dir}"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton sync                               ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    log_info "Syncing from: ${BOLD}${SKELETON_ROOT}${NC}"
    log_info "Target:       ${BOLD}${target_dir}${NC}"
    echo ""

    # Force-sync all framework files
    # Guard: ensure target_dir is set and non-empty
    [[ -z "${target_dir}" ]] && die "Target directory is empty — aborting sync"
    [[ ! -d "${target_dir}" ]] && die "Target directory does not exist: ${target_dir}"

    log_step "Syncing skills..."
    if [[ -d "${SKELETON_ROOT}/.github/skills" ]]; then
        [[ -d "${target_dir}/.github/skills" ]] && rm -rf "${target_dir}/.github/skills"
        mkdir -p "${target_dir}/.github"
        cp -R "${SKELETON_ROOT}/.github/skills" "${target_dir}/.github/"
        log_ok "Skills synced"
    fi

    log_step "Syncing agents..."
    if [[ -d "${SKELETON_ROOT}/.github/agents" ]]; then
        [[ -d "${target_dir}/.github/agents" ]] && rm -rf "${target_dir}/.github/agents"
        mkdir -p "${target_dir}/.github"
        cp -R "${SKELETON_ROOT}/.github/agents" "${target_dir}/.github/"
        log_ok "Agents synced"
    fi

    log_step "Syncing prompts..."
    if [[ -d "${SKELETON_ROOT}/.github/prompts" ]]; then
        [[ -d "${target_dir}/.github/prompts" ]] && rm -rf "${target_dir}/.github/prompts"
        mkdir -p "${target_dir}/.github"
        cp -R "${SKELETON_ROOT}/.github/prompts" "${target_dir}/.github/"
        log_ok "Prompts synced"
    fi

    log_step "Syncing run_parallel.sh..."
    mkdir -p "${target_dir}/scripts"
    cp "${SKELETON_ROOT}/scripts/run_parallel.sh" "${target_dir}/scripts/"
    chmod +x "${target_dir}/scripts/run_parallel.sh"
    log_ok "run_parallel.sh synced"

    log_step "Syncing copilot-instructions.md..."
    cp "${SKELETON_ROOT}/.github/copilot-instructions.md" "${target_dir}/.github/"
    log_ok "copilot-instructions.md synced"

    echo ""
    log_ok "Sync complete!"
    echo ""

    # Background agent validates sync results
    _spawn_copilot_agent_bg "${target_dir}" "doctor" \
        "Validate post-sync state: 1) All skills match upstream (${SKELETON_ROOT}). 2) All agents match upstream. 3) run_parallel.sh is current and executable. 4) copilot-instructions.md is current. 5) No custom configurations were accidentally overwritten. Report findings in .parallel-dev/agent-logs/." \
        "sync-validation"
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: autoskills
# ═════════════════════════════════════════════════════════════════════════════

# ── Helper: spawn agent to analyze target codebase and produce recommendations
# Writes to recommendations_file: one line per skill → name|action|reason
# action: install | merge
_autoskills_agent_analyze() {
    local target_dir="$1"
    local detected_lang="$2"
    local features_str="$3"
    local recommendations_file="$4"

    mkdir -p "$(dirname "${recommendations_file}")"
    rm -f "${recommendations_file}"

    # Ensure Explore agent exists in target project (copy from skeleton if missing)
    local explore_agent_dst="${target_dir}/.github/agents/Explore.agent.md"
    local explore_agent_src="${SKELETON_ROOT}/.github/agents/Explore.agent.md"
    if [[ ! -f "${explore_agent_dst}" ]] && [[ -f "${explore_agent_src}" ]]; then
        mkdir -p "${target_dir}/.github/agents"
        cp "${explore_agent_src}" "${explore_agent_dst}"
        log_info "Installed Explore agent to target project"
    fi

    local available_skills_list
    available_skills_list="$(get_available_skills)"

    _spawn_copilot_agent "${target_dir}" "Explore" \
        "Analyze this ${detected_lang:-unknown} project (detected features: ${features_str:-none}) and decide which skeleton-parallel skills to recommend installing.

AVAILABLE SKILLS TO EVALUATE (one per line):
${available_skills_list}

SKILL REFERENCE (name → what it does):
running-prompt: structured task execution workflow (planning, security review, verification)
brainstorming: design-first gate — present a design before any implementation
writing-plans: convert approved design into bite-sized implementation tasks
subagent-driven-development: dispatch fresh subagent per task + 2-stage review
test-driven-development: RED-GREEN-REFACTOR cycle enforcement
code-quality: type annotations, structured logging, no anti-patterns
coding-standards: naming conventions, function design, language idioms
security-audit: OWASP Top 10 vulnerability detection and remediation
modularity: module boundary enforcement, no cross-module imports
dto: immutable DTO contracts, validation, producer/consumer mapping
determinism: same input + same config = identical output enforcement
idempotency: no duplicate writes, content-addressable IDs, ON CONFLICT
failure: retry policies, abort thresholds, graceful degradation
database-portability: engine-agnostic SQL, no driver leakage into modules
migration-management: safe append-only schema migrations
config-validation: YAML-driven parameters, no hardcoded values in code
test-generation: unit/integration test patterns, AAA structure, mocking
api-design: REST/gRPC endpoint patterns, error responses, versioning
vertical-slice: feature-per-folder self-contained architecture
pipeline: stage ordering, DTO flow, checkpoint dependencies
docs-sync: detect drift between documentation and code
dependency-analysis: import graph validation, coupling metrics
conflict-resolution: git merge conflict resolution for parallel branches
token-optimization: context loading optimization for agent prompts
performance-optimization: profiling, query optimization, throughput
rtk: token-efficient CLI proxy for terminal output compression
caveman: ultra-compressed output mode (~75% fewer tokens)
project-scaffold: project initialization and structure validation

INSTRUCTIONS:
1. Explore the project: read key source files, directory structure, existing .github/skills/ (if any)
2. For each skill above, decide one of:
   - install: skill is clearly beneficial and NOT yet present in .github/skills/
   - merge: skill ALREADY EXISTS in .github/skills/ but skeleton version adds missing value
   - skip: skill is irrelevant to this project's actual stack, patterns, or purpose
3. ONLY output install and merge decisions (skip means exclude)
4. Write results to: .parallel-dev/autoskills-recommendations.txt
5. Format — one line per skill, pipe-separated, NO extra whitespace:
   skill-name|action|specific reason citing actual files or patterns found
6. Example lines:
   security-audit|install|Found HTTP handlers in internal/web/server.go without input validation
   running-prompt|merge|Existing SKILL.md present but missing security-review phase
   database-portability|skip|No database access detected
7. Reason MUST be specific to what you actually found — do NOT use generic reasons
8. Do NOT modify any project files other than creating .parallel-dev/autoskills-recommendations.txt" \
        "autoskills-analysis"
}

# ── Helper: static skill mapping fallback (when no Copilot CLI)
# Prints lines: name|action|reason
_autoskills_static_map() {
    local detected_lang="$1"
    local target_dir="$2"
    shift 2
    local features=("$@")

    local -a skills
    skills=("running-prompt" "code-quality" "coding-standards" "security-audit"
            "token-optimization" "brainstorming" "writing-plans" "subagent-driven-development")

    case "${detected_lang}" in
        go|python|rust)
            skills+=("modularity" "dto" "determinism" "idempotency" "failure"
                     "database-portability" "migration-management"
                     "config-validation" "test-generation" "test-driven-development") ;;
        typescript|nodejs)
            skills+=("modularity" "dto" "api-design" "vertical-slice"
                     "config-validation" "test-generation" "test-driven-development") ;;
        java)
            skills+=("modularity" "dto" "api-design" "database-portability"
                     "migration-management" "config-validation" "test-generation") ;;
        *)
            skills+=("modularity" "dto" "config-validation" "test-generation") ;;
    esac

    for feature in "${features[@]+"${features[@]}"}"; do
        case "${feature}" in
            database) skills+=("database-portability" "migration-management") ;;
            tests)    skills+=("test-generation" "test-driven-development") ;;
            api)      skills+=("api-design") ;;
            pipeline) skills+=("pipeline" "failure" "idempotency") ;;
        esac
    done
    skills+=("docs-sync" "dependency-analysis" "conflict-resolution")

    # Deduplicate and emit lines
    local -A seen
    for s in "${skills[@]}"; do
        if [[ -z "${seen[$s]+x}" ]]; then
            seen[$s]=1
            if [[ ! -d "${SKELETON_ROOT}/.github/skills/${s}" ]]; then
                continue  # not in skeleton, skip
            fi
            if [[ -f "${target_dir}/.github/skills/${s}/SKILL.md" ]]; then
                printf '%s|merge|Existing skill detected; skeleton version may add missing sections\n' "${s}"
            else
                printf '%s|install|Recommended for %s project\n' "${s}" "${detected_lang:-unknown}"
            fi
        fi
    done
}

# ── Helper: spawn agent to generate domain-specific custom skills
# Identifies patterns unique to the project's domain (e.g. payment, crypto, video),
# writes .github/skills/<name>/SKILL.md for each, and produces a manifest.
_autoskills_agent_plan_domain() {
    local target_dir="$1"
    local detected_lang="$2"
    local features_str="$3"
    local manifest_file="$4"

    mkdir -p "$(dirname "${manifest_file}")"
    rm -f "${manifest_file}"

    # Ensure Explore agent is present in target project
    local explore_agent_dst="${target_dir}/.github/agents/Explore.agent.md"
    local explore_agent_src="${SKELETON_ROOT}/.github/agents/Explore.agent.md"
    if [[ ! -f "${explore_agent_dst}" ]] && [[ -f "${explore_agent_src}" ]]; then
        mkdir -p "${target_dir}/.github/agents"
        cp "${explore_agent_src}" "${explore_agent_dst}"
    fi

    _spawn_copilot_agent "${target_dir}" "Explore" \
        "Analyze this ${detected_lang:-unknown} project (features: ${features_str:-none}) and IDENTIFY domain-specific skill areas for coding patterns UNIQUE to this project.

SKELETON SKILLS ALREADY AVAILABLE — do NOT plan skills that duplicate these domains:
dto, pipeline, modularity, determinism, idempotency, failure, config-validation, code-quality,
coding-standards, database-portability, docs-sync, conflict-resolution, token-optimization,
running-prompt, security-audit, test-generation, vertical-slice, api-design, project-scaffold,
dependency-analysis, migration-management, performance-optimization, caveman, brainstorming,
writing-plans, subagent-driven-development, test-driven-development, rtk

INSTRUCTIONS:
1. Explore key source files to understand the project's business domain and unique technical patterns
2. Identify 3-7 domain-specific skill areas NOT covered by the skeleton skills above
   Examples of good domain skills:
   - Crypto/blockchain project  → 'crypto-key-management', 'blockchain-transaction-patterns'
   - Payment system             → 'payment-processing', 'pci-compliance-patterns'
   - Video pipeline             → 'ffmpeg-encoding-patterns', 'gpu-worker-patterns'
   - AI/ML project              → 'prompt-safety-patterns', 'model-inference-constraints'
   - Multi-tenant SaaS          → 'tenant-isolation-patterns', 'subscription-billing-rules'
   - Supabase project           → 'supabase-rls-patterns', 'supabase-migration-conventions'
3. Write ONLY the manifest file — do NOT create any .github/skills/ directories or SKILL.md files.
   The manifest will be reviewed by the user before any files are created.

MANIFEST FILE to write: ${manifest_file}
Format — one line per skill, pipe-separated, NO extra whitespace:
skill-name|one-sentence description of what it covers and why it is unique to this project
Example:
supabase-rls-patterns|Row-level security enforcement for multi-tenant Supabase queries
ffmpeg-encoding-patterns|FFmpeg subprocess constraints and output path safety rules

RULES:
- Plan 3-7 skills MAXIMUM — quality over quantity
- Every planned skill MUST be justified by actual files, functions, or patterns found in THIS codebase
- Do NOT plan generic skills that could apply to any project
- Do NOT duplicate any skeleton skill domain listed above
- Skill names: lowercase, hyphenated, domain-specific (e.g. 'crypto-key-management', not 'security')
- Do NOT write any files other than the manifest" \
        "autoskills-domain-planning"
}

_autoskills_agent_generate_domain() {
    local target_dir="$1"
    local detected_lang="$2"
    local features_str="$3"
    local manifest_file="$4"

    mkdir -p "${target_dir}/.github/skills"

    # Ensure Explore agent is present in target project
    local explore_agent_dst="${target_dir}/.github/agents/Explore.agent.md"
    local explore_agent_src="${SKELETON_ROOT}/.github/agents/Explore.agent.md"
    if [[ ! -f "${explore_agent_dst}" ]] && [[ -f "${explore_agent_src}" ]]; then
        mkdir -p "${target_dir}/.github/agents"
        cp "${explore_agent_src}" "${explore_agent_dst}"
    fi

    # Read planned skill names from the manifest to guide generation
    local planned_skills=""
    if [[ -f "${manifest_file}" ]]; then
        planned_skills="$(awk -F'|' '{print $1}' "${manifest_file}" | tr '\n' ',' | sed 's/,$//') "
    fi

    _spawn_copilot_agent "${target_dir}" "Explore" \
        "Generate domain-specific SKILL.md files for this ${detected_lang:-unknown} project (features: ${features_str:-none}).

The user has already approved generating these domain skills: ${planned_skills:-see manifest at ${manifest_file}}

SKELETON SKILLS ALREADY INSTALLED — do NOT generate skills that duplicate these domains:
dto, pipeline, modularity, determinism, idempotency, failure, config-validation, code-quality,
coding-standards, database-portability, docs-sync, conflict-resolution, token-optimization,
running-prompt, security-audit, test-generation, vertical-slice, api-design, project-scaffold,
dependency-analysis, migration-management, performance-optimization, caveman, brainstorming,
writing-plans, subagent-driven-development, test-driven-development, rtk

INSTRUCTIONS:
1. If a manifest exists at ${manifest_file}, generate ONLY the skills listed there
2. For each domain skill, create .github/skills/<skill-name>/SKILL.md using this EXACT format:

---
name: <skill-name>
type: skill
description: \"<one-line description of what this skill enforces>\"
---

## Purpose

[What this skill enforces and why it exists in THIS project — reference actual files]

## Rules

[5-10 specific, actionable rules derived from patterns found in THIS codebase.
 Reference specific files, functions, or line numbers you observed.]

## Anti-Patterns

[3-5 things to NEVER do in this domain, with examples from THIS codebase]

## Checklist

\`\`\`
[ ] Specific rule 1
[ ] Specific rule 2
...\`\`\`

RULES:
- Generate 3-7 skills MAXIMUM — quality over quantity
- Every rule MUST reference actual files, functions, or patterns found in THIS codebase
- Do NOT generate generic skills that could apply to any project
- Do NOT duplicate any skeleton skill domain listed above
- Skill names: lowercase, hyphenated, domain-specific (e.g. 'crypto-key-management', not 'security')
- Do NOT modify any project source files — only write to .github/skills/" \
        "autoskills-domain-generation"
}

# ── Helper: install a skill fresh from skeleton
_autoskills_install_skill() {
    local skill="$1"
    local target_dir="$2"
    local src="${SKELETON_ROOT}/.github/skills/${skill}"
    local dst="${target_dir}/.github/skills/${skill}"

    if [[ ! -d "${src}" ]]; then
        log_warn "Skill not in skeleton: ${skill} — skipped"
        return 1
    fi
    mkdir -p "${dst}"
    cp -r "${src}/." "${dst}/"
    log_ok "Installed: ${BOLD}${skill}${NC}"
}

# ── Helper: merge an existing skill with skeleton version
# Backs up existing, installs skeleton version, queues background merge agent
_autoskills_merge_skill() {
    local skill="$1"
    local target_dir="$2"
    local src="${SKELETON_ROOT}/.github/skills/${skill}"
    local dst="${target_dir}/.github/skills/${skill}"
    local bak="${target_dir}/.github/skills/${skill}.bak"

    if [[ ! -d "${src}" ]]; then
        log_warn "Skill not in skeleton: ${skill} — skipped"
        return 1
    fi

    # Backup existing
    if [[ -d "${dst}" ]]; then
        rm -rf "${bak}"
        mkdir -p "${bak}"
        cp -r "${dst}/." "${bak}/"
    fi

    # Install skeleton version as base
    mkdir -p "${dst}"
    cp -r "${src}/." "${dst}/"

    # Try agent merge (background)
    if _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]]; then
        local log_dir="${target_dir}/${COPILOT_LOG_DIR}"
        mkdir -p "${log_dir}"
        local merge_log="${log_dir}/merge-${skill}-$(date +%Y%m%d-%H%M%S).log"
        (
            cd "${target_dir}"
            copilot \
                -p "Merge two versions of the '${skill}' skill SKILL.md. ORIGINAL (custom, from previous install): .github/skills/${skill}.bak/SKILL.md. NEW (skeleton-parallel base): .github/skills/${skill}/SKILL.md. MERGE RULES: 1) Use NEW as the base document. 2) For any ## section that exists in ORIGINAL but NOT in NEW, append it at the end of .github/skills/${skill}/SKILL.md. 3) For any ## section that exists in BOTH, keep the NEW version but append any unique bullet points from ORIGINAL under a '### Custom Additions' subsection. 4) After writing the merged SKILL.md, delete .github/skills/${skill}.bak/. 5) Do NOT modify any other files." \
                --agent="Explore" \
                --model="${COPILOT_MODEL}" \
                --no-ask-user \
                --allow-all-tools \
                --autopilot \
                &>"${merge_log}"
            rm -rf "${target_dir}/.github/skills/${skill}.bak" 2>/dev/null || true
        ) &
        log_ok "Merged: ${BOLD}${skill}${NC} ${YELLOW}(background merge agent queued)${NC}"
    else
        # No agent — simple structural merge: append unique ## sections from backup
        if [[ -f "${bak}/SKILL.md" ]] && [[ -f "${dst}/SKILL.md" ]]; then
            local in_section=false
            local section_buf=""
            local current_header=""
            while IFS= read -r line; do
                if [[ "${line}" =~ ^##[[:space:]] ]]; then
                    # Flush previous section if header not in new version
                    if [[ -n "${current_header}" ]] && ! grep -qF "${current_header}" "${dst}/SKILL.md"; then
                        printf '\n<!-- Preserved from previous installation -->\n%s\n%s\n' \
                            "${current_header}" "${section_buf}" >> "${dst}/SKILL.md"
                    fi
                    current_header="${line}"
                    section_buf=""
                else
                    [[ -n "${current_header}" ]] && section_buf+="${line}"$'\n'
                fi
            done < "${bak}/SKILL.md"
            # Flush last section
            if [[ -n "${current_header}" ]] && ! grep -qF "${current_header}" "${dst}/SKILL.md"; then
                printf '\n<!-- Preserved from previous installation -->\n%s\n%s\n' \
                    "${current_header}" "${section_buf}" >> "${dst}/SKILL.md"
            fi
        fi
        rm -rf "${bak}" 2>/dev/null || true
        log_ok "Merged: ${BOLD}${skill}${NC} (custom sections preserved)"
    fi
}

cmd_autoskills() {
    local target_dir="."
    local dry_run=false
    local auto_yes=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*)    target_dir="${1#*=}"; shift ;;
            --dir)      target_dir="${2}"; shift 2 ;;
            --dry-run)  dry_run=true; shift ;;
            --no-agent) SKIP_AGENT=true; shift ;;
            -y)         auto_yes=true; shift ;;
            -*)         die "Unknown option: $1" ;;
            *)          target_dir="$1"; shift ;;
        esac
    done

    target_dir="$(cd "${target_dir}" 2>/dev/null && pwd)" || die "Directory not found: ${target_dir}"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton autoskills                         ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    log_info "Scanning: ${BOLD}${target_dir}${NC}"
    echo ""

    # ── Step 1: Language + feature detection ─────────────────────────────
    local detected_lang
    detected_lang="$(_detect_language "${target_dir}")"
    log_step "Detected language: ${detected_lang:-unknown}"

    local features=()

    if find "${target_dir}" -maxdepth 4 -name '*.sql' -not -path '*/.*' 2>/dev/null | grep -q .; then
        features+=("database")
    elif [[ -d "${target_dir}/database/migrations" ]] || [[ -d "${target_dir}/migrations" ]]; then
        features+=("database")
    fi

    local test_patterns=('*_test.go' 'test_*.py' '*_test.py' '*_test.ts' '*_test.js' '*_test.rs' '*Test.java')
    for pat in "${test_patterns[@]}"; do
        if find "${target_dir}" -maxdepth 6 -name "${pat}" -not -path '*/.*' 2>/dev/null | grep -q .; then
            features+=("tests"); break
        fi
    done

    if [[ -f "${target_dir}/Dockerfile" ]] || [[ -f "${target_dir}/docker-compose.yml" ]]; then
        features+=("docker")
    fi

    if find "${target_dir}" -maxdepth 3 \( -name 'openapi.yaml' -o -name 'openapi.json' -o -name '*.proto' \) 2>/dev/null | grep -q .; then
        features+=("api")
    fi

    if [[ -f "${target_dir}/docs/architecture.md" ]]; then
        features+=("pipeline")
    fi

    if [[ ${#features[@]} -gt 0 ]]; then
        log_ok "Detected features: ${features[*]}"
    else
        log_info "No special features detected"
    fi
    echo ""

    # ── Step 2: Agent analysis ────────────────────────────────────────────
    local recommendations_file="${target_dir}/.parallel-dev/autoskills-recommendations.txt"
    local domain_manifest="${target_dir}/.parallel-dev/domain-skills-manifest.txt"
    local -a rec_names=() rec_actions=() rec_reasons=()
    local -a domain_names=() domain_reasons=()
    local features_str="${features[*]+"${features[*]}"}"

    if _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]]; then
        log_step "Spawning agent to read and understand the codebase..."
        log_info "The agent will explore the project and recommend only skills that fit."
        echo ""
        _autoskills_agent_analyze "${target_dir}" "${detected_lang}" "${features_str}" "${recommendations_file}" || true
    fi

    # ── Step 2b: Domain-specific skill planning (manifest only — no files written yet) ──
    if _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]] && [[ "${dry_run}" != "true" ]]; then
        log_step "Spawning agent to identify domain-specific skills..."
        log_info "The agent will explore the project and plan custom skills — no files created until you confirm."
        echo ""
        _autoskills_agent_plan_domain "${target_dir}" "${detected_lang}" "${features_str}" "${domain_manifest}" || true
    fi

    # ── Step 3: Parse agent recommendations ──────────────────────────────
    if [[ -f "${recommendations_file}" ]]; then
        log_ok "Agent analysis complete — parsing recommendations..."
        while IFS='|' read -r name action reason; do
            # Skip blank lines and comments
            name="${name// /}"  # trim spaces
            [[ -z "${name}" || "${name}" =~ ^# ]] && continue
            action="${action,,}"
            action="${action// /}"
            [[ "${action}" != "install" && "${action}" != "merge" ]] && continue
            # Only include skills that exist in skeleton
            [[ ! -d "${SKELETON_ROOT}/.github/skills/${name}" ]] && continue
            rec_names+=("${name}")
            rec_actions+=("${action}")
            rec_reasons+=("${reason}")
        done < "${recommendations_file}"
    fi

    # ── Step 3b: Parse domain skill plan ──────────────────────────────────
    if [[ -f "${domain_manifest}" ]]; then
        while IFS='|' read -r name reason; do
            name="${name// /}"
            [[ -z "${name}" || "${name}" =~ ^# ]] && continue
            domain_names+=("${name}")
            domain_reasons+=("${reason}")
        done < "${domain_manifest}"
        if [[ ${#domain_names[@]} -gt 0 ]]; then
            log_ok "Domain skills planned: ${BOLD}${#domain_names[@]}${NC}"
        fi
    fi

    # ── Step 4: Fallback to static map if no agent output ─────────────────
    if [[ ${#rec_names[@]} -eq 0 ]]; then
        if _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]]; then
            log_warn "Agent produced no parseable recommendations — using static detection as fallback"
        else
            log_info "Copilot not available — using static skill detection"
        fi
        while IFS='|' read -r name action reason; do
            [[ -z "${name}" ]] && continue
            rec_names+=("${name}")
            rec_actions+=("${action}")
            rec_reasons+=("${reason}")
        done < <(_autoskills_static_map "${detected_lang}" "${target_dir}" "${features[@]+"${features[@]}"}")
    fi

    if [[ ${#rec_names[@]} -eq 0 ]] && [[ ${#domain_names[@]} -eq 0 ]]; then
        log_ok "No skills recommended — project is up to date or no matches found."
        echo ""
        return 0
    fi

    # ── Step 5: Show plan with reasons ────────────────────────────────────
    local total_skills=$(( ${#rec_names[@]} + ${#domain_names[@]} ))
    echo ""
    log_step "Recommended skills (${total_skills}):"
    echo ""
    for i in "${!rec_names[@]}"; do
        local action_label
        case "${rec_actions[$i]}" in
            install) action_label="${GREEN}[install]  ${NC}" ;;
            merge)   action_label="${CYAN}[merge]    ${NC}" ;;
            *)       action_label="[${rec_actions[$i]}]    " ;;
        esac
        echo -e "  ${action_label} ${BOLD}${rec_names[$i]}${NC}"
        echo -e "             ${rec_reasons[$i]}"
    done
    for i in "${!domain_names[@]}"; do
        echo -e "  ${MAGENTA}[generate] ${NC} ${BOLD}${domain_names[$i]}${NC}"
        echo -e "             ${domain_reasons[$i]}"
    done
    echo ""
    echo -e "  ${GREEN}[install]${NC}  = fresh copy from skeleton-parallel"
    echo -e "  ${CYAN}[merge]${NC}    = existing skill combined with skeleton version (custom sections preserved)"
    echo -e "  ${MAGENTA}[generate]${NC} = new domain-specific skill generated for this project"
    echo ""

    if [[ "${dry_run}" == true ]]; then
        log_info "Dry run complete. Use without --dry-run to install."
        echo ""
        return 0
    fi

    # ── Step 6: Confirmation ──────────────────────────────────────────────
    if [[ "${auto_yes}" != true ]]; then
        echo -e "${BOLD}Options:${NC}"
        local domain_note=""
        [[ ${#domain_names[@]} -gt 0 ]] && domain_note=" + generate ${#domain_names[@]} domain skills"
        echo -e "  ${GREEN}[y]${NC} Install all ${#rec_names[@]} skeleton skills${domain_note}"
        echo -e "  ${YELLOW}[i]${NC} Choose individually (confirm each skill)"
        echo -e "  ${RED}[n]${NC} Abort"
        echo ""
        printf "%b" "${BOLD}Proceed? [y/i/n]: ${NC}"
        read -r bulk_choice
        echo ""

        case "${bulk_choice,,}" in
            y|yes)
                # keep all
                ;;
            i|individual)
                local sel_names=() sel_actions=() sel_reasons=()
                for i in "${!rec_names[@]}"; do
                    local action_short="${rec_actions[$i]}"
                    printf "%b" "  ${BOLD}${rec_names[$i]}${NC} (${action_short}) — ${rec_reasons[$i]}"$'\n'
                    printf "%b" "  Install? [y/N]: "
                    read -r per_choice
                    if [[ "${per_choice,,}" == "y" ]]; then
                        sel_names+=("${rec_names[$i]}")
                        sel_actions+=("${rec_actions[$i]}")
                        sel_reasons+=("${rec_reasons[$i]}")
                    fi
                done
                if [[ ${#domain_names[@]} -gt 0 ]]; then
                    echo ""
                    printf "%b" "  ${MAGENTA}${#domain_names[@]} domain skill(s)${NC} planned for generation.\n"
                    printf "%b" "  Generate all domain skills? [y/N]: "
                    read -r domain_choice
                    if [[ "${domain_choice,,}" != "y" ]]; then
                        domain_names=()
                        domain_reasons=()
                    fi
                fi
                if [[ ${#sel_names[@]} -eq 0 ]] && [[ ${#domain_names[@]} -eq 0 ]]; then
                    log_info "Nothing selected. Aborted."
                    echo ""
                    return 0
                fi
                rec_names=("${sel_names[@]+"${sel_names[@]}"}") 
                rec_actions=("${sel_actions[@]+"${sel_actions[@]}"}") 
                rec_reasons=("${sel_reasons[@]+"${sel_reasons[@]}"}")
                ;;
            *)
                log_info "Aborted."
                echo ""
                return 0
                ;;
        esac
    fi

    # ── Step 7: Install / merge ───────────────────────────────────────────
    echo ""
    mkdir -p "${target_dir}/.github/skills"
    local installed=0 merged=0 generated=0 failed=0
    for i in "${!rec_names[@]}"; do
        case "${rec_actions[$i]}" in
            install)
                _autoskills_install_skill "${rec_names[$i]}" "${target_dir}" && ((installed++)) || ((failed++))
                ;;
            merge)
                _autoskills_merge_skill "${rec_names[$i]}" "${target_dir}" && ((merged++)) || ((failed++))
                ;;
        esac
    done

    # ── Step 7b: Generate domain skills (now that user has confirmed) ─────
    if [[ ${#domain_names[@]} -gt 0 ]] && _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]]; then
        echo ""
        log_step "Generating ${#domain_names[@]} domain-specific skill(s)..."
        _autoskills_agent_generate_domain "${target_dir}" "${detected_lang}" "${features_str}" "${domain_manifest}" || true
        # Count how many were actually created
        for name in "${domain_names[@]}"; do
            [[ -f "${target_dir}/.github/skills/${name}/SKILL.md" ]] && ((generated++))
        done
    elif [[ ${#domain_names[@]} -gt 0 ]]; then
        log_warn "Copilot not available — domain skills not generated."
    fi

    echo ""
    log_ok "Done. ${BOLD}${installed}${NC} installed, ${BOLD}${merged}${NC} merged, ${BOLD}${generated}${NC} generated, ${BOLD}${failed}${NC} failed."
    if [[ ${merged} -gt 0 ]] && _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]]; then
        log_info "Merge agents are running in the background."
        log_info "Check .parallel-dev/agent-logs/ for merge results."
    fi
    if [[ ${generated} -gt 0 ]]; then
        log_info "Domain skills are in .github/skills/ — review and customize them for this project."
    fi
    echo ""
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: version / help
# ═════════════════════════════════════════════════════════════════════════════
cmd_version() {
    echo "skeleton v${VERSION} (skeleton-parallel framework)"
}

cmd_help() {
    cat <<'EOF'

  skeleton — CLI for the skeleton-parallel framework (v1.1.0)

  USAGE:
    skeleton <command> [options]

  COMMANDS:
    init <language>           Initialize a new project from template
    upgrade [--dir=DIR]       Upgrade existing repo with skeleton-parallel
    doctor [--dir=DIR]        Validate project health and wiring
    add skill <name>          Add a skill to current project
    add agent <name>          Add an agent to current project
    list [skills|agents|templates]  List available resources
    sync [--dir=DIR]          Force-sync all skills/agents/scripts from upstream
    autoskills [--dir=DIR]    Auto-detect stack and install matching skills
    version                   Show version
    help                      Show this help

  INIT OPTIONS:
    --name=NAME               Project name (default: directory name)
    --dir=DIR                 Target directory (default: ./<name>)
    --no-agent                Skip Copilot agent spawning

  UPGRADE OPTIONS:
    --dir=DIR                 Target directory (default: .)
    --mode=MODE               Force upgrade mode: replace, hybrid, or skip
    --no-agent                Skip Copilot agent spawning
    --no-analyze              Skip pre-upgrade Explore analysis (use existing context report if present)

  AGENT BEHAVIOR:
    By default, file-modifying commands (init, upgrade, doctor, sync, add,
    autoskills) spawn a Copilot CLI agent for validation or deep health check.
    Use --no-agent to disable agent spawning, or set SKIP_AGENT=true.
    Agent model: controlled by COPILOT_MODEL env var (default: claude-sonnet-4.6).
    Agent logs are saved to .parallel-dev/agent-logs/.

  SUPPORTED LANGUAGES:
    go          Vertical slice architecture (handler/service/repository per feature)
    python      Modular monolith (module/feature/handler pattern)
    typescript  Modular monolith (module/feature pattern)
    nodejs      Modular monolith (Express/Fastify pattern)
    rust        Modular monolith (module/feature pattern)
    java        Modular monolith (module/feature pattern)

  EXAMPLES:
    skeleton init go --name=my-service
    skeleton init python --name=trading-system --dir=~/projects/trading
    skeleton init nodejs --name=api-gateway --no-agent
    skeleton upgrade --dir=../existing-project
    skeleton upgrade --dir=../existing-project --mode=hybrid
    skeleton doctor
    skeleton add skill security-audit
    skeleton add agent test-builder
    skeleton list skills
    skeleton sync --dir=../my-project
    skeleton autoskills --dir=../existing-project --dry-run
    skeleton autoskills -y

  ENVIRONMENT VARIABLES:
    COPILOT_MODEL             Model for Copilot agent (default: claude-sonnet-4.6)
    SKIP_AGENT                Set to 'true' to disable agent spawning globally

EOF
}

# ═════════════════════════════════════════════════════════════════════════════
# MAIN ROUTER
# ═════════════════════════════════════════════════════════════════════════════
main() {
    if [[ $# -eq 0 ]]; then
        cmd_help
        exit 0
    fi

    local command="$1"
    shift

    case "${command}" in
        init)       cmd_init "$@" ;;
        upgrade)    cmd_upgrade "$@" ;;
        doctor)     cmd_doctor "$@" ;;
        autoskills) cmd_autoskills "$@" ;;
        add)        cmd_add "$@" ;;
        list)       cmd_list "$@" ;;
        sync)       cmd_sync "$@" ;;
        version)    cmd_version ;;
        help|-h|--help) cmd_help ;;
        *)          die "Unknown command: ${command}\nRun 'skeleton help' for usage." ;;
    esac
}

main "$@"

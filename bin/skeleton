#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# skeleton — CLI for the skeleton-parallel framework
# ─────────────────────────────────────────────────────────────────────────────
# Initialize, upgrade, and manage projects using the skeleton-parallel
# modular monolith framework with AI-assisted parallel development.
#
# Usage:
#   skeleton init <language> [--name=NAME] [--dir=DIR]
#   skeleton upgrade [--dir=DIR]
#   skeleton doctor [--dir=DIR]
#   skeleton add skill <name> [--dir=DIR]
#   skeleton add agent <name> [--dir=DIR]
#   skeleton list [skills|agents|templates]
#   skeleton sync [--dir=DIR]
#   skeleton version
#   skeleton help
#
# Supported languages: go, python, typescript, nodejs, rust, java
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail

# ── Resolve skeleton-parallel root (follow symlink so ~/.local/bin/skeleton works) ──
_SCRIPT="${BASH_SOURCE[0]}"
[[ -L "${_SCRIPT}" ]] && _SCRIPT="$(readlink "${_SCRIPT}")"
SKELETON_BIN="$(cd "$(dirname "${_SCRIPT}")" && pwd)"
SKELETON_ROOT="$(cd "${SKELETON_BIN}/.." && pwd)"

# Derive version from the git tag; fall back to the embedded default.
VERSION="$(git -C "${SKELETON_ROOT}" describe --tags --exact-match 2>/dev/null \
           | sed 's/^v//' \
           || git -C "${SKELETON_ROOT}" describe --tags --always 2>/dev/null \
           | sed 's/^v//' \
           || echo "0.2.0")"
TEMPLATES_DIR="${SKELETON_ROOT}/templates"

# ── Agent Configuration (provider-agnostic) ─────────────────────────────────
COPILOT_MODEL="${COPILOT_MODEL:-claude-sonnet-4-6}"  # legacy alias honoured
AGENT_MODEL="${AGENT_MODEL:-${COPILOT_MODEL:-claude-sonnet-4-6}}"
COPILOT_LOG_DIR=".parallel-dev/agent-logs"
# All 28 skills — injected into every agent prompt
COPILOT_SKILLS="dto, pipeline, modularity, determinism, idempotency, failure, config-validation, code-quality, coding-standards, database-portability, docs-sync, conflict-resolution, token-optimization, running-prompt, security-audit, test-generation, vertical-slice, api-design, project-scaffold, dependency-analysis, migration-management, performance-optimization, caveman, brainstorming, plan-management, subagent-driven-development, test-driven-development, rtk"
# Workspace constraint — prevent agents from writing outside project
COPILOT_WORKSPACE_CONSTRAINT="WORKSPACE CONSTRAINT: NEVER write files outside this project directory. Use .parallel-dev/ for temporary artifacts and output/ for generated files."

# ── Colors ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# ── Logging ──────────────────────────────────────────────────────────────────
log_info()  { echo -e "${BLUE}[INFO]${NC}  $*"; }
log_ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }
log_step()  { echo -e "${CYAN}[STEP]${NC}  $*"; }

# ── Helpers ──────────────────────────────────────────────────────────────────
die() { log_error "$@"; exit 1; }

confirm() {
    local prompt="${1:-Continue?}"
    read -rp "$(echo -e "${YELLOW}${prompt} [y/N]${NC} ")" answer
    [[ "${answer}" =~ ^[Yy]$ ]]
}

# Escape a string for safe use in sed replacement patterns
# Handles /, &, \, and newlines
_sed_escape() {
    printf '%s' "$1" | sed -e 's/[\/&\\]/\\&/g'
}

# Validate project name — only allow safe characters
_validate_project_name() {
    local name="$1"
    if [[ ${#name} -gt 255 ]]; then
        die "Project name too long (max 255 chars)"
    fi
    if [[ ! "${name}" =~ ^[a-zA-Z][a-zA-Z0-9._-]*$ ]]; then
        die "Invalid project name '${name}'. Must start with a letter, contain only [a-zA-Z0-9._-]"
    fi
}

# ── Agent Helpers (provider-agnostic, ARES-aligned) ─────────────────────────

# Detect the configured AI provider for a given project directory.
# Reads config/skeleton.yaml; defaults to "copilot" for backward compatibility.
_detect_provider_for_dir() {
    local dir="${1:-.}"
    local p=""
    if [[ -f "${dir}/config/skeleton.yaml" ]]; then
        p="$(grep -E '^\s*provider\s*:' "${dir}/config/skeleton.yaml" \
            2>/dev/null | head -1 | sed 's/.*://;s/#.*//;s/[[:space:]]//g;s/"//g;s/'"'"'//g')"
    fi
    echo "${p:-copilot}"
}

# Return the ARES-composed harness file path for a given provider.
# These files are ARES outputs — skeleton reads them, never writes them.
_provider_harness_file() {
    case "${1:-copilot}" in
        copilot)     echo ".github/copilot-instructions.md" ;;
        claude)      echo "CLAUDE.md" ;;
        codex)       echo "AGENTS.md" ;;
        cursor)      echo ".cursor/rules/" ;;
        antigravity) echo ".antigravity/" ;;
        *)           echo ".ai/manifest.yaml" ;;
    esac
}

# Check whether the CLI binary for the given provider is available.
_check_agent_cli_available() {
    local provider="${1:-copilot}"
    case "${provider}" in
        copilot) command -v copilot &>/dev/null ;;
        claude)  command -v claude  &>/dev/null ;;
        codex)   command -v codex   &>/dev/null ;;
        *)       return 0 ;;  # sdk_cursor / router_http — no binary needed
    esac
}

# Die with a provider-specific install hint if the CLI binary is missing.
_require_agent_cli() {
    local provider="${1:-copilot}"
    if ! _check_agent_cli_available "${provider}"; then
        case "${provider}" in
            copilot) die "copilot CLI not found. Install: npm install -g @githubnext/github-copilot-cli\nAlternative: use --no-agent to skip." ;;
            claude)  die "claude CLI not found. Install: https://claude.ai/code\nAlternative: use --no-agent to skip." ;;
            codex)   die "codex CLI not found. Install: https://platform.openai.com/codex\nAlternative: use --no-agent to skip." ;;
            *)       die "No CLI binary available for provider '${provider}'. Use --no-agent to skip." ;;
        esac
    fi
}

# Spawn an agent in the foreground (blocking) using the project's configured provider.
# Usage: _spawn_agent <work_dir> <agent_name> <prompt> [log_label]
_spawn_agent() {
    local work_dir="$1"
    local agent_name="$2"
    local prompt="$3"
    local log_label="${4:-${agent_name}}"

    if [[ "${SKIP_AGENT:-false}" == "true" ]]; then
        log_info "Agent spawning skipped (--no-agent)"
        return 0
    fi

    local provider; provider="$(_detect_provider_for_dir "${work_dir}")"
    local harness_file; harness_file="$(_provider_harness_file "${provider}")"
    local full_prompt="${prompt} MANDATORY: Use skills as primary knowledge source (${COPILOT_SKILLS}). Follow constraints in ${harness_file} (ARES-composed harness). ${COPILOT_WORKSPACE_CONSTRAINT}"

    local log_dir="${work_dir}/${COPILOT_LOG_DIR}"
    mkdir -p "${log_dir}"
    local log_file="${log_dir}/${log_label}-$(date +%Y%m%d-%H%M%S).log"

    log_step "Spawning agent: ${BOLD}${agent_name}${NC} (provider: ${provider}, model: ${AGENT_MODEL})"

    local exit_code=0
    case "${provider}" in
        copilot)
            _require_agent_cli "copilot"
            (
                cd "${work_dir}"
                copilot \
                    -p "${full_prompt}" \
                    --agent="${agent_name}" \
                    --model="${AGENT_MODEL}" \
                    --no-ask-user \
                    --allow-all-tools \
                    --autopilot \
                    2>&1 | tee "${log_file}"
            )
            exit_code=${PIPESTATUS[0]:-$?}
            ;;
        claude)
            _require_agent_cli "claude"
            (
                cd "${work_dir}"
                claude \
                    -p "${full_prompt}" \
                    --model="${AGENT_MODEL}" \
                    --allowedTools all \
                    2>&1 | tee "${log_file}"
            )
            exit_code=${PIPESTATUS[0]:-$?}
            ;;
        codex)
            _require_agent_cli "codex"
            (
                cd "${work_dir}"
                codex \
                    -p "${full_prompt}" \
                    2>&1 | tee "${log_file}"
            )
            exit_code=${PIPESTATUS[0]:-$?}
            ;;
        *)
            log_warn "Provider '${provider}' — foreground agent CLI not implemented; skipping"
            return 0
            ;;
    esac

    if [[ ${exit_code} -eq 0 ]]; then
        log_ok "Agent ${agent_name} completed successfully"
    else
        log_error "Agent ${agent_name} failed (exit ${exit_code}). Log: ${log_file}"
    fi
    return ${exit_code}
}

# Spawn an agent in the background (non-blocking) using the project's configured provider.
# Usage: _spawn_agent_bg <work_dir> <agent_name> <prompt> [log_label]
_spawn_agent_bg() {
    local work_dir="$1"
    local agent_name="$2"
    local prompt="$3"
    local log_label="${4:-${agent_name}}"

    if [[ "${SKIP_AGENT:-false}" == "true" ]]; then
        return 0
    fi

    local provider; provider="$(_detect_provider_for_dir "${work_dir}")"

    if ! _check_agent_cli_available "${provider}"; then
        log_warn "${provider} CLI not found — skipping background agent"
        return 0
    fi

    local harness_file; harness_file="$(_provider_harness_file "${provider}")"
    local full_prompt="${prompt} MANDATORY: Use skills as primary knowledge source (${COPILOT_SKILLS}). Follow constraints in ${harness_file} (ARES-composed harness). ${COPILOT_WORKSPACE_CONSTRAINT}"

    local log_dir="${work_dir}/${COPILOT_LOG_DIR}"
    mkdir -p "${log_dir}"
    local log_file="${log_dir}/${log_label}-$(date +%Y%m%d-%H%M%S).log"

    log_info "Spawning background agent: ${agent_name} (provider: ${provider}, log: ${log_file})"

    case "${provider}" in
        copilot)
            (
                cd "${work_dir}"
                copilot \
                    -p "${full_prompt}" \
                    --agent="${agent_name}" \
                    --model="${AGENT_MODEL}" \
                    --no-ask-user \
                    --allow-all-tools \
                    --autopilot \
                    &>"${log_file}"
            ) &
            ;;
        claude)
            (
                cd "${work_dir}"
                claude \
                    -p "${full_prompt}" \
                    --model="${AGENT_MODEL}" \
                    --allowedTools all \
                    &>"${log_file}"
            ) &
            ;;
        codex)
            (
                cd "${work_dir}"
                codex \
                    -p "${full_prompt}" \
                    &>"${log_file}"
            ) &
            ;;
        *)
            log_warn "Provider '${provider}' — background agent CLI not implemented; skipping"
            return 0
            ;;
    esac
    local bg_pid=$!
    log_info "Background agent PID: ${bg_pid}"
}

# ── Backward-compatible aliases (keep all existing call sites unchanged) ──────
_spawn_copilot_agent()    { _spawn_agent    "$@"; }
_spawn_copilot_agent_bg() { _spawn_agent_bg "$@"; }
_check_copilot_available() {
    local dir="${1:-.}"
    _check_agent_cli_available "$(_detect_provider_for_dir "${dir}")"
}
_require_copilot() {
    local dir="${1:-.}"
    _require_agent_cli "$(_detect_provider_for_dir "${dir}")"
}


# Detect existing skeleton-parallel mechanisms in a directory
# Returns space-separated list of found mechanisms
_detect_existing_mechanisms() {
    local dir="$1"
    local found=()

    [[ -f "${dir}/.github/copilot-instructions.md" ]] && found+=("copilot-instructions")
    [[ -d "${dir}/.github/skills" ]] && found+=("skills")
    [[ -d "${dir}/.github/agents" ]] && found+=("agents")
    [[ -d "${dir}/.github/prompts" ]] && found+=("prompts")
    [[ -f "${dir}/scripts/run_parallel.sh" ]] && found+=("run_parallel")
    [[ -f "${dir}/config/phases.yaml" ]] && found+=("phases_config")

    # Check for spec docs
    for doc in architecture.md implementation_roadmap.md orchestrator_spec.md dto_contracts.md db_adapter_spec.md; do
        if [[ -f "${dir}/docs/${doc}" ]]; then
            found+=("docs_templates")
            break
        fi
    done

    echo "${found[*]}"
}

# Detect missing skeleton-parallel files in a directory
# Prints each missing path (relative to dir), one per line
_detect_missing_files() {
    local dir="$1"

    # .github components
    [[ ! -f "${dir}/.github/copilot-instructions.md" ]] && echo ".github/copilot-instructions.md"
    [[ ! -d "${dir}/.github/skills" ]]                   && echo ".github/skills/"
    [[ ! -d "${dir}/.github/agents" ]]                   && echo ".github/agents/"
    [[ ! -d "${dir}/.github/prompts" ]]                  && echo ".github/prompts/"

    # Scripts
    [[ ! -f "${dir}/scripts/run_parallel.sh" ]] && echo "scripts/run_parallel.sh"

    # Config
    [[ ! -f "${dir}/config/phases.yaml" ]] && echo "config/phases.yaml"

    # Docs
    for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
               dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
               AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
        [[ ! -f "${dir}/docs/${doc}" ]] && echo "docs/${doc}"
    done
}

# Prompt user for upgrade mode when existing mechanisms are detected
# Returns: "replace", "hybrid", or "skip"
_prompt_upgrade_mode() {
    local dir="$1"
    local mechanisms="$2"

    echo "" >&2
    echo -e "${YELLOW}[WARN]${NC}  Existing skeleton-parallel mechanisms detected:" >&2
    for mech in ${mechanisms}; do
        echo -e "    ${YELLOW}●${NC} ${mech}" >&2
    done
    echo "" >&2
    echo -e "${BOLD}Choose upgrade mode:${NC}" >&2
    echo -e "  ${GREEN}[R]eplace${NC}  — Remove existing mechanisms, install fresh from skeleton-parallel" >&2
    echo -e "  ${CYAN}[H]ybrid${NC}   — Merge additively (add missing, preserve existing custom files)" >&2
    echo -e "  ${YELLOW}[S]kip${NC}     — Don't touch existing mechanisms, install only new components" >&2
    echo "" >&2
    read -rp "$(echo -e "${BOLD}Mode [R/H/S]: ${NC}")" mode_choice
    # Normalize input
    case "${mode_choice,,}" in
        r|replace)  printf 'replace' ;;
        h|hybrid)   printf 'hybrid' ;;
        s|skip)     printf 'skip' ;;
        *)          printf 'hybrid' ;;  # Default to hybrid (safest)
    esac
}

# Substitute template placeholders in a file
# Usage: substitute_placeholders <file> <project_name> <module_name>
substitute_placeholders() {
    local file="$1"
    local project_name="$2"
    local module_name="${3:-app}"

    # Derive common names
    local project_snake
    project_snake="$(echo "${project_name}" | tr '-' '_' | tr '[:upper:]' '[:lower:]')"
    local project_pascal
    project_pascal="$(echo "${project_name}" | sed -E 's/(^|[-_ ])([a-z])/\U\2/g')"

    # Escape all values for safe sed usage
    local esc_name esc_snake esc_pascal esc_module esc_year
    esc_name="$(_sed_escape "${project_name}")"
    esc_snake="$(_sed_escape "${project_snake}")"
    esc_pascal="$(_sed_escape "${project_pascal}")"
    esc_module="$(_sed_escape "${module_name}")"
    esc_year="$(date +%Y)"

    if [[ -f "${file}" ]]; then
        sed -i.bak \
            -e "s/{{PROJECT_NAME}}/${esc_name}/g" \
            -e "s/{{PROJECT_SNAKE}}/${esc_snake}/g" \
            -e "s/{{PROJECT_PASCAL}}/${esc_pascal}/g" \
            -e "s/{{MODULE_NAME}}/${esc_module}/g" \
            -e "s/{{YEAR}}/${esc_year}/g" \
            -e "s|example\.com/myapp|${esc_name}|g" \
            "${file}"
        rm -f "${file}.bak"
    fi
}

# Recursively substitute placeholders in all files in a directory
substitute_all() {
    local dir="$1"
    local project_name="$2"
    local module_name="${3:-app}"

    find "${dir}" -type f \( -name '*.go' -o -name '*.py' -o -name '*.ts' -o -name '*.js' \
        -o -name '*.rs' -o -name '*.java' -o -name '*.md' -o -name '*.yaml' -o -name '*.yml' \
        -o -name '*.json' -o -name '*.toml' -o -name '*.mod' -o -name '*.xml' \
        -o -name 'Makefile' -o -name '*.txt' -o -name '*.cfg' -o -name '*.sh' \) | while read -r f; do
        substitute_placeholders "${f}" "${project_name}" "${module_name}"
    done
}

# ── Available resources ──────────────────────────────────────────────────────
SUPPORTED_LANGUAGES=("go" "python" "typescript" "nodejs" "rust" "java")

get_available_skills() {
    local skills_dir="${SKELETON_ROOT}/.github/skills"
    if [[ -d "${skills_dir}" ]]; then
        find "${skills_dir}" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort
    fi
}

get_available_agents() {
    local agents_dir="${SKELETON_ROOT}/.github/agents"
    if [[ -d "${agents_dir}" ]]; then
        find "${agents_dir}" -name '*.agent.md' -exec basename {} .agent.md \; | sort
    fi
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: init
# ═════════════════════════════════════════════════════════════════════════════
cmd_init() {
    local language=""
    local language=""
    local project_name=""
    local target_dir=""
    local init_mode=""
    local init_role=""
    local init_root=""
    local force_overwrite=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name=*)    project_name="${1#*=}"; shift ;;
            --dir=*)     target_dir="${1#*=}"; shift ;;
            --name)      project_name="${2}"; shift 2 ;;
            --dir)       target_dir="${2}"; shift 2 ;;
            --no-agent)  SKIP_AGENT=true; shift ;;
            --mode=*)    init_mode="${1#*=}"; shift ;;
            --role=*)    init_role="${1#*=}"; shift ;;
            --root=*)    init_root="${1#*=}"; init_root="${init_root%/}"; shift ;;
            --mode)      init_mode="${2}"; shift 2 ;;
            --role)      init_role="${2}"; shift 2 ;;
            --root)      init_root="${2%/}"; shift 2 ;;
            --force)     force_overwrite=true; shift ;;
            -*)          die "Unknown option: $1" ;;
            *)
                if [[ -z "${language}" ]]; then
                    language="$1"
                else
                    die "Unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    # Validate language
    if [[ -z "${language}" ]]; then
        die "Usage: skeleton init <language> [--name=NAME] [--dir=DIR]\nSupported: ${SUPPORTED_LANGUAGES[*]}"
    fi

    local lang_found=false
    for l in "${SUPPORTED_LANGUAGES[@]}"; do
        [[ "${language}" == "${l}" ]] && lang_found=true
    done
    if ! ${lang_found}; then
        die "Unsupported language: ${language}\nSupported: ${SUPPORTED_LANGUAGES[*]}"
    fi

    # Validate --mode value
    case "${init_mode}" in
        ""|create|overlay|respect-existing) ;;
        *) die "Unknown --mode '${init_mode}'. Valid: create, overlay, respect-existing" ;;
    esac

    # Default project name
    if [[ -z "${project_name}" ]]; then
        if [[ -n "${target_dir}" ]]; then
            project_name="$(basename "${target_dir}")"
        elif [[ -n "${init_role}" ]]; then
            project_name="$(basename "$(pwd)")"
        else
            read -rp "$(echo -e "${CYAN}Project name: ${NC}")" project_name
            [[ -z "${project_name}" ]] && die "Project name is required"
        fi
    fi

    # Validate project name for safety
    _validate_project_name "${project_name}"

    # Default target directory
    if [[ -z "${target_dir}" ]]; then
        if [[ -n "${init_role}" ]]; then
            target_dir="."
        else
            target_dir="./${project_name}"
        fi
    fi

    # Resolve absolute path
    target_dir="$(cd "$(dirname "${target_dir}")" 2>/dev/null && pwd)/$(basename "${target_dir}")" \
        || target_dir="$(pwd)/${project_name}"

    # Resolve effective root (where language template files land)
    local effective_root
    effective_root="$(resolve_init_root "${target_dir}" "${init_role}" "${init_root}")"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton init                               ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    log_info "Language:     ${BOLD}${language}${NC}"
    log_info "Project:      ${BOLD}${project_name}${NC}"
    log_info "Directory:    ${BOLD}${target_dir}${NC}"
    [[ -n "${init_role}" ]] && log_info "Role:         ${BOLD}${init_role}${NC}"
    [[ "${effective_root}" != "${target_dir}" ]] && \
        log_info "Root:         ${BOLD}${effective_root}${NC}"
    echo ""

    # ── Mode detection ────────────────────────────────────────────────────
    if [[ -z "${init_mode}" ]]; then
        init_mode="$(detect_init_mode "${target_dir}" "${effective_root}" "${init_role}")"
        log_info "Mode (auto):  ${BOLD}${init_mode}${NC}"
    else
        log_info "Mode:         ${BOLD}${init_mode}${NC}"
    fi
    echo ""

    # In create mode, guard against non-empty target (legacy behavior preserved)
    if [[ "${init_mode}" == "create" ]]; then
        if [[ -d "${effective_root}" ]]; then
            local file_count
            file_count="$(find "${effective_root}" -maxdepth 1 -not -name '.' \
                | wc -l | tr -d ' ')"
            if [[ "${file_count}" -gt 0 ]] && [[ "${force_overwrite}" != "true" ]]; then
                log_warn "Directory ${effective_root} already exists and is not empty."
                confirm "Overwrite? (or use --mode=overlay / --mode=respect-existing)" \
                    || die "Aborted."
            fi
        fi
    fi

    mkdir -p "${effective_root}"

    # ── Step 1: Common files (always at project root, always idempotent) ──
    log_step "Copying common framework files..."
    _copy_common_overlay "${target_dir}" "${force_overwrite}"

    # ── Step 2: Language template (mode-aware, placed under effective root) ─
    log_step "Applying ${language} template to ${effective_root}..."
    local lang_template="${TEMPLATES_DIR}/${language}"
    if [[ ! -d "${lang_template}" ]]; then
        die "Template not found: ${lang_template}"
    fi

    # Collect declared architecture paths for respect-existing mode
    local arch_paths_file
    arch_paths_file="$(mktemp)"
    read_architecture_paths "${target_dir}" > "${arch_paths_file}"
    local arch_paths_count
    arch_paths_count="$(wc -l < "${arch_paths_file}" | tr -d ' ')"
    if [[ "${arch_paths_count}" -gt 0 ]]; then
        log_info "  Architecture declares ${arch_paths_count} path(s) — will be respected"
    fi

    # Determine if the role root itself is architecture-declared.
    # If so, all structure files placed under it would conflict with the
    # architecture's intended internal layout — skip them all.
    local role_arch_owned=false
    if [[ -n "${init_role}" ]] && [[ -s "${arch_paths_file}" ]]; then
        local role_root_name
        role_root_name="$(basename "${effective_root}")"
        if grep -qFx "${role_root_name}" "${arch_paths_file}" 2>/dev/null; then
            role_arch_owned=true
            log_info "  Role root '${role_root_name}' is architecture-declared — structure files will be skipped"
        fi
    fi

    local copied=0 skipped=0
    while IFS= read -r -d '' src_file; do
        local rel="${src_file#${lang_template}/}"
        local dest_file="${effective_root}/${rel}"
        if safe_copy_file \
            "${src_file}" "${dest_file}" \
            "${init_mode}" "${force_overwrite}" \
            "${arch_paths_file}" "${rel}" \
            "${role_arch_owned}"; then
            (( copied++ )) || true
        else
            (( skipped++ )) || true
        fi
    done < <(find "${lang_template}" -type f -print0)
    rm -f "${arch_paths_file}"
    log_ok "Template applied: ${copied} file(s) written, ${skipped} skipped"

    # ── Step 3: Substitute placeholders (scoped to effective root) ────────
    log_step "Customizing project files..."
    substitute_all "${effective_root}" "${project_name}"

    # ── Step 3.5: Write v1.0 config files ─────────────────────────────────
    log_step "Writing v1.0 configuration files..."
    _write_v1_config "${target_dir}" "${project_name}" "${language}" "${force_overwrite}"

    # ── Step 3.6: Write .skeleton/layout.yaml ─────────────────────────────
    log_step "Writing .skeleton/layout.yaml..."
    local arch_source=""
    for c in "docs/architecture.md" "architecture.md" "ARCHITECTURE.md"; do
        [[ -f "${target_dir}/${c}" ]] && arch_source="${c}" && break
    done
    local role_root_rel="${init_root:-${init_role}}"
    write_skeleton_layout \
        "${target_dir}" \
        "${init_role}" \
        "${language}" \
        "${role_root_rel}" \
        "${init_mode}" \
        "${arch_source}"

    # ── Step 4: Initialize git ────────────────────────────────────────────
    log_step "Initializing Git repository..."
    (
        cd "${target_dir}"
        if [[ ! -d ".git" ]]; then
            git init -q
            git add -A
            git commit -q -m "Initial commit: skeleton-parallel ${language} project (${project_name})"
        elif [[ "${init_mode}" == "create" ]]; then
            git add -A 2>/dev/null && \
            git diff --cached --quiet || \
            git commit -q -m "chore: skeleton init ${language} (${project_name})" 2>/dev/null || true
        else
            log_info "Git repo exists — skipping auto-commit (run: git add -A && git commit)"
        fi
    )

    # ── Step 5: Post-init setup ───────────────────────────────────────────
    log_step "Running post-init setup for ${language}..."
    _post_init_setup "${language}" "${target_dir}" "${project_name}"

    # ── Step 6: Spawn Copilot agent for project validation ────────────────
    log_step "Spawning Copilot agent for project validation..."
    _spawn_copilot_agent "${target_dir}" "scaffold" \
        "You are validating a newly initialized ${language} project named '${project_name}'. Perform a complete validation: 1) All docs/ templates exist (architecture.md, dto_contracts.md, orchestrator_spec.md, db_adapter_spec.md, implementation_roadmap.md, PARALLEL_DEV.md, AGENTS_AND_SKILLS.md, STARTER_GUIDE.md, PROGRESS_REPORT.md). 2) config/phases.yaml is present and properly structured. 3) scripts/run_parallel.sh is present and executable. 4) .github/ has all 28 skills, 15 agents, 7 prompts, and copilot-instructions.md. 5) Language-specific structure (${language}) matches skeleton-parallel modular monolith standards — contracts/ for DTOs, database/ for adapter, app/modules/ or src/modules/ for domain modules. 6) Health module reference implementation exists and is properly wired. 7) Ensure the project can seamlessly run parallel development via run_parallel.sh. Fix any issues found. After fixing, commit changes with message 'chore: post-init validation fixes'." \
        "init-validation"

    echo ""
    log_ok "Project ${BOLD}${project_name}${NC} initialized successfully!"
    [[ -n "${init_role}" ]] && \
        log_ok "Role ${BOLD}${init_role}${NC} configured at ${BOLD}${effective_root}${NC}"
    echo ""
    echo -e "  ${CYAN}Next steps:${NC}"
    echo -e "    cd ${target_dir}"
    if [[ -n "${init_role}" ]]; then
        echo -e "    # Add more roles:  skeleton init typescript --role=frontend --root=frontend/"
        echo -e "    skeleton doctor          # Validate merged layout"
    fi
    echo -e "    skeleton run --dry-run   # Preview execution plan"
    echo -e "    skeleton run             # Execute all pending tasks"
    [[ -z "${init_role}" ]] && echo -e "    skeleton doctor          # Run health check"
    echo -e "    # Legacy: ./scripts/run_parallel.sh start --mode=3 1 2 3"
    echo ""
}

# ── _write_v1_config ──────────────────────────────────────────────────────────
# Write v1.0 config files: .ai/manifest.yaml, config/skeleton.yaml,
# docs/PLAN.md (from stub), and scripts/hooks/ (from language template).
# Idempotent: skips existing files.
_write_v1_config() {
    local target_dir="$1"
    local project_name="$2"
    local language="$3"
    local force="${4:-false}"

    # Write .ai/manifest.yaml from template (idempotent — never overwrite unless force)
    local ai_dir="${target_dir}/.ai"
    mkdir -p "${ai_dir}"
    local manifest_tpl="${SKELETON_ROOT}/templates/ai/manifest.yaml.template"
    if [[ -f "${manifest_tpl}" ]]; then
        if [[ ! -f "${ai_dir}/manifest.yaml" ]] || [[ "${force}" == "true" ]]; then
            local esc_name; esc_name="$(_sed_escape "${project_name}")"
            sed \
                -e "s/<project-name>/${esc_name}/g" \
                -e "s/<domain>/${language}/g" \
                -e "s/<one-line description>/A ${language} project built with skeleton-parallel/g" \
                "${manifest_tpl}" > "${ai_dir}/manifest.yaml"
            log_ok ".ai/manifest.yaml created"
        else
            log_info ".ai/manifest.yaml already exists — preserved"
        fi
    else
        log_warn ".ai/manifest.yaml template not found — skipping"
    fi

    # Write config/skeleton.yaml from template (idempotent)
    local skeleton_tpl="${SKELETON_ROOT}/config/skeleton.yaml.template"
    mkdir -p "${target_dir}/config"
    if [[ -f "${skeleton_tpl}" ]] && [[ ! -f "${target_dir}/config/skeleton.yaml" ]]; then
        cp "${skeleton_tpl}" "${target_dir}/config/skeleton.yaml"
        log_ok "config/skeleton.yaml created"
    elif [[ -f "${target_dir}/config/skeleton.yaml" ]]; then
        log_info "config/skeleton.yaml already exists — preserved"
    fi

    # Create docs/PLAN.md from stub (idempotent)
    local plan_stub="${SKELETON_ROOT}/templates/docs/PLAN.md.stub"
    mkdir -p "${target_dir}/docs"
    if [[ -f "${plan_stub}" ]] && [[ ! -f "${target_dir}/docs/PLAN.md" ]]; then
        local esc_name; esc_name="$(_sed_escape "${project_name}")"
        sed -e "s/{{PROJECT_NAME}}/${esc_name}/g" "${plan_stub}" > "${target_dir}/docs/PLAN.md"
        log_ok "docs/PLAN.md created from stub"
    elif [[ -f "${target_dir}/docs/PLAN.md" ]]; then
        log_info "docs/PLAN.md already exists — preserved"
    fi

    # Create scripts/hooks/ from language template (idempotent)
    local hooks_tpl="${SKELETON_ROOT}/templates/hooks/${language}"
    local target_hooks="${target_dir}/scripts/hooks"
    mkdir -p "${target_hooks}"
    if [[ -d "${hooks_tpl}" ]]; then
        if [[ ! -f "${target_hooks}/quality-gates.sh" ]] || [[ "${force}" == "true" ]]; then
            cp -R "${hooks_tpl}/." "${target_hooks}/"
            find "${target_hooks}" -name '*.sh' -exec chmod +x {} \;
            log_ok "scripts/hooks/ created from ${language} template"
        else
            log_info "scripts/hooks/ already exists — preserved"
        fi
    else
        # Create minimal stub hooks if no template exists
        for hook in quality-gates acceptance-gates; do
            if [[ ! -f "${target_hooks}/${hook}.sh" ]]; then
                printf '#!/usr/bin/env bash\n# %s.sh\n# TODO: add project-specific gates\nexit 0\n' \
                    "${hook}" > "${target_hooks}/${hook}.sh"
                chmod +x "${target_hooks}/${hook}.sh"
            fi
        done
        log_info "scripts/hooks/ created with stub templates"
    fi
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: hooks — manage and regenerate hook scripts (Task 15)
# ═════════════════════════════════════════════════════════════════════════════
cmd_hooks() {
    local subcmd="${1:-help}"
    shift || true

    case "${subcmd}" in
        regenerate) _hooks_regenerate "$@" ;;
        help|--help|-h)
            echo ""
            echo "  skeleton hooks regenerate [--dir=DIR]"
            echo ""
            echo "  Detects the project stack and copies matching quality-gate"
            echo "  and acceptance-gate hook scripts to scripts/hooks/."
            echo ""
            ;;
        *)
            die "Unknown hooks subcommand: ${subcmd}. Use: skeleton hooks regenerate"
            ;;
    esac
}

# ── _hooks_regenerate ─────────────────────────────────────────────────────────
# Detect stack and install matching hook templates to scripts/hooks/.
# Supported stacks: go | python | typescript | fullstack | unknown
#
# Usage: _hooks_regenerate [--dir=DIR]
_hooks_regenerate() {
    local target_dir="."

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*) target_dir="${1#*=}"; shift ;;
            --dir)   target_dir="${2}"; shift 2 ;;
            *)       target_dir="$1"; shift ;;
        esac
    done

    target_dir="$(cd "${target_dir}" 2>/dev/null && pwd)" || die "Directory not found: ${target_dir}"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton hooks regenerate                   ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""

    # ── Detect stack ─────────────────────────────────────────────────────────
    local stack
    stack="$(_detect_stack "${target_dir}")"
    log_info "Detected stack: ${BOLD}${stack}${NC}"

    local hooks_tpl="${SKELETON_ROOT}/templates/hooks/${stack}"

    # Fallback if no matching template
    if [[ ! -d "${hooks_tpl}" ]] || [[ "${stack}" == "unknown" ]]; then
        log_warn "No specific hook template for '${stack}' — using go as fallback"
        stack="go"
        hooks_tpl="${SKELETON_ROOT}/templates/hooks/go"
    fi

    # ── Install hooks ─────────────────────────────────────────────────────────
    local target_hooks="${target_dir}/scripts/hooks"
    mkdir -p "${target_hooks}"

    if [[ -d "${hooks_tpl}" ]]; then
        cp -R "${hooks_tpl}/." "${target_hooks}/"
        find "${target_hooks}" -name '*.sh' -exec chmod +x {} \;
        log_ok "Hook scripts installed from '${stack}' template:"
        for hook in "${target_hooks}"/*.sh; do
            [[ -f "${hook}" ]] && log_ok "  $(basename "${hook}")"
        done
    else
        log_error "Hook template directory not found: ${hooks_tpl}"
        return 1
    fi

    echo ""
    log_ok "Hooks regenerated for stack: ${BOLD}${stack}${NC}"
    log_info "  Quality gates:    ${target_dir}/scripts/hooks/quality-gates.sh"
    log_info "  Acceptance gates: ${target_dir}/scripts/hooks/acceptance-gates.sh"
    echo ""
    return 0
}

# ── _detect_stack ─────────────────────────────────────────────────────────────
# Detect project stack: go | python | typescript | fullstack | unknown
# Differs from _detect_language by also detecting fullstack projects.
_detect_stack() {
    local dir="$1"

    # Check for fullstack (both backend and frontend indicators)
    local has_backend=false has_frontend=false

    [[ -f "${dir}/go.mod" ]] && has_backend=true
    [[ -f "${dir}/pyproject.toml" ]] || [[ -f "${dir}/requirements.txt" ]] && has_backend=true
    [[ -f "${dir}/pom.xml" ]] || [[ -f "${dir}/build.gradle" ]] && has_backend=true

    for d in frontend web client ui; do
        if [[ -d "${dir}/${d}" ]] && [[ -f "${dir}/${d}/package.json" ]]; then
            has_frontend=true
            break
        fi
    done

    if ${has_backend} && ${has_frontend}; then
        echo "fullstack"
        return
    fi

    # Single-stack detection (delegates to existing _detect_language)
    local lang
    lang="$(_detect_language "${dir}")"
    case "${lang}" in
        typescript|nodejs) echo "typescript" ;;
        go|python|rust|java) echo "${lang}" ;;
        *) echo "unknown" ;;
    esac
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: integrate — brownfield onboarding (Appendix A checklist)
# ═════════════════════════════════════════════════════════════════════════════
cmd_integrate() {
    local target_dir="."

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*) target_dir="${1#*=}"; shift ;;
            --dir)   target_dir="${2}"; shift 2 ;;
            --no-agent) SKIP_AGENT=true; shift ;;
            -*)      die "Unknown option: $1" ;;
            *)       target_dir="$1"; shift ;;
        esac
    done

    target_dir="$(cd "${target_dir}" 2>/dev/null && pwd)" || die "Directory not found: ${target_dir}"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton integrate                          ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    log_info "Integrating: ${BOLD}${target_dir}${NC}"
    echo ""

    # ── Step 1: Upgrade framework files ──────────────────────────────────
    log_step "[1/12] Upgrading framework files (hybrid mode)..."
    cmd_upgrade --dir="${target_dir}" --mode=hybrid --no-analyze -y 2>/dev/null || \
        log_warn "Upgrade had minor issues — continuing"

    # ── Step 2: Initialize .ai/ if absent ────────────────────────────────
    log_step "[2/12] Initializing .ai/ knowledge base..."
    if [[ ! -d "${target_dir}/.ai" ]]; then
        if command -v ars &>/dev/null; then
            (cd "${target_dir}" && ars init 2>/dev/null) || true
        fi
        mkdir -p "${target_dir}/.ai"
        log_ok ".ai/ directory created"
    else
        log_info ".ai/ already exists — skipping init"
    fi

    # ── Step 3: Detect + import legacy provider files ─────────────────────
    log_step "[3/12] Detecting legacy provider files..."
    if [[ -f "${SKELETON_ROOT}/scripts/knowledge/detect_legacy.py" ]]; then
        local detected
        detected="$(python3 "${SKELETON_ROOT}/scripts/knowledge/detect_legacy.py" \
            "${target_dir}" 2>/dev/null || echo "[]")"
        if [[ "${detected}" != "[]" ]] && command -v ars &>/dev/null; then
            log_info "Legacy sources found — running ars import"
            (cd "${target_dir}" && ars import '*' 2>/dev/null) || \
                log_warn "ars import returned non-zero — continuing"
        else
            log_info "No legacy sources to import (or ars not installed)"
        fi
    fi

    # ── Step 4: Write config/skeleton.yaml ────────────────────────────────
    log_step "[4/12] Writing runtime config (config/skeleton.yaml)..."
    mkdir -p "${target_dir}/config"
    if [[ ! -f "${target_dir}/config/skeleton.yaml" ]]; then
        local skel_tpl="${SKELETON_ROOT}/config/skeleton.yaml.template"
        if [[ -f "${skel_tpl}" ]]; then
            cp "${skel_tpl}" "${target_dir}/config/skeleton.yaml"
            log_ok "config/skeleton.yaml created"
        else
            log_warn "skeleton.yaml.template not found — skipping"
        fi
    else
        log_info "config/skeleton.yaml already exists — preserved"
    fi

    # ── Step 5: Write .ai/manifest.yaml ───────────────────────────────────
    log_step "[5/12] Writing identity config (.ai/manifest.yaml)..."
    mkdir -p "${target_dir}/.ai"
    if [[ ! -f "${target_dir}/.ai/manifest.yaml" ]]; then
        local manifest_tpl="${SKELETON_ROOT}/templates/ai/manifest.yaml.template"
        if [[ -f "${manifest_tpl}" ]]; then
            local project_name detected_lang
            project_name="$(basename "${target_dir}")"
            detected_lang="$(_detect_language "${target_dir}")"
            local esc_name; esc_name="$(_sed_escape "${project_name}")"
            sed \
                -e "s/<project-name>/${esc_name}/g" \
                -e "s/<domain>/${detected_lang:-unknown}/g" \
                -e "s/<one-line description>/Integrated with skeleton-parallel/g" \
                "${manifest_tpl}" > "${target_dir}/.ai/manifest.yaml"
            log_ok ".ai/manifest.yaml created"
        else
            log_warn "manifest.yaml.template not found — skipping"
        fi
    else
        log_info ".ai/manifest.yaml already exists — preserved"
    fi

    # ── Step 6: ars validate ──────────────────────────────────────────────
    log_step "[6/12] Running ars validate..."
    if command -v ars &>/dev/null && [[ -d "${target_dir}/.ai" ]]; then
        (cd "${target_dir}" && ars validate 2>/dev/null) && log_ok "ars validate passed" || \
            log_warn "ars validate returned issues — check .ai/ structure"
    else
        log_info "ars validate skipped (ars not installed or .ai/ empty)"
    fi

    # ── Step 7: ars compose ───────────────────────────────────────────────
    log_step "[7/12] Running ars compose..."
    if command -v ars &>/dev/null && [[ -d "${target_dir}/.ai" ]]; then
        (cd "${target_dir}" && ars compose --target copilot 2>/dev/null) && \
            log_ok "ars compose completed" || \
            log_warn "ars compose returned issues — continuing"
    else
        log_info "ars compose skipped (ars not installed)"
    fi

    # ── Step 8/9: Router install + OAuth ─────────────────────────────────
    log_step "[8/12] Router setup (advisory)..."
    log_info "  Run manually if needed: skeleton router install && skeleton router start"
    log_step "[9/12] Router OAuth (advisory)..."
    log_info "  Run manually if needed: skeleton router oauth"

    # ── Step 10: Generate hooks ───────────────────────────────────────────
    log_step "[10/12] Generating hook templates..."
    local detected_lang
    detected_lang="$(_detect_language "${target_dir}")"
    local hooks_tpl="${SKELETON_ROOT}/templates/hooks/${detected_lang:-go}"
    local target_hooks="${target_dir}/scripts/hooks"
    mkdir -p "${target_hooks}"
    if [[ -d "${hooks_tpl}" ]]; then
        cp -R "${hooks_tpl}/." "${target_hooks}/"
        find "${target_hooks}" -name '*.sh' -exec chmod +x {} \;
        log_ok "Hook scripts installed from ${detected_lang:-go} template"
    else
        for hook in quality-gates acceptance-gates; do
            [[ -f "${target_hooks}/${hook}.sh" ]] && continue
            printf '#!/usr/bin/env bash\n# %s.sh — stub\nexit 0\n' "${hook}" > \
                "${target_hooks}/${hook}.sh"
            chmod +x "${target_hooks}/${hook}.sh"
        done
        log_info "scripts/hooks/ created with stubs"
    fi

    # ── Step 11: skeleton doctor ──────────────────────────────────────────
    log_step "[11/12] Running health check..."
    cmd_doctor --dir="${target_dir}" --no-agent || true

    # ── Step 12: Print next step ──────────────────────────────────────────
    log_step "[12/12] Integration complete!"
    echo ""
    log_ok "Project ${BOLD}$(basename "${target_dir}")${NC} is integrated with skeleton-parallel v1.0"
    echo ""
    echo -e "  ${CYAN}Next steps:${NC}"
    echo -e "    skeleton run --dry-run   # Preview execution plan"
    echo -e "    skeleton run             # Execute all pending tasks"
    echo ""
}

# ═════════════════════════════════════════════════════════════════════════════
# INIT HELPERS: Architecture-aware additive scaffolding
# ═════════════════════════════════════════════════════════════════════════════

# read_architecture_paths <project_root>
# Parses tree-diagram lines from architecture.md. Returns declared dirs at
# depth 1-2, one per line. Safe to call when no architecture file exists.
read_architecture_paths() {
    local project_root="$1"
    local arch_file=""
    for candidate in "${project_root}/docs/architecture.md" \
                     "${project_root}/architecture.md" \
                     "${project_root}/ARCHITECTURE.md"; do
        [[ -f "${candidate}" ]] && arch_file="${candidate}" && break
    done
    [[ -z "${arch_file}" ]] && return 0

    if command -v python3 &>/dev/null; then
        python3 - "${arch_file}" << '__ARCHPY__'
import sys, re
arch_file = sys.argv[1]
try:
    with open(arch_file, encoding="utf-8", errors="replace") as f:
        content = f.read()
except Exception:
    sys.exit(0)
# Box-drawing chars: ├─ └─ │ and ASCII equivalents
tree_re = re.compile(r"[├└│─|+]")
dirs = set()
for line in content.splitlines():
    if not tree_re.search(line):
        continue
    cleaned = tree_re.sub(" ", line).strip()
    token = cleaned.split()[0] if cleaned.split() else ""
    if not token.endswith("/"):
        continue
    name = token.rstrip("/")
    parts = [p for p in name.split("/") if p]
    if 1 <= len(parts) <= 2:
        dirs.add("/".join(parts))
for d in sorted(dirs):
    print(d)
__ARCHPY__
    else
        # Fallback: grab tokens ending in / from the file
        LC_ALL=C grep -oE '[a-zA-Z][a-zA-Z0-9._-]*/' "${arch_file}" \
            | sed 's|/$||' | sort -u || true
    fi
}

# resolve_init_root <target_dir> <init_role> <init_root_flag>
# Returns the absolute path where template files should land.
resolve_init_root() {
    local target_dir="$1"
    local init_role="$2"
    local init_root_flag="$3"
    if [[ -n "${init_root_flag}" ]]; then
        echo "${target_dir}/${init_root_flag%/}"
    elif [[ -n "${init_role}" ]]; then
        echo "${target_dir}/${init_role}"
    else
        echo "${target_dir}"
    fi
}

# detect_init_mode <target_dir> <effective_root> <init_role>
# Auto-detects the merge mode. Prints: create | overlay | respect-existing
detect_init_mode() {
    local target_dir="$1"
    local effective_root="$2"
    local init_role="$3"

    [[ -f "${target_dir}/.skeleton/layout.yaml" ]] && echo "respect-existing" && return

    local arch_found=false
    for candidate in "${target_dir}/docs/architecture.md" \
                     "${target_dir}/architecture.md" \
                     "${target_dir}/ARCHITECTURE.md"; do
        [[ -f "${candidate}" ]] && arch_found=true && break
    done

    # Architecture exists + role specified → always respect-existing.
    # The architecture is the source of truth for the internal layout;
    # don't impose the template's structure even into a brand-new role dir.
    if [[ "${arch_found}" == "true" ]] && [[ -n "${init_role}" ]]; then
        echo "respect-existing"; return
    fi

    if [[ -n "${init_role}" ]] && [[ -d "${effective_root}" ]]; then
        local existing_count
        existing_count="$(find "${effective_root}" -maxdepth 1 -not -name '.' \
            2>/dev/null | wc -l | tr -d ' ')"
        if [[ "${existing_count}" -gt 0 ]]; then
            echo "overlay"; return
        fi
    fi

    if [[ "${effective_root}" == "${target_dir}" ]]; then
        local root_count
        root_count="$(find "${target_dir}" -maxdepth 1 -not -name '.' \
            -not -name '.git' -not -name '.skeleton' 2>/dev/null | wc -l | tr -d ' ')"
        if [[ "${root_count}" -gt 0 ]]; then
            ${arch_found} && echo "respect-existing" || echo "overlay"; return
        fi
    fi

    echo "create"
}

# _is_structure_file <relative_path>
# Returns 0 (structure = skip in respect-existing) for source directories.
# Returns 1 (tooling = safe to place) for build configs, etc.
_is_structure_file() {
    local rel_path="$1"
    local top_dir; top_dir="$(echo "${rel_path}" | cut -d'/' -f1)"
    local depth; depth=$(echo "${rel_path}" | tr -cd '/' | wc -c | tr -d ' ')

    [[ "${depth}" -eq 0 ]] && return 1

    if [[ "${depth}" -eq 1 ]]; then
        local filename; filename="$(basename "${rel_path}")"
        local tooling_files=(
            "pyproject.toml" "requirements.txt" "requirements-dev.txt"
            "go.mod" "go.sum" "package.json" "package-lock.json"
            "yarn.lock" "pnpm-lock.yaml" "Cargo.toml" "Cargo.lock"
            "pom.xml" "build.gradle" "settings.gradle"
            "Makefile" "GNUmakefile" ".gitignore" ".gitattributes"
            ".env.example" "tsconfig.json" "tsconfig.base.json"
            ".eslintrc.js" ".eslintrc.json" ".eslintrc.yaml"
            "config.yaml" "config.yml"
        )
        for tfile in "${tooling_files[@]}"; do
            [[ "${filename}" == "${tfile}" ]] && return 1
        done
    fi

    local structure_tops=(
        "app" "src" "internal" "cmd" "lib"
        "contracts" "database" "modules" "tests" "test" "orchestrator"
    )
    for sdir in "${structure_tops[@]}"; do
        [[ "${top_dir}" == "${sdir}" ]] && return 0
    done
    return 1
}

# safe_copy_file <src> <dest> <mode> <force> <arch_paths_file> <rel_path> [role_arch_owned]
# Core file placement primitive. Returns 0 on copy, 1 on skip.
safe_copy_file() {
    local src="$1" dest="$2" mode="$3"
    local force="${4:-false}"
    local arch_paths_file="${5:-/dev/null}"
    local rel_path="${6:-}"
    local role_arch_owned="${7:-false}"

    case "${mode}" in
        create)
            if [[ -f "${dest}" ]] && [[ "${force}" != "true" ]]; then return 1; fi
            mkdir -p "$(dirname "${dest}")" && cp "${src}" "${dest}"
            return 0
            ;;
        overlay)
            if [[ -f "${dest}" ]] && [[ "${force}" != "true" ]]; then return 1; fi
            mkdir -p "$(dirname "${dest}")" && cp "${src}" "${dest}"
            return 0
            ;;
        respect-existing)
            [[ -f "${dest}" ]] && return 1
            if [[ -n "${rel_path}" ]] && _is_structure_file "${rel_path}"; then
                # If role root is arch-declared, ALL structure files are off-limits —
                # the architecture defines the internal layout, not the template.
                [[ "${role_arch_owned}" == "true" ]] && return 1
                # Otherwise check if this file's top-level dir is arch-declared.
                local top_dir; top_dir="$(echo "${rel_path}" | cut -d'/' -f1)"
                if grep -qFx "${top_dir}" "${arch_paths_file}" 2>/dev/null; then return 1; fi
            fi
            mkdir -p "$(dirname "${dest}")" && cp "${src}" "${dest}"
            return 0
            ;;
    esac
    return 1
}

# write_skeleton_layout <project_root> <role> <language> <role_root> <mode> <arch_source>
# Creates or idempotently updates .skeleton/layout.yaml at the project root.
write_skeleton_layout() {
    local project_root="$1" role_name="${2:-}" language="$3"
    local role_root="${4:-}" merge_mode="${5:-create}" arch_source="${6:-}"
    local layout_dir="${project_root}/.skeleton"
    local layout_file="${layout_dir}/layout.yaml"
    mkdir -p "${layout_dir}"

    if [[ ! -f "${layout_file}" ]]; then
        {
            echo "version: \"1.0\""
            echo "merge_policy: ${merge_mode}"
            [[ -n "${arch_source}" ]] && echo "architecture_source: ${arch_source}"
            echo "roles:"
            if [[ -n "${role_name}" ]] && [[ -n "${role_root}" ]]; then
                echo "  ${role_name}:"
                echo "    language: ${language}"
                echo "    root: ${role_root}/"
                echo "    status: active"
            fi
        } > "${layout_file}"
        log_ok ".skeleton/layout.yaml created"
        return
    fi

    # File exists — update using Python for reliable YAML merging
    if command -v python3 &>/dev/null; then
        local py_script="${TMPDIR:-/tmp}/sk_layout_update_$$.py"
        cat > "${py_script}" << 'SKPY'
import sys
layout_file, role_name, language, role_root, merge_mode, arch_source = sys.argv[1:]
with open(layout_file) as f:
    lines = f.readlines()
data_lines, roles_block, in_roles = [], [], False
for line in lines:
    s = line.rstrip()
    if s.startswith("merge_policy:"):
        data_lines.append(f"merge_policy: {merge_mode}\n"); continue
    if s.startswith("roles:"):
        in_roles = True; data_lines.append(line); continue
    if in_roles:
        if s and not s.startswith(" ") and not s.startswith("\t"):
            in_roles = False
        else:
            roles_block.append(line); continue
    if not in_roles:
        data_lines.append(line)
if role_name:
    if any(f"  {role_name}:" in l for l in roles_block):
        nr, in_t = [], False
        for line in roles_block:
            s = line.rstrip()
            if s == f"  {role_name}:":
                in_t = True; nr.append(line)
                nr += [f"    language: {language}\n",
                       f"    root: {role_root}/\n",
                       f"    status: active\n"]
            elif in_t and s.startswith("    "):
                continue
            else:
                in_t = False; nr.append(line)
        roles_block = nr
    else:
        roles_block += [f"  {role_name}:\n",
                        f"    language: {language}\n",
                        f"    root: {role_root}/\n",
                        f"    status: active\n"]
if arch_source and not any("architecture_source:" in l for l in data_lines):
    nd = []
    for line in data_lines:
        nd.append(line)
        if line.startswith("merge_policy:"):
            nd.append(f"architecture_source: {arch_source}\n")
    data_lines = nd
with open(layout_file, "w") as f:
    f.writelines(data_lines); f.writelines(roles_block)
SKPY
        python3 "${py_script}" "${layout_file}" "${role_name}" "${language}" \
                "${role_root}" "${merge_mode}" "${arch_source}"
        rm -f "${py_script}"
        log_ok ".skeleton/layout.yaml updated (role: ${role_name:-none})"
    else
        [[ -n "${role_name}" ]] && [[ -n "${role_root}" ]] && \
            printf '  %s:\n    language: %s\n    root: %s/\n    status: active\n' \
                "${role_name}" "${language}" "${role_root}" >> "${layout_file}"
        log_ok ".skeleton/layout.yaml updated"
    fi
}

# _copy_common_overlay <dest> <force>
# Idempotent version of _copy_common — never overwrites unless force=true.
_copy_common_overlay() {
    local dest="$1" force="${2:-false}"

    mkdir -p "${dest}/.github"
    for src_dir in skills agents prompts; do
        local src="${SKELETON_ROOT}/.github/${src_dir}"
        local dst="${dest}/.github/${src_dir}"
        [[ ! -d "${src}" ]] && continue
        if [[ ! -d "${dst}" ]] || [[ "${force}" == "true" ]]; then
            cp -R "${src}" "${dest}/.github/"; log_ok "  .github/${src_dir}/ installed"
        else
            log_info "  .github/${src_dir}/ already exists — preserved"
        fi
    done
    local instr_src="${SKELETON_ROOT}/.github/copilot-instructions.md"
    local instr_dst="${dest}/.github/copilot-instructions.md"
    if [[ -f "${instr_src}" ]]; then
        if [[ ! -f "${instr_dst}" ]] || [[ "${force}" == "true" ]]; then
            cp "${instr_src}" "${instr_dst}"; log_ok "  .github/copilot-instructions.md installed"
        else
            log_info "  .github/copilot-instructions.md already exists — preserved"
        fi
    fi

    mkdir -p "${dest}/scripts"
    local rp_src="${SKELETON_ROOT}/scripts/run_parallel.sh"
    local rp_dst="${dest}/scripts/run_parallel.sh"
    if [[ -f "${rp_src}" ]]; then
        if [[ ! -f "${rp_dst}" ]] || [[ "${force}" == "true" ]]; then
            cp "${rp_src}" "${rp_dst}"; chmod +x "${rp_dst}"; log_ok "  scripts/run_parallel.sh installed"
        else
            log_info "  scripts/run_parallel.sh already exists — preserved"
        fi
    fi

    mkdir -p "${dest}/config"
    local phases_src="${SKELETON_ROOT}/config/phases.yaml"
    local phases_dst="${dest}/config/phases.yaml"
    if [[ -f "${phases_src}" ]]; then
        if [[ ! -f "${phases_dst}" ]] || [[ "${force}" == "true" ]]; then
            cp "${phases_src}" "${phases_dst}"; log_ok "  config/phases.yaml installed"
        else
            log_info "  config/phases.yaml already exists — preserved"
        fi
    fi

    mkdir -p "${dest}/docs"
    for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
               dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
               AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
        local dsrc="${SKELETON_ROOT}/docs/${doc}"
        local ddst="${dest}/docs/${doc}"
        if [[ -f "${dsrc}" ]]; then
            if [[ ! -f "${ddst}" ]] || [[ "${force}" == "true" ]]; then
                cp "${dsrc}" "${ddst}"; log_ok "  docs/${doc} installed"
            else
                log_info "  docs/${doc} already exists — preserved"
            fi
        fi
    done

    mkdir -p "${dest}/output"
    [[ ! -f "${dest}/output/.gitignore" ]] && echo '*' > "${dest}/output/.gitignore"
}

_copy_common() {
    local dest="$1"

    # .github directory (skills, agents, prompts, copilot-instructions)
    mkdir -p "${dest}/.github"
    if [[ -d "${SKELETON_ROOT}/.github/skills" ]]; then
        cp -R "${SKELETON_ROOT}/.github/skills" "${dest}/.github/"
    fi
    if [[ -d "${SKELETON_ROOT}/.github/agents" ]]; then
        cp -R "${SKELETON_ROOT}/.github/agents" "${dest}/.github/"
    fi
    if [[ -d "${SKELETON_ROOT}/.github/prompts" ]]; then
        cp -R "${SKELETON_ROOT}/.github/prompts" "${dest}/.github/"
    fi
    if [[ -f "${SKELETON_ROOT}/.github/copilot-instructions.md" ]]; then
        cp "${SKELETON_ROOT}/.github/copilot-instructions.md" "${dest}/.github/"
    fi

    # Scripts
    mkdir -p "${dest}/scripts"
    if [[ -f "${SKELETON_ROOT}/scripts/run_parallel.sh" ]]; then
        cp "${SKELETON_ROOT}/scripts/run_parallel.sh" "${dest}/scripts/"
        chmod +x "${dest}/scripts/run_parallel.sh"
    fi

    # Config
    mkdir -p "${dest}/config"
    if [[ -f "${SKELETON_ROOT}/config/phases.yaml" ]]; then
        cp "${SKELETON_ROOT}/config/phases.yaml" "${dest}/config/"
    fi

    # Docs templates
    mkdir -p "${dest}/docs"
    for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
               dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
               AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
        if [[ -f "${SKELETON_ROOT}/docs/${doc}" ]]; then
            cp "${SKELETON_ROOT}/docs/${doc}" "${dest}/docs/"
        fi
    done

    # Output directory
    mkdir -p "${dest}/output"
    echo '*' > "${dest}/output/.gitignore"
}

_post_init_setup() {
    local language="$1"
    local target_dir="$2"
    local project_name="$3"

    case "${language}" in
        go)
            log_info "Tip: Run 'go mod tidy' to install dependencies."
            ;;
        python)
            log_info "Tip: Run 'python -m venv .venv && pip install -r requirements.txt' to set up."
            ;;
        typescript)
            log_info "Tip: Run 'npm install' to install dependencies."
            ;;
        nodejs)
            log_info "Tip: Run 'npm install' to install dependencies, then 'npm test' to run tests."
            ;;
        rust)
            log_info "Tip: Run 'cargo build' to compile the project."
            ;;
        java)
            log_info "Tip: Run 'mvn compile' or 'gradle build' to compile."
            ;;
    esac
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: upgrade — helper: spawn Explore to analyze project before install
# Writes .parallel-dev/upgrade-context.md for use by upgrade-manager
# ═════════════════════════════════════════════════════════════════════════════
_upgrade_analyze_context() {
    local target_dir="$1"
    local detected_lang="$2"
    local context_file="${target_dir}/.parallel-dev/upgrade-context.md"

    mkdir -p "${target_dir}/.parallel-dev/agent-logs"

    # Ensure Explore agent exists in target project (may not be installed yet)
    local explore_agent_dst="${target_dir}/.github/agents/Explore.agent.md"
    local explore_agent_src="${SKELETON_ROOT}/.github/agents/Explore.agent.md"
    if [[ ! -f "${explore_agent_dst}" ]] && [[ -f "${explore_agent_src}" ]]; then
        mkdir -p "${target_dir}/.github/agents"
        cp "${explore_agent_src}" "${explore_agent_dst}"
        log_info "Installed Explore agent to target project (for pre-upgrade analysis)"
    fi

    _spawn_copilot_agent "${target_dir}" "Explore" \
        "Analyze this ${detected_lang:-unknown} project BEFORE skeleton-parallel installation. Write a structured report to .parallel-dev/upgrade-context.md covering:

## 1. Project Structure
- Actual source layout (module/package directories, entry points)
- Detected domains/features — list each as a potential parallel-dev phase
- Language version and key runtime dependencies

## 2. Database
- Database engine (postgres, sqlite, mysql, etc.) if any
- Migration tool in use (flyway, alembic, goose, liquibase, etc.)
- ORM or query builder in use

## 3. Testing
- Test framework(s) and test runner commands
- Location of test files
- CI configuration (GitHub Actions, CircleCI, Jenkins, etc.)

## 4. Git & Collaboration
- Git remote URL and platform (GitHub, GitLab, Bitbucket)
- Default branch name (main, master, etc.)
- Existing branch naming conventions
- PR/MR label conventions if any

## 5. Existing Scripts & Automation
- Makefile targets or scripts that overlap with run_parallel.sh
- Any existing parallel/concurrent task runners or CI pipeline definitions

## 6. Phase Candidates
- List 3-8 concrete phase names derived from the actual codebase structure
- Each entry: phase name, what it implements, rough dependency order
- Example: 'phase-auth: JWT authentication layer, depends on phase-db'

## 7. config/phases.yaml Suggestions
- Propose the phases.yaml 'phases:' block tailored to this project's domains
- Use actual module names, not generic placeholders

## 8. scripts/run_parallel.sh Adaptation Notes
- Any env vars that need to change (PR_LABEL, DEFAULT_BRANCH, etc.)
- Integration branch naming that fits the project's conventions

## 9. Upgrade Risks
- Files or patterns that might conflict with skeleton-parallel conventions
- Any non-standard structures that need special handling during upgrade

Write the complete report to: .parallel-dev/upgrade-context.md
Do NOT modify any other project files." \
        "upgrade-context-analysis"
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: upgrade
# ═════════════════════════════════════════════════════════════════════════════
# ── Preview what an upgrade mode will change (dry-run, no writes) ────────
_upgrade_preview() {
    local target_dir="$1"
    local upgrade_mode="$2"

    echo ""
    log_step "Preview — changes that will be applied (${BOLD}${upgrade_mode}${NC} mode):"
    echo ""

    local skills_count
    skills_count="$(get_available_skills | wc -l | tr -d ' ')"
    local agents_count
    agents_count="$(get_available_agents | wc -l | tr -d ' ')"

    case "${upgrade_mode}" in
        replace)
            echo -e "  ${RED}[replace]${NC}  .github/skills/        (${skills_count} skills — all overwritten)"
            echo -e "  ${RED}[replace]${NC}  .github/agents/        (${agents_count} agents — all overwritten)"
            echo -e "  ${RED}[replace]${NC}  .github/prompts/"
            echo -e "  ${RED}[replace]${NC}  .github/copilot-instructions.md"
            echo -e "  ${RED}[replace]${NC}  scripts/run_parallel.sh"
            echo -e "  ${RED}[replace]${NC}  config/phases.yaml"
            for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
                       dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
                       AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
                echo -e "  ${RED}[replace]${NC}  docs/${doc}"
            done
            ;;
        hybrid)
            echo -e "  ${GREEN}[update]${NC}   .github/skills/        (${skills_count} skills — always synced)"
            echo -e "  ${GREEN}[update]${NC}   .github/agents/        (${agents_count} agents — always synced)"
            echo -e "  ${GREEN}[update]${NC}   .github/prompts/       (always synced)"
            echo -e "  ${GREEN}[update]${NC}   scripts/run_parallel.sh"
            if [[ -f "${target_dir}/.github/copilot-instructions.md" ]]; then
                echo -e "  ${CYAN}[preserve]${NC} .github/copilot-instructions.md (exists — kept as-is)"
            else
                echo -e "  ${GREEN}[install]${NC}  .github/copilot-instructions.md (missing — will install)"
            fi
            if [[ -f "${target_dir}/config/phases.yaml" ]]; then
                echo -e "  ${CYAN}[preserve]${NC} config/phases.yaml (exists — kept as-is)"
            else
                echo -e "  ${GREEN}[install]${NC}  config/phases.yaml (missing — will install)"
            fi
            for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
                       dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
                       AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
                if [[ -f "${target_dir}/docs/${doc}" ]]; then
                    echo -e "  ${CYAN}[preserve]${NC} docs/${doc} (exists — kept as-is)"
                else
                    echo -e "  ${GREEN}[install]${NC}  docs/${doc} (missing — will install)"
                fi
            done
            ;;
        skip)
            for item in ".github/skills" ".github/agents" ".github/prompts"; do
                if [[ -d "${target_dir}/${item}" ]]; then
                    echo -e "  ${YELLOW}[skip]${NC}     ${item}/ (exists — no changes)"
                else
                    echo -e "  ${GREEN}[install]${NC}  ${item}/ (missing — will install)"
                fi
            done
            if [[ -f "${target_dir}/.github/copilot-instructions.md" ]]; then
                echo -e "  ${YELLOW}[skip]${NC}     .github/copilot-instructions.md (exists — no changes)"
            else
                echo -e "  ${GREEN}[install]${NC}  .github/copilot-instructions.md (missing — will install)"
            fi
            if [[ -f "${target_dir}/scripts/run_parallel.sh" ]]; then
                echo -e "  ${YELLOW}[skip]${NC}     scripts/run_parallel.sh (exists — no changes)"
            else
                echo -e "  ${GREEN}[install]${NC}  scripts/run_parallel.sh (missing — will install)"
            fi
            if [[ -f "${target_dir}/config/phases.yaml" ]]; then
                echo -e "  ${YELLOW}[skip]${NC}     config/phases.yaml (exists — no changes)"
            else
                echo -e "  ${GREEN}[install]${NC}  config/phases.yaml (missing — will install)"
            fi
            for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
                       dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
                       AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
                if [[ -f "${target_dir}/docs/${doc}" ]]; then
                    echo -e "  ${YELLOW}[skip]${NC}     docs/${doc} (exists — no changes)"
                else
                    echo -e "  ${GREEN}[install]${NC}  docs/${doc} (missing — will install)"
                fi
            done
            ;;
    esac
    echo ""
    echo -e "  ${GREEN}[update]${NC}   = overwrite with latest skeleton version"
    echo -e "  ${GREEN}[install]${NC}  = copy from skeleton (file does not exist yet)"
    echo -e "  ${CYAN}[preserve]${NC} = keep your existing file unchanged"
    echo -e "  ${RED}[replace]${NC}  = remove existing and install fresh skeleton version"
    echo -e "  ${YELLOW}[skip]${NC}     = file exists, no action taken"
    echo ""
}

cmd_upgrade() {
    local target_dir="."
    local force_mode=""
    local no_analyze=false
    local auto_yes=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*)      target_dir="${1#*=}"; shift ;;
            --dir)        target_dir="${2}"; shift 2 ;;
            --mode=*)     force_mode="${1#*=}"; shift ;;
            --no-agent)   SKIP_AGENT=true; shift ;;
            --no-analyze) no_analyze=true; shift ;;
            -y|--yes)     auto_yes=true; shift ;;
            -*)           die "Unknown option: $1" ;;
            *)            target_dir="$1"; shift ;;
        esac
    done

    target_dir="$(cd "${target_dir}" 2>/dev/null && pwd)" || die "Directory not found: ${target_dir}"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton upgrade                            ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    log_info "Target: ${BOLD}${target_dir}${NC}"
    echo ""

    # ── Step 0: Detect language ────────────────────────────────────────────
    log_step "Detecting project language..."
    local detected_lang
    detected_lang="$(_detect_language "${target_dir}")"
    if [[ -n "${detected_lang}" ]]; then
        log_ok "Detected language: ${BOLD}${detected_lang}${NC}"
    else
        log_warn "Could not auto-detect language."
    fi
    echo ""

    # ── Step 1: Pre-upgrade analysis (Explore agent) ──────────────────────
    local context_file="${target_dir}/.parallel-dev/upgrade-context.md"
    if _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]] && [[ "${no_analyze}" != "true" ]]; then
        if [[ -f "${context_file}" ]]; then
            log_info "Pre-upgrade analysis already exists — skipping (use --no-analyze to skip, or delete .parallel-dev/upgrade-context.md to re-run)"
        else
            log_step "Spawning Explore agent to analyze project before installing..."
            log_info "The agent will explore the project and write a context report."
            echo ""
            _upgrade_analyze_context "${target_dir}" "${detected_lang}" || true
        fi
    elif [[ "${no_analyze}" == "true" ]]; then
        log_info "Pre-upgrade analysis skipped (--no-analyze)"
    fi
    echo ""

    # ── Step 2: Detect existing mechanisms ────────────────────────────────
    log_step "Detecting existing skeleton-parallel mechanisms..."
    local existing_mechanisms
    existing_mechanisms="$(_detect_existing_mechanisms "${target_dir}")"

    # Report missing files before deciding upgrade mode
    local missing_files=()
    while IFS= read -r line; do
        [[ -n "${line}" ]] && missing_files+=("${line}")
    done < <(_detect_missing_files "${target_dir}")

    if [[ ${#missing_files[@]} -gt 0 ]]; then
        echo ""
        log_warn "Missing skeleton-parallel files detected (${#missing_files[@]} item(s)):"
        for f in "${missing_files[@]}"; do
            echo -e "    ${RED}✗${NC} ${f}"
        done
        echo ""
    else
        log_ok "All skeleton-parallel files present"
    fi

    local upgrade_mode="replace"
    if [[ -n "${existing_mechanisms}" ]]; then
        if [[ -n "${force_mode}" ]]; then
            upgrade_mode="${force_mode}"
            log_info "Using forced mode: ${upgrade_mode}"
        else
            upgrade_mode="$(_prompt_upgrade_mode "${target_dir}" "${existing_mechanisms}")"
        fi
        log_info "Upgrade mode: ${BOLD}${upgrade_mode}${NC}"
    else
        log_ok "No existing mechanisms found — full install"
    fi
    echo ""

    # ── Step 2: Preview changes + confirm before writing anything ─────────
    _upgrade_preview "${target_dir}" "${upgrade_mode}"

    if [[ "${auto_yes}" != true ]]; then
        printf "%b" "${BOLD}Apply these changes? [y/N]: ${NC}"
        read -r proceed_choice
        echo ""
        if [[ "${proceed_choice,,}" != "y" && "${proceed_choice,,}" != "yes" ]]; then
            log_info "Aborted. No files were modified."
            echo ""
            return 0
        fi
    fi

    # ── Step 3: Apply upgrade based on mode ───────────────────────────────
    case "${upgrade_mode}" in
        replace)
            _upgrade_replace "${target_dir}"
            ;;
        hybrid)
            _upgrade_hybrid "${target_dir}"
            ;;
        skip)
            _upgrade_skip "${target_dir}"
            ;;
    esac

    # ── Step 2b: Confirm no missing files remain ──────────────────────────
    local remaining_missing=()
    while IFS= read -r line; do
        [[ -n "${line}" ]] && remaining_missing+=("${line}")
    done < <(_detect_missing_files "${target_dir}")

    if [[ ${#remaining_missing[@]} -eq 0 ]]; then
        log_ok "All skeleton-parallel files are now present"
    else
        log_warn "${#remaining_missing[@]} file(s) still missing after upgrade:"
        for f in "${remaining_missing[@]}"; do
            echo -e "    ${RED}✗${NC} ${f}"
        done
    fi
    echo ""

    # ── Step 3: Spawn upgrade-manager for context-aware post-upgrade adaptation ──
    log_step "Spawning upgrade-manager agent for context-aware adaptation..."
    local context_hint=""
    if [[ -f "${context_file}" ]]; then
        context_hint="A pre-upgrade analysis report is available at .parallel-dev/upgrade-context.md — READ IT FIRST before making any decisions. Use the Phase Candidates, config/phases.yaml Suggestions, and Adaptation Notes sections to customize installed files for this specific project."
    else
        context_hint="No pre-upgrade analysis report was generated. Analyze the project structure yourself before making changes."
    fi
    _spawn_copilot_agent "${target_dir}" "upgrade-manager" \
        "The skeleton-parallel framework files have just been installed into this ${detected_lang:-unknown} project. ${context_hint}

Your job:
1) READ .parallel-dev/upgrade-context.md (if present) to understand the actual project structure.
2) Adapt config/phases.yaml — replace generic phase placeholders with the actual phase names and dependencies found in the codebase. Use the 'Phase Candidates' and 'config/phases.yaml Suggestions' sections from the context report.
3) Adapt scripts/run_parallel.sh env vars — set DEFAULT_BRANCH, PR_LABEL, and any other vars to match the project's Git conventions from the context report.
4) Verify all installed files are correct (.github/skills, .github/agents, .github/prompts, copilot-instructions.md, run_parallel.sh, phases.yaml, docs/ templates).
5) Check that the project's existing code follows skeleton-parallel modular monolith standards (contracts/ for DTOs, database/ for adapter, app/modules/ or src/modules/ or internal/modules/ for domain modules).
6) Fix any structural violations — move files to correct locations, add missing boilerplate.
7) Validate that scripts/run_parallel.sh would run successfully end-to-end: correct branch names, valid phase config, working git remote, gh CLI available for PR creation.
8) Commit all adaptations with message 'chore: post-upgrade adaptation (context-aware)'.
9) Run 'skeleton doctor' to confirm all checks pass." \
        "upgrade-adaptation" || \
        log_warn "Post-upgrade agent skipped — agents not yet available in this context. Run 'skeleton doctor --dir=${target_dir}' after opening the project in VS Code."

    echo ""
    log_ok "Upgrade complete!"
    echo ""
    echo -e "  ${CYAN}Next steps:${NC}"
    echo -e "    skeleton doctor --dir=${target_dir}"
    echo -e "    # Review and customize .github/copilot-instructions.md"
    echo -e "    # Configure config/phases.yaml for your phases"
    echo ""
}

# ── Upgrade mode: Replace ─────────────────────────────────────────────────
# Remove existing mechanisms, install fresh from skeleton-parallel
_upgrade_replace() {
    local target_dir="$1"

    log_step "Mode: REPLACE — Installing fresh skeleton-parallel mechanisms..."

    # Remove existing and reinstall
    log_step "Upgrading .github/ (skills, agents, prompts, instructions)..."
    mkdir -p "${target_dir}/.github"

    # Force overwrite all .github components
    [[ -d "${target_dir}/.github/skills" ]] && rm -rf "${target_dir}/.github/skills"
    [[ -d "${target_dir}/.github/agents" ]] && rm -rf "${target_dir}/.github/agents"
    [[ -d "${target_dir}/.github/prompts" ]] && rm -rf "${target_dir}/.github/prompts"

    cp -R "${SKELETON_ROOT}/.github/skills" "${target_dir}/.github/"
    log_ok "Skills replaced ($(get_available_skills | wc -l | tr -d ' ') skills)"
    cp -R "${SKELETON_ROOT}/.github/agents" "${target_dir}/.github/"
    log_ok "Agents replaced ($(get_available_agents | wc -l | tr -d ' ') agents)"
    [[ -d "${SKELETON_ROOT}/.github/prompts" ]] && cp -R "${SKELETON_ROOT}/.github/prompts" "${target_dir}/.github/"
    log_ok "Prompts replaced"

    # Force overwrite copilot-instructions
    cp "${SKELETON_ROOT}/.github/copilot-instructions.md" "${target_dir}/.github/"
    log_ok "copilot-instructions.md replaced"

    # Scripts — force overwrite
    log_step "Replacing scripts/..."
    mkdir -p "${target_dir}/scripts"
    cp "${SKELETON_ROOT}/scripts/run_parallel.sh" "${target_dir}/scripts/"
    chmod +x "${target_dir}/scripts/run_parallel.sh"
    log_ok "run_parallel.sh replaced"

    # Config — force overwrite
    log_step "Replacing config/..."
    mkdir -p "${target_dir}/config"
    cp "${SKELETON_ROOT}/config/phases.yaml" "${target_dir}/config/"
    log_ok "phases.yaml replaced"

    # Docs — install all templates (overwrite existing)
    log_step "Replacing doc templates..."
    mkdir -p "${target_dir}/docs"
    local docs_installed=0
    for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
               dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
               AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
        if [[ -f "${SKELETON_ROOT}/docs/${doc}" ]]; then
            cp "${SKELETON_ROOT}/docs/${doc}" "${target_dir}/docs/"
            docs_installed=$(( docs_installed + 1 ))
        fi
    done
    log_ok "Installed ${docs_installed} doc templates"

    # Output directory
    mkdir -p "${target_dir}/output"
    [[ ! -f "${target_dir}/output/.gitignore" ]] && echo '*' > "${target_dir}/output/.gitignore"
}

# ── Upgrade mode: Hybrid ──────────────────────────────────────────────────
# Merge additively — add missing components, preserve existing custom files
_upgrade_hybrid() {
    local target_dir="$1"

    log_step "Mode: HYBRID — Merging additively (preserving custom files)..."

    # .github — always update skills and agents (these should be current)
    log_step "Upgrading .github/ (skills, agents, prompts)..."
    mkdir -p "${target_dir}/.github"

    if [[ -d "${SKELETON_ROOT}/.github/skills" ]]; then
        cp -R "${SKELETON_ROOT}/.github/skills" "${target_dir}/.github/"
        log_ok "Skills updated ($(get_available_skills | wc -l | tr -d ' ') skills)"
    fi
    if [[ -d "${SKELETON_ROOT}/.github/agents" ]]; then
        cp -R "${SKELETON_ROOT}/.github/agents" "${target_dir}/.github/"
        log_ok "Agents updated ($(get_available_agents | wc -l | tr -d ' ') agents)"
    fi
    if [[ -d "${SKELETON_ROOT}/.github/prompts" ]]; then
        cp -R "${SKELETON_ROOT}/.github/prompts" "${target_dir}/.github/"
        log_ok "Prompts updated"
    fi

    # Copilot instructions — preserve if exists
    if [[ ! -f "${target_dir}/.github/copilot-instructions.md" ]]; then
        cp "${SKELETON_ROOT}/.github/copilot-instructions.md" "${target_dir}/.github/"
        log_ok "copilot-instructions.md installed"
    else
        log_warn "copilot-instructions.md exists — preserved (use 'skeleton sync' to force update)"
    fi

    # Scripts — always update (executable, not customized)
    log_step "Upgrading scripts/..."
    mkdir -p "${target_dir}/scripts"
    cp "${SKELETON_ROOT}/scripts/run_parallel.sh" "${target_dir}/scripts/"
    chmod +x "${target_dir}/scripts/run_parallel.sh"
    log_ok "run_parallel.sh updated"

    # Config — preserve existing, add missing
    log_step "Upgrading config/..."
    mkdir -p "${target_dir}/config"
    if [[ ! -f "${target_dir}/config/phases.yaml" ]]; then
        cp "${SKELETON_ROOT}/config/phases.yaml" "${target_dir}/config/"
        log_ok "phases.yaml installed"
    else
        log_warn "phases.yaml exists — preserved"
    fi

    # Docs — only install missing
    log_step "Installing missing doc templates..."
    mkdir -p "${target_dir}/docs"
    local docs_installed=0
    for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
               dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
               AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
        if [[ ! -f "${target_dir}/docs/${doc}" ]] && [[ -f "${SKELETON_ROOT}/docs/${doc}" ]]; then
            cp "${SKELETON_ROOT}/docs/${doc}" "${target_dir}/docs/"
            log_ok "Installed docs/${doc}"
            docs_installed=$(( docs_installed + 1 ))
        fi
    done
    [[ ${docs_installed} -eq 0 ]] && log_warn "All doc templates already present — nothing to install"

    # Output directory
    mkdir -p "${target_dir}/output"
    [[ ! -f "${target_dir}/output/.gitignore" ]] && echo '*' > "${target_dir}/output/.gitignore"
}

# ── Upgrade mode: Skip ────────────────────────────────────────────────────
# Install only new components that don't exist yet
_upgrade_skip() {
    local target_dir="$1"

    log_step "Mode: SKIP — Installing only new components..."

    # .github — only add if directory doesn't exist
    mkdir -p "${target_dir}/.github"

    if [[ ! -d "${target_dir}/.github/skills" ]]; then
        cp -R "${SKELETON_ROOT}/.github/skills" "${target_dir}/.github/"
        log_ok "Skills installed (new)"
    else
        log_warn "Skills directory exists — skipped"
    fi
    if [[ ! -d "${target_dir}/.github/agents" ]]; then
        cp -R "${SKELETON_ROOT}/.github/agents" "${target_dir}/.github/"
        log_ok "Agents installed (new)"
    else
        log_warn "Agents directory exists — skipped"
    fi
    if [[ ! -d "${target_dir}/.github/prompts" ]]; then
        [[ -d "${SKELETON_ROOT}/.github/prompts" ]] && cp -R "${SKELETON_ROOT}/.github/prompts" "${target_dir}/.github/"
        log_ok "Prompts installed (new)"
    else
        log_warn "Prompts directory exists — skipped"
    fi

    if [[ ! -f "${target_dir}/.github/copilot-instructions.md" ]]; then
        cp "${SKELETON_ROOT}/.github/copilot-instructions.md" "${target_dir}/.github/"
        log_ok "copilot-instructions.md installed (new)"
    else
        log_warn "copilot-instructions.md exists — skipped"
    fi

    # Scripts — only if missing
    if [[ ! -f "${target_dir}/scripts/run_parallel.sh" ]]; then
        mkdir -p "${target_dir}/scripts"
        cp "${SKELETON_ROOT}/scripts/run_parallel.sh" "${target_dir}/scripts/"
        chmod +x "${target_dir}/scripts/run_parallel.sh"
        log_ok "run_parallel.sh installed (new)"
    else
        log_warn "run_parallel.sh exists — skipped"
    fi

    # Config — only if missing
    if [[ ! -f "${target_dir}/config/phases.yaml" ]]; then
        mkdir -p "${target_dir}/config"
        cp "${SKELETON_ROOT}/config/phases.yaml" "${target_dir}/config/"
        log_ok "phases.yaml installed (new)"
    else
        log_warn "phases.yaml exists — skipped"
    fi

    # Docs — only missing
    mkdir -p "${target_dir}/docs"
    local docs_installed=0
    for doc in architecture.md implementation_roadmap.md orchestrator_spec.md \
               dto_contracts.md db_adapter_spec.md PARALLEL_DEV.md \
               AGENTS_AND_SKILLS.md STARTER_GUIDE.md PROGRESS_REPORT.md; do
        if [[ ! -f "${target_dir}/docs/${doc}" ]] && [[ -f "${SKELETON_ROOT}/docs/${doc}" ]]; then
            cp "${SKELETON_ROOT}/docs/${doc}" "${target_dir}/docs/"
            log_ok "Installed docs/${doc}"
            docs_installed=$(( docs_installed + 1 ))
        fi
    done
    [[ ${docs_installed} -eq 0 ]] && log_warn "All doc templates already present — nothing to install"

    # Output directory
    mkdir -p "${target_dir}/output"
    [[ ! -f "${target_dir}/output/.gitignore" ]] && echo '*' > "${target_dir}/output/.gitignore"
}

_detect_language() {
    local dir="$1"
    if [[ -f "${dir}/go.mod" ]]; then echo "go"
    elif [[ -f "${dir}/pyproject.toml" ]] || [[ -f "${dir}/requirements.txt" ]] || [[ -f "${dir}/setup.py" ]]; then echo "python"
    elif [[ -f "${dir}/package.json" ]] && [[ -f "${dir}/tsconfig.json" ]]; then echo "typescript"
    elif [[ -f "${dir}/package.json" ]]; then echo "nodejs"
    elif [[ -f "${dir}/Cargo.toml" ]]; then echo "rust"
    elif [[ -f "${dir}/pom.xml" ]] || [[ -f "${dir}/build.gradle" ]]; then echo "java"
    else echo ""
    fi
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: doctor
# ═════════════════════════════════════════════════════════════════════════════
cmd_doctor() {
    local target_dir="."

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*) target_dir="${1#*=}"; shift ;;
            --dir)   target_dir="${2}"; shift 2 ;;
            --no-agent) SKIP_AGENT=true; shift ;;
            -*)      die "Unknown option: $1" ;;
            *)       target_dir="$1"; shift ;;
        esac
    done

    target_dir="$(cd "${target_dir}" 2>/dev/null && pwd)" || die "Directory not found: ${target_dir}"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton doctor                             ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    log_info "Checking: ${BOLD}${target_dir}${NC}"
    echo ""

    local issues=0
    local warnings=0

    _check_exists() {
        local path="$1" label="$2" severity="${3:-error}"
        if [[ -e "${target_dir}/${path}" ]]; then
            log_ok "${label}"
        elif [[ "${severity}" == "warn" ]]; then
            log_warn "${label} — MISSING (optional)"
            (( ++warnings ))
        elif [[ "${severity}" == "info" ]]; then
            log_info "${label} — not present"
        else
            log_error "${label} — MISSING"
            (( ++issues ))
        fi
        return 0
    }

    # ── Section 1: Identity & Runtime Config ──────────────────────────────
    log_step "Checking identity & runtime config..."

    if [[ -f "${target_dir}/.ai/manifest.yaml" ]]; then
        log_ok ".ai/manifest.yaml"
    else
        log_error ".ai/manifest.yaml — MISSING (run: ars init  or  skeleton integrate)"
        (( ++issues ))
    fi

    if [[ -f "${target_dir}/config/skeleton.yaml" ]]; then
        if bash -c "
            source '${SKELETON_ROOT}/scripts/lib/config.sh' 2>/dev/null
            SKELETON_DRIVER='' load_config '${target_dir}' 2>/dev/null" 2>/dev/null; then
            log_ok "config/skeleton.yaml"
        else
            log_error "config/skeleton.yaml — present but not loadable (run: skeleton integrate)"
            (( ++issues ))
        fi
    else
        log_error "config/skeleton.yaml — MISSING (run: skeleton integrate)"
        (( ++issues ))
    fi

    if [[ -f "${target_dir}/docs/PLAN.md" ]]; then
        log_ok "docs/PLAN.md"
    else
        log_error "docs/PLAN.md — MISSING (canonical work source)"
        (( ++issues ))
    fi

    # ── Section 2: Agentic Knowledge Plane ────────────────────────────────
    echo ""
    log_step "Checking agentic knowledge plane..."

    local agents_dir="" skills_dir="" knowledge_source=""
    if [[ -d "${target_dir}/.ai/agents" ]]; then
        agents_dir="${target_dir}/.ai/agents"
        knowledge_source=".ai"
    elif [[ -d "${target_dir}/.github/agents" ]]; then
        agents_dir="${target_dir}/.github/agents"
        knowledge_source=".github"
    fi
    if [[ -d "${target_dir}/.ai/skills" ]]; then
        skills_dir="${target_dir}/.ai/skills"
    elif [[ -d "${target_dir}/.github/skills" ]]; then
        skills_dir="${target_dir}/.github/skills"
    fi

    if [[ -n "${agents_dir}" ]]; then
        log_ok "Agents directory: ${agents_dir#${target_dir}/}"
    else
        log_error "No agents directory found (expected .ai/agents/ or .github/agents/)"
        (( ++issues ))
    fi
    if [[ -n "${skills_dir}" ]]; then
        log_ok "Skills directory: ${skills_dir#${target_dir}/}"
    else
        log_error "No skills directory found (expected .ai/skills/ or .github/skills/)"
        (( ++issues ))
    fi
    if [[ "${knowledge_source}" == ".github" ]]; then
        log_warn "Skills/agents live in .github/ (legacy) — run: ars compose to migrate to .ai/"
        (( ++warnings ))
    fi
    _check_exists ".github/prompts" ".github/prompts/ (prompts directory)" "warn"

    # ── Section 3: Pipeline Infrastructure ────────────────────────────────
    echo ""
    log_step "Checking pipeline infrastructure..."
    _check_exists "scripts/hooks/quality-gates.sh" "scripts/hooks/quality-gates.sh"
    if [[ -f "${target_dir}/scripts/run_parallel.sh" ]]; then
        log_info "scripts/run_parallel.sh present (deprecated shim — safe to keep)"
    fi

    # ── Section 4: Provider-Specific Harness ──────────────────────────────
    echo ""
    log_step "Checking provider harness..."

    local _drv="" _provider=""
    if [[ -f "${SKELETON_ROOT}/scripts/lib/config.sh" ]]; then
        local _cfg_out
        _cfg_out="$(bash -c "
            source '${SKELETON_ROOT}/scripts/lib/config.sh' 2>/dev/null
            load_config '${target_dir}' 2>/dev/null
            echo \"driver=\${SKELETON_DRIVER:-cli_subscription}\"
            echo \"provider=\${SKELETON_PROVIDER:-}\"" 2>/dev/null || true)"
        _drv="$(echo "${_cfg_out}"      | grep '^driver='   | cut -d= -f2)"
        _provider="$(echo "${_cfg_out}" | grep '^provider=' | cut -d= -f2)"
    fi
    _drv="${_drv:-cli_subscription}"
    # Infer provider from config/skeleton.yaml if not set via SKELETON_PROVIDER
    if [[ -z "${_provider}" ]] && [[ -f "${target_dir}/config/skeleton.yaml" ]]; then
        _provider="$(grep -E '^\s*provider\s*:' "${target_dir}/config/skeleton.yaml" \
            2>/dev/null | head -1 | sed 's/.*://;s/#.*//;s/[[:space:]]//g;s/"//g;s/'"'"'//g')"
    fi
    _provider="${_provider:-copilot}"

    log_info "driver=${_drv}  provider=${_provider}"

    case "${_provider}" in
        copilot)
            _check_exists ".github/copilot-instructions.md" \
                ".github/copilot-instructions.md (Copilot harness)" "warn"
            if command -v copilot &>/dev/null; then
                log_ok "copilot CLI found: $(command -v copilot)"
            else
                log_warn "copilot CLI — not found (optional; needed for driver=cli_subscription)"
                (( ++warnings ))
            fi
            ;;
        claude)
            _check_exists "CLAUDE.md" "CLAUDE.md (Claude Code harness)" "warn"
            if command -v claude &>/dev/null; then
                log_ok "claude CLI found: $(command -v claude)"
            else
                log_warn "claude CLI — not found"
                (( ++warnings ))
            fi
            ;;
        codex)
            _check_exists "AGENTS.md" "AGENTS.md (Codex harness)" "warn"
            if command -v codex &>/dev/null; then
                log_ok "codex CLI found: $(command -v codex)"
            else
                log_warn "codex CLI — not found"
                (( ++warnings ))
            fi
            ;;
        cursor)
            _check_exists ".cursor/rules" ".cursor/rules/ (Cursor harness)" "warn"
            ;;
        antigravity)
            _check_exists ".antigravity" ".antigravity/ (Antigravity harness)" "warn"
            ;;
        *)
            log_info "Provider '${_provider}' — no harness check defined"
            ;;
    esac

    case "${_drv}" in
        router_http)
            if command -v node &>/dev/null; then
                log_ok "Node.js $(node --version 2>/dev/null) (required for router_http / 9router)"
            else
                log_warn "Node.js — not found (needed for driver=router_http)"
                (( ++warnings ))
            fi
            ;;
        sdk_cursor)
            if command -v node &>/dev/null; then
                local _nv; _nv="$(node --version 2>/dev/null | sed 's/v//')"
                local _nmaj; _nmaj="$(echo "${_nv}" | cut -d. -f1)"
                if [[ "${_nmaj:-0}" -ge 22 ]]; then
                    log_ok "Node.js v${_nv} (≥22.13 satisfied for sdk_cursor)"
                else
                    log_error "Node.js v${_nv} — need ≥22.13 for driver=sdk_cursor"
                    (( ++issues ))
                fi
            else
                log_error "Node.js — NOT FOUND (required for driver=sdk_cursor)"
                (( ++issues ))
            fi
            if [[ -z "${CURSOR_API_KEY:-}" ]]; then
                log_error "CURSOR_API_KEY — not set (required for driver=sdk_cursor)"
                (( ++issues ))
            else
                log_ok "CURSOR_API_KEY set"
            fi
            ;;
    esac

    # ── Section 5: ARES Tooling ────────────────────────────────────────────
    echo ""
    log_step "Checking ARES tooling..."
    if command -v ars &>/dev/null; then
        log_ok "ars CLI found: $(command -v ars)"
    else
        log_warn "ars CLI — not found (install: https://github.com/okfriansyah-moh/ares)"
        (( ++warnings ))
    fi

    # ── Section 6: Skills & Agents Inventory ──────────────────────────────
    echo ""
    log_step "Checking skills inventory..."
    local core_skills=("dto" "pipeline" "modularity" "determinism" "idempotency"
                       "failure" "config-validation" "code-quality" "coding-standards"
                       "database-portability" "docs-sync" "conflict-resolution"
                       "token-optimization" "running-prompt" "security-audit"
                       "test-generation" "vertical-slice" "api-design"
                       "project-scaffold" "dependency-analysis" "migration-management"
                       "performance-optimization" "caveman" "brainstorming"
                       "plan-management" "subagent-driven-development"
                       "test-driven-development" "rtk")
    local skill_count=0
    local missing_skills=()
    for skill in "${core_skills[@]}"; do
        local _skill_found=false
        if [[ -n "${skills_dir}" ]]; then
            if [[ -f "${skills_dir}/${skill}/SKILL.md" ]] || \
               [[ -f "${skills_dir}/${skill}.md" ]]; then
                _skill_found=true
            fi
        fi
        if [[ "${_skill_found}" == "true" ]]; then
            skill_count=$(( skill_count + 1 ))
        else
            missing_skills+=("${skill}")
        fi
    done
    log_ok "Skills present: ${skill_count}/${#core_skills[@]}"
    if [[ ${#missing_skills[@]} -gt 0 ]]; then
        log_warn "Missing skills: ${missing_skills[*]}"
        (( ++warnings ))
    fi

    echo ""
    log_step "Checking agents inventory..."
    local core_agents=("phase-builder" "dto-guardian" "integration" "refactor"
                       "orchestrator" "module-builder" "conflict-resolver"
                       "merge-reviewer" "task-sync" "scaffold" "security-auditor"
                       "test-builder" "upgrade-manager" "doctor")
    local agent_count=0
    local missing_agents=()
    for agent in "${core_agents[@]}"; do
        local _agent_found=false
        if [[ -n "${agents_dir}" ]]; then
            if [[ -f "${agents_dir}/${agent}.agent.md" ]] || \
               [[ -f "${agents_dir}/${agent}.md" ]] || \
               [[ -d "${agents_dir}/${agent}" ]]; then
                _agent_found=true
            fi
        fi
        if [[ "${_agent_found}" == "true" ]]; then
            agent_count=$(( agent_count + 1 ))
        else
            missing_agents+=("${agent}")
        fi
    done
    log_ok "Agents present: ${agent_count}/${#core_agents[@]}"
    if [[ ${#missing_agents[@]} -gt 0 ]]; then
        log_warn "Missing agents: ${missing_agents[*]}"
        (( ++warnings ))
    fi

    # ── Section 7: Project Structure ──────────────────────────────────────
    echo ""
    log_step "Checking project structure..."
    local detected_lang
    detected_lang="$(_detect_language "${target_dir}")"
    if [[ -n "${detected_lang}" ]]; then
        log_ok "Language detected: ${detected_lang}"
        _check_lang_structure "${detected_lang}" "${target_dir}"
    else
        log_warn "Could not detect project language"
        (( ++warnings ))
    fi

    # ── Section 8: Doc Templates ───────────────────────────────────────────
    echo ""
    log_step "Checking documentation..."
    local doc_files=("architecture.md" "implementation_roadmap.md" "orchestrator_spec.md"
                     "dto_contracts.md" "db_adapter_spec.md")
    for doc in "${doc_files[@]}"; do
        _check_exists "docs/${doc}" "docs/${doc}" "warn"
    done

    # ── Section 9: Git Health ──────────────────────────────────────────────
    echo ""
    log_step "Checking Git setup..."
    if [[ -d "${target_dir}/.git" ]]; then
        log_ok "Git repository initialized"
    else
        log_warn "Not a Git repository"
        (( ++warnings ))
    fi

    # ── Summary ───────────────────────────────────────────────────────────
    echo ""
    echo -e "${BOLD}────────────────────────────────────────────────${NC}"
    if [[ ${issues} -eq 0 ]] && [[ ${warnings} -eq 0 ]]; then
        log_ok "${BOLD}All checks passed!${NC}"
    elif [[ ${issues} -eq 0 ]]; then
        log_ok "${BOLD}No critical issues. ${warnings} warning(s).${NC}"
    else
        log_error "${BOLD}${issues} issue(s), ${warnings} warning(s).${NC}"
    fi
    echo ""

    # ── Deep agent health check (Copilot only) ────────────────────────────
    if [[ "${_provider}" == "copilot" ]]; then
        if [[ ${issues} -gt 0 ]] || [[ ${warnings} -gt 0 ]]; then
            log_step "Spawning Copilot agent for deep health check and auto-fix..."
            _spawn_copilot_agent "${target_dir}" "doctor" \
                "Run a deep health check on this project. Found ${issues} issues and ${warnings} warnings. Validate and fix: 1) All module boundaries (no cross-module imports). 2) DTO contracts are immutable and properly defined in contracts/. 3) Database adapter is the sole DB access point (no raw SQL in modules). 4) All config is YAML-driven (no hardcoded values in code). 5) Tests are deterministic and network-free. 6) All missing skills, agents, or prompts should be installed. 7) Missing docs templates should be created from skeleton-parallel defaults. Fix all issues found. After fixing, commit with message 'chore: doctor auto-fix'." \
                "doctor-deep-check"
        else
            _spawn_copilot_agent_bg "${target_dir}" "doctor" \
                "All basic checks passed. Run a deep validation: 1) Verify module boundaries. 2) Check DTO immutability. 3) Validate database adapter isolation. 4) Check for hardcoded config values. 5) Ensure parallel dev readiness. Report findings in .parallel-dev/agent-logs/." \
                "doctor-bg-validation"
        fi
    fi

    return ${issues}
}

_check_lang_structure() {
    local lang="$1" dir="$2"

    case "${lang}" in
        go)
            _check_exists "cmd" "cmd/ (entry points)" "warn"
            _check_exists "internal/modules" "internal/modules/ (domain modules)" "warn"
            _check_exists "contracts" "contracts/ (DTO interfaces)" "warn"
            ;;
        python)
            _check_exists "app/main.py" "app/main.py (entry point)" "warn"
            _check_exists "app/modules" "app/modules/ (domain modules)" "warn"
            _check_exists "contracts" "contracts/ (DTOs)" "warn"
            _check_exists "database" "database/ (adapter)" "warn"
            ;;
        typescript)
            _check_exists "src" "src/ (source directory)" "warn"
            _check_exists "contracts" "contracts/ (DTOs)" "warn"
            ;;
        nodejs)
            _check_exists "src" "src/ (source directory)" "warn"
            _check_exists "src/modules" "src/modules/ (domain modules)" "warn"
            _check_exists "contracts" "contracts/ (DTOs)" "warn"
            _check_exists "database" "database/ (adapter)" "warn"
            ;;
        rust)
            _check_exists "src/main.rs" "src/main.rs (entry point)" "warn"
            _check_exists "src/modules" "src/modules/ (domain modules)" "warn"
            ;;
        java)
            _check_exists "src/main/java" "src/main/java/ (source)" "warn"
            ;;
    esac
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: add
# ═════════════════════════════════════════════════════════════════════════════
cmd_add() {
    local resource_type=""
    local resource_name=""
    local target_dir="."

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*) target_dir="${1#*=}"; shift ;;
            --dir)   target_dir="${2}"; shift 2 ;;
            --no-agent) SKIP_AGENT=true; shift ;;
            -*)      die "Unknown option: $1" ;;
            *)
                if [[ -z "${resource_type}" ]]; then
                    resource_type="$1"
                elif [[ -z "${resource_name}" ]]; then
                    resource_name="$1"
                fi
                shift
                ;;
        esac
    done

    target_dir="$(cd "${target_dir}" 2>/dev/null && pwd)" || die "Directory not found: ${target_dir}"

    case "${resource_type}" in
        skill)
            [[ -z "${resource_name}" ]] && die "Usage: skeleton add skill <name>"
            _add_skill "${resource_name}" "${target_dir}"
            # Background agent validates the newly added skill
            _spawn_copilot_agent_bg "${target_dir}" "doctor" \
                "Validate the newly installed skill '${resource_name}': 1) SKILL.md follows correct format (frontmatter with name, type, description + Purpose, Rules, Inputs, Outputs, Examples, Checklist sections). 2) Skill is referenced in relevant agent files that need it. 3) No conflicts with existing skills. Report findings in .parallel-dev/agent-logs/." \
                "add-skill-${resource_name}"
            ;;
        agent)
            [[ -z "${resource_name}" ]] && die "Usage: skeleton add agent <name>"
            _add_agent "${resource_name}" "${target_dir}"
            # Background agent validates the newly added agent
            _spawn_copilot_agent_bg "${target_dir}" "doctor" \
                "Validate the newly installed agent '${resource_name}': 1) Agent file follows correct format (description, skills, instructions). 2) All referenced skills exist in .github/skills/. 3) No conflicts with existing agents. Report findings in .parallel-dev/agent-logs/." \
                "add-agent-${resource_name}"
            ;;
        *)
            die "Usage: skeleton add <skill|agent> <name>"
            ;;
    esac
}

_add_skill() {
    local name="$1" dest="$2"
    local src="${SKELETON_ROOT}/.github/skills/${name}"

    if [[ ! -d "${src}" ]]; then
        die "Skill '${name}' not found.\nAvailable: $(get_available_skills | tr '\n' ' ')"
    fi

    # Install to .ai/skills/ — ARES canonical source
    mkdir -p "${dest}/.ai/skills"
    cp -R "${src}" "${dest}/.ai/skills/"
    log_ok "Skill '${name}' installed to ${dest}/.ai/skills/${name}/"
    log_info "  Run 'ars compose --target <provider>' to update your provider harness."
}

_add_agent() {
    local name="$1" dest="$2"
    local src="${SKELETON_ROOT}/.github/agents/${name}.agent.md"

    if [[ ! -f "${src}" ]]; then
        die "Agent '${name}' not found.\nAvailable: $(get_available_agents | tr '\n' ' ')"
    fi

    # Install to .ai/agents/ — ARES canonical source
    mkdir -p "${dest}/.ai/agents"
    cp "${src}" "${dest}/.ai/agents/"
    log_ok "Agent '${name}' installed to ${dest}/.ai/agents/${name}.agent.md"
    log_info "  Run 'ars compose --target <provider>' to update your provider harness."
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: list
# ═════════════════════════════════════════════════════════════════════════════
cmd_list() {
    local filter="${1:-all}"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton list                               ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""

    if [[ "${filter}" == "all" ]] || [[ "${filter}" == "templates" ]]; then
        echo -e "${BOLD}Templates:${NC}"
        for lang in "${SUPPORTED_LANGUAGES[@]}"; do
            if [[ -d "${TEMPLATES_DIR}/${lang}" ]]; then
                echo -e "  ${GREEN}●${NC} ${lang}"
            else
                echo -e "  ${RED}○${NC} ${lang} (not installed)"
            fi
        done
        echo ""
    fi

    if [[ "${filter}" == "all" ]] || [[ "${filter}" == "skills" ]]; then
        echo -e "${BOLD}Skills:${NC}"
        get_available_skills | while read -r skill; do
            local desc=""
            local skill_file="${SKELETON_ROOT}/.github/skills/${skill}/SKILL.md"
            if [[ -f "${skill_file}" ]]; then
                desc="$(grep -m1 '^description:' "${skill_file}" 2>/dev/null | sed 's/^description:[[:space:]]*//' | tr -d '"' || true)"
            fi
            echo -e "  ${GREEN}●${NC} ${skill}${desc:+ — ${desc}}"
        done
        echo ""
    fi

    if [[ "${filter}" == "all" ]] || [[ "${filter}" == "agents" ]]; then
        echo -e "${BOLD}Agents:${NC}"
        get_available_agents | while read -r agent; do
            local desc=""
            local agent_file="${SKELETON_ROOT}/.github/agents/${agent}.agent.md"
            if [[ -f "${agent_file}" ]]; then
                desc="$(grep -m1 '^description:' "${agent_file}" 2>/dev/null | sed 's/^description:[[:space:]]*//' | tr -d '"' || true)"
            fi
            echo -e "  ${GREEN}●${NC} ${agent}${desc:+ — ${desc}}"
        done
        echo ""
    fi
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: sync
# ═════════════════════════════════════════════════════════════════════════════
cmd_sync() {
    local target_dir="."

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*) target_dir="${1#*=}"; shift ;;
            --dir)   target_dir="${2}"; shift 2 ;;
            --no-agent) SKIP_AGENT=true; shift ;;
            -*)      die "Unknown option: $1" ;;
            *)       target_dir="$1"; shift ;;
        esac
    done

    target_dir="$(cd "${target_dir}" 2>/dev/null && pwd)" || die "Directory not found: ${target_dir}"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton sync                               ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    log_info "Syncing from: ${BOLD}${SKELETON_ROOT}${NC}"
    log_info "Target:       ${BOLD}${target_dir}${NC}"
    echo ""

    # Guard: ensure target_dir is set and non-empty
    [[ -z "${target_dir}" ]] && die "Target directory is empty — aborting sync"
    [[ ! -d "${target_dir}" ]] && die "Target directory does not exist: ${target_dir}"

    # ── Sync skills, agents, prompts → .ai/ (ARES canonical source) ──────────
    log_step "Syncing skills → .ai/skills/ (ARES canonical)..."
    if [[ -d "${SKELETON_ROOT}/.github/skills" ]]; then
        mkdir -p "${target_dir}/.ai/skills"
        cp -R "${SKELETON_ROOT}/.github/skills/." "${target_dir}/.ai/skills/"
        log_ok "Skills synced to .ai/skills/"
    fi

    log_step "Syncing agents → .ai/agents/ (ARES canonical)..."
    if [[ -d "${SKELETON_ROOT}/.github/agents" ]]; then
        mkdir -p "${target_dir}/.ai/agents"
        cp -R "${SKELETON_ROOT}/.github/agents/." "${target_dir}/.ai/agents/"
        log_ok "Agents synced to .ai/agents/"
    fi

    log_step "Syncing prompts → .ai/prompts/ (ARES canonical)..."
    if [[ -d "${SKELETON_ROOT}/.github/prompts" ]]; then
        mkdir -p "${target_dir}/.ai/prompts"
        cp -R "${SKELETON_ROOT}/.github/prompts/." "${target_dir}/.ai/prompts/"
        log_ok "Prompts synced to .ai/prompts/"
    fi

    log_step "Syncing run_parallel.sh..."
    mkdir -p "${target_dir}/scripts"
    if [[ -f "${SKELETON_ROOT}/scripts/run_parallel.sh" ]]; then
        cp "${SKELETON_ROOT}/scripts/run_parallel.sh" "${target_dir}/scripts/"
        chmod +x "${target_dir}/scripts/run_parallel.sh"
        log_ok "run_parallel.sh synced"
    fi

    echo ""
    log_ok "Knowledge synced to .ai/ — now composing provider harness via ARES..."
    echo ""

    # ── Compose provider harness (ARES owns this) ─────────────────────────────
    local _sync_provider; _sync_provider="$(_detect_provider_for_dir "${target_dir}")"
    if command -v ars &>/dev/null; then
        log_step "Running: ars compose --target ${_sync_provider}"
        ( cd "${target_dir}" && ars compose --target "${_sync_provider}" 2>&1 )             && log_ok "Provider harness composed via ars (target: ${_sync_provider})"             || log_warn "ars compose failed — run manually: ars compose --target ${_sync_provider}"
    else
        log_warn "ars CLI not found — it is required to compose the provider harness."
        log_info "  Install: curl -fsSL https://github.com/okfriansyah-moh/ares/releases/latest/download/install.sh | bash"
        echo ""
        local _install_ars=""
        # shellcheck disable=SC2162
        read -r -p "  Install ars now and compose the harness? [y/N] " _install_ars
        if [[ "${_install_ars}" =~ ^[Yy]$ ]]; then
            log_step "Installing ars..."
            if curl -fsSL https://github.com/okfriansyah-moh/ares/releases/latest/download/install.sh | bash; then
                log_ok "ars installed"
                ( cd "${target_dir}" && ars compose --target "${_sync_provider}" 2>&1 )                     && log_ok "Provider harness composed (target: ${_sync_provider})"                     || log_warn "ars compose failed — run manually: ars compose --target ${_sync_provider}"
            else
                log_error "ars installation failed — see https://github.com/okfriansyah-moh/ares"
            fi
        else
            log_info "Skipping ars install. Provider harness not composed."
            log_info "Run when ready: ars compose --target ${_sync_provider}"
        fi
    fi

    echo ""
    log_ok "Sync complete!"
    echo ""

    # Background validation (provider-aware)
    _spawn_agent_bg "${target_dir}" "doctor" \
        "Validate post-sync state: 1) .ai/skills/ and .ai/agents/ match upstream (${SKELETON_ROOT}). 2) Provider harness file is current (run 'ars compose' if stale). 3) run_parallel.sh is executable. 4) No custom configurations were accidentally overwritten. Report findings in .parallel-dev/agent-logs/." \
        "sync-validation"
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: autoskills
# ═════════════════════════════════════════════════════════════════════════════

# ── Helper: spawn agent to analyze target codebase and produce recommendations
# Writes to recommendations_file: one line per skill → name|action|reason
# action: install | merge
_autoskills_agent_analyze() {
    local target_dir="$1"
    local detected_lang="$2"
    local features_str="$3"
    local recommendations_file="$4"

    mkdir -p "$(dirname "${recommendations_file}")"
    rm -f "${recommendations_file}"

    # Ensure Explore agent exists in target project (copy from skeleton if missing)
    local explore_agent_dst="${target_dir}/.github/agents/Explore.agent.md"
    local explore_agent_src="${SKELETON_ROOT}/.github/agents/Explore.agent.md"
    if [[ ! -f "${explore_agent_dst}" ]] && [[ -f "${explore_agent_src}" ]]; then
        mkdir -p "${target_dir}/.github/agents"
        cp "${explore_agent_src}" "${explore_agent_dst}"
        log_info "Installed Explore agent to target project"
    fi

    local available_skills_list
    available_skills_list="$(get_available_skills)"

    _spawn_copilot_agent "${target_dir}" "Explore" \
        "Analyze this ${detected_lang:-unknown} project (detected features: ${features_str:-none}) and decide which skeleton-parallel skills to recommend installing.

AVAILABLE SKILLS TO EVALUATE (one per line):
${available_skills_list}

SKILL REFERENCE (name → what it does):
running-prompt: structured task execution workflow (planning, security review, verification)
brainstorming: design-first gate — present a design before any implementation
plan-management: convert approved design into bite-sized implementation tasks
subagent-driven-development: dispatch fresh subagent per task + 2-stage review
test-driven-development: RED-GREEN-REFACTOR cycle enforcement
code-quality: type annotations, structured logging, no anti-patterns
coding-standards: naming conventions, function design, language idioms
security-audit: OWASP Top 10 vulnerability detection and remediation
modularity: module boundary enforcement, no cross-module imports
dto: immutable DTO contracts, validation, producer/consumer mapping
determinism: same input + same config = identical output enforcement
idempotency: no duplicate writes, content-addressable IDs, ON CONFLICT
failure: retry policies, abort thresholds, graceful degradation
database-portability: engine-agnostic SQL, no driver leakage into modules
migration-management: safe append-only schema migrations
config-validation: YAML-driven parameters, no hardcoded values in code
test-generation: unit/integration test patterns, AAA structure, mocking
api-design: REST/gRPC endpoint patterns, error responses, versioning
vertical-slice: feature-per-folder self-contained architecture
pipeline: stage ordering, DTO flow, checkpoint dependencies
docs-sync: detect drift between documentation and code
dependency-analysis: import graph validation, coupling metrics
conflict-resolution: git merge conflict resolution for parallel branches
token-optimization: context loading optimization for agent prompts
performance-optimization: profiling, query optimization, throughput
rtk: token-efficient CLI proxy for terminal output compression
caveman: ultra-compressed output mode (~75% fewer tokens)
project-scaffold: project initialization and structure validation

INSTRUCTIONS:
1. Explore the project: read key source files, directory structure, existing .github/skills/ (if any)
2. For each skill above, decide one of:
   - install: skill is clearly beneficial and NOT yet present in .github/skills/
   - merge: skill ALREADY EXISTS in .github/skills/ but skeleton version adds missing value
   - skip: skill is irrelevant to this project's actual stack, patterns, or purpose
3. ONLY output install and merge decisions (skip means exclude)
4. Write results to: .parallel-dev/autoskills-recommendations.txt
5. Format — one line per skill, pipe-separated, NO extra whitespace:
   skill-name|action|specific reason citing actual files or patterns found
6. Example lines:
   security-audit|install|Found HTTP handlers in internal/web/server.go without input validation
   running-prompt|merge|Existing SKILL.md present but missing security-review phase
   database-portability|skip|No database access detected
7. Reason MUST be specific to what you actually found — do NOT use generic reasons
8. Do NOT modify any project files other than creating .parallel-dev/autoskills-recommendations.txt" \
        "autoskills-analysis"
}

# ── Helper: static skill mapping fallback (when no Copilot CLI)
# Prints lines: name|action|reason
_autoskills_static_map() {
    local detected_lang="$1"
    local target_dir="$2"
    shift 2
    local features=("$@")

    local -a skills
    skills=("running-prompt" "code-quality" "coding-standards" "security-audit"
            "token-optimization" "brainstorming" "plan-management" "subagent-driven-development")

    case "${detected_lang}" in
        go|python|rust)
            skills+=("modularity" "dto" "determinism" "idempotency" "failure"
                     "database-portability" "migration-management"
                     "config-validation" "test-generation" "test-driven-development") ;;
        typescript|nodejs)
            skills+=("modularity" "dto" "api-design" "vertical-slice"
                     "config-validation" "test-generation" "test-driven-development") ;;
        java)
            skills+=("modularity" "dto" "api-design" "database-portability"
                     "migration-management" "config-validation" "test-generation") ;;
        *)
            skills+=("modularity" "dto" "config-validation" "test-generation") ;;
    esac

    for feature in "${features[@]+"${features[@]}"}"; do
        case "${feature}" in
            database) skills+=("database-portability" "migration-management") ;;
            tests)    skills+=("test-generation" "test-driven-development") ;;
            api)      skills+=("api-design") ;;
            pipeline) skills+=("pipeline" "failure" "idempotency") ;;
        esac
    done
    skills+=("docs-sync" "dependency-analysis" "conflict-resolution")

    # Deduplicate and emit lines
    local -A seen
    for s in "${skills[@]}"; do
        if [[ -z "${seen[$s]+x}" ]]; then
            seen[$s]=1
            if [[ ! -d "${SKELETON_ROOT}/.github/skills/${s}" ]]; then
                continue  # not in skeleton, skip
            fi
            if [[ -f "${target_dir}/.github/skills/${s}/SKILL.md" ]]; then
                printf '%s|merge|Existing skill detected; skeleton version may add missing sections\n' "${s}"
            else
                printf '%s|install|Recommended for %s project\n' "${s}" "${detected_lang:-unknown}"
            fi
        fi
    done
}

# ── Helper: spawn agent to generate domain-specific custom skills
# Identifies patterns unique to the project's domain (e.g. payment, crypto, video),
# writes .github/skills/<name>/SKILL.md for each, and produces a manifest.
_autoskills_agent_plan_domain() {
    local target_dir="$1"
    local detected_lang="$2"
    local features_str="$3"
    local manifest_file="$4"

    mkdir -p "$(dirname "${manifest_file}")"
    rm -f "${manifest_file}"

    # Ensure Explore agent is present in target project
    local explore_agent_dst="${target_dir}/.github/agents/Explore.agent.md"
    local explore_agent_src="${SKELETON_ROOT}/.github/agents/Explore.agent.md"
    if [[ ! -f "${explore_agent_dst}" ]] && [[ -f "${explore_agent_src}" ]]; then
        mkdir -p "${target_dir}/.github/agents"
        cp "${explore_agent_src}" "${explore_agent_dst}"
    fi

    _spawn_copilot_agent "${target_dir}" "Explore" \
        "Analyze this ${detected_lang:-unknown} project (features: ${features_str:-none}) and IDENTIFY domain-specific skill areas for coding patterns UNIQUE to this project.

SKELETON SKILLS ALREADY AVAILABLE — do NOT plan skills that duplicate these domains:
dto, pipeline, modularity, determinism, idempotency, failure, config-validation, code-quality,
coding-standards, database-portability, docs-sync, conflict-resolution, token-optimization,
running-prompt, security-audit, test-generation, vertical-slice, api-design, project-scaffold,
dependency-analysis, migration-management, performance-optimization, caveman, brainstorming,
plan-management, subagent-driven-development, test-driven-development, rtk

INSTRUCTIONS:
1. Explore key source files to understand the project's business domain and unique technical patterns
2. Identify 3-7 domain-specific skill areas NOT covered by the skeleton skills above
   Examples of good domain skills:
   - Crypto/blockchain project  → 'crypto-key-management', 'blockchain-transaction-patterns'
   - Payment system             → 'payment-processing', 'pci-compliance-patterns'
   - Video pipeline             → 'ffmpeg-encoding-patterns', 'gpu-worker-patterns'
   - AI/ML project              → 'prompt-safety-patterns', 'model-inference-constraints'
   - Multi-tenant SaaS          → 'tenant-isolation-patterns', 'subscription-billing-rules'
   - Supabase project           → 'supabase-rls-patterns', 'supabase-migration-conventions'
3. Write ONLY the manifest file — do NOT create any .github/skills/ directories or SKILL.md files.
   The manifest will be reviewed by the user before any files are created.

MANIFEST FILE to write: ${manifest_file}
Format — one line per skill, pipe-separated, NO extra whitespace:
skill-name|one-sentence description of what it covers and why it is unique to this project
Example:
supabase-rls-patterns|Row-level security enforcement for multi-tenant Supabase queries
ffmpeg-encoding-patterns|FFmpeg subprocess constraints and output path safety rules

RULES:
- Plan 3-7 skills MAXIMUM — quality over quantity
- Every planned skill MUST be justified by actual files, functions, or patterns found in THIS codebase
- Do NOT plan generic skills that could apply to any project
- Do NOT duplicate any skeleton skill domain listed above
- Skill names: lowercase, hyphenated, domain-specific (e.g. 'crypto-key-management', not 'security')
- Do NOT write any files other than the manifest" \
        "autoskills-domain-planning"
}

_autoskills_agent_generate_domain() {
    local target_dir="$1"
    local detected_lang="$2"
    local features_str="$3"
    local manifest_file="$4"

    mkdir -p "${target_dir}/.github/skills"

    # Ensure Explore agent is present in target project
    local explore_agent_dst="${target_dir}/.github/agents/Explore.agent.md"
    local explore_agent_src="${SKELETON_ROOT}/.github/agents/Explore.agent.md"
    if [[ ! -f "${explore_agent_dst}" ]] && [[ -f "${explore_agent_src}" ]]; then
        mkdir -p "${target_dir}/.github/agents"
        cp "${explore_agent_src}" "${explore_agent_dst}"
    fi

    # Read planned skill names from the manifest to guide generation
    local planned_skills=""
    if [[ -f "${manifest_file}" ]]; then
        planned_skills="$(awk -F'|' '{print $1}' "${manifest_file}" | tr '\n' ',' | sed 's/,$//') "
    fi

    _spawn_copilot_agent "${target_dir}" "Explore" \
        "Generate domain-specific SKILL.md files for this ${detected_lang:-unknown} project (features: ${features_str:-none}).

The user has already approved generating these domain skills: ${planned_skills:-see manifest at ${manifest_file}}

SKELETON SKILLS ALREADY INSTALLED — do NOT generate skills that duplicate these domains:
dto, pipeline, modularity, determinism, idempotency, failure, config-validation, code-quality,
coding-standards, database-portability, docs-sync, conflict-resolution, token-optimization,
running-prompt, security-audit, test-generation, vertical-slice, api-design, project-scaffold,
dependency-analysis, migration-management, performance-optimization, caveman, brainstorming,
plan-management, subagent-driven-development, test-driven-development, rtk

INSTRUCTIONS:
1. If a manifest exists at ${manifest_file}, generate ONLY the skills listed there
2. For each domain skill, create .github/skills/<skill-name>/SKILL.md using this EXACT format:

---
name: <skill-name>
type: skill
description: \"<one-line description of what this skill enforces>\"
---

## Purpose

[What this skill enforces and why it exists in THIS project — reference actual files]

## Rules

[5-10 specific, actionable rules derived from patterns found in THIS codebase.
 Reference specific files, functions, or line numbers you observed.]

## Anti-Patterns

[3-5 things to NEVER do in this domain, with examples from THIS codebase]

## Checklist

\`\`\`
[ ] Specific rule 1
[ ] Specific rule 2
...\`\`\`

RULES:
- Generate 3-7 skills MAXIMUM — quality over quantity
- Every rule MUST reference actual files, functions, or patterns found in THIS codebase
- Do NOT generate generic skills that could apply to any project
- Do NOT duplicate any skeleton skill domain listed above
- Skill names: lowercase, hyphenated, domain-specific (e.g. 'crypto-key-management', not 'security')
- Do NOT modify any project source files — only write to .github/skills/" \
        "autoskills-domain-generation"
}

# ── Helper: install a skill fresh from skeleton
_autoskills_install_skill() {
    local skill="$1"
    local target_dir="$2"
    local src="${SKELETON_ROOT}/.github/skills/${skill}"
    local dst="${target_dir}/.github/skills/${skill}"

    if [[ ! -d "${src}" ]]; then
        log_warn "Skill not in skeleton: ${skill} — skipped"
        return 1
    fi
    mkdir -p "${dst}"
    cp -r "${src}/." "${dst}/"
    log_ok "Installed: ${BOLD}${skill}${NC}"
}

# ── Helper: merge an existing skill with skeleton version
# Backs up existing, installs skeleton version, queues background merge agent
_autoskills_merge_skill() {
    local skill="$1"
    local target_dir="$2"
    local src="${SKELETON_ROOT}/.github/skills/${skill}"
    local dst="${target_dir}/.github/skills/${skill}"
    local bak="${target_dir}/.github/skills/${skill}.bak"

    if [[ ! -d "${src}" ]]; then
        log_warn "Skill not in skeleton: ${skill} — skipped"
        return 1
    fi

    # Backup existing
    if [[ -d "${dst}" ]]; then
        rm -rf "${bak}"
        mkdir -p "${bak}"
        cp -r "${dst}/." "${bak}/"
    fi

    # Install skeleton version as base
    mkdir -p "${dst}"
    cp -r "${src}/." "${dst}/"

    # Try agent merge (background)
    if _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]]; then
        local log_dir="${target_dir}/${COPILOT_LOG_DIR}"
        mkdir -p "${log_dir}"
        local merge_log="${log_dir}/merge-${skill}-$(date +%Y%m%d-%H%M%S).log"
        (
            cd "${target_dir}"
            copilot \
                -p "Merge two versions of the '${skill}' skill SKILL.md. ORIGINAL (custom, from previous install): .github/skills/${skill}.bak/SKILL.md. NEW (skeleton-parallel base): .github/skills/${skill}/SKILL.md. MERGE RULES: 1) Use NEW as the base document. 2) For any ## section that exists in ORIGINAL but NOT in NEW, append it at the end of .github/skills/${skill}/SKILL.md. 3) For any ## section that exists in BOTH, keep the NEW version but append any unique bullet points from ORIGINAL under a '### Custom Additions' subsection. 4) After writing the merged SKILL.md, delete .github/skills/${skill}.bak/. 5) Do NOT modify any other files." \
                --agent="Explore" \
                --model="${COPILOT_MODEL}" \
                --no-ask-user \
                --allow-all-tools \
                --autopilot \
                &>"${merge_log}"
            rm -rf "${target_dir}/.github/skills/${skill}.bak" 2>/dev/null || true
        ) &
        log_ok "Merged: ${BOLD}${skill}${NC} ${YELLOW}(background merge agent queued)${NC}"
    else
        # No agent — simple structural merge: append unique ## sections from backup
        if [[ -f "${bak}/SKILL.md" ]] && [[ -f "${dst}/SKILL.md" ]]; then
            local in_section=false
            local section_buf=""
            local current_header=""
            while IFS= read -r line; do
                if [[ "${line}" =~ ^##[[:space:]] ]]; then
                    # Flush previous section if header not in new version
                    if [[ -n "${current_header}" ]] && ! grep -qF "${current_header}" "${dst}/SKILL.md"; then
                        printf '\n<!-- Preserved from previous installation -->\n%s\n%s\n' \
                            "${current_header}" "${section_buf}" >> "${dst}/SKILL.md"
                    fi
                    current_header="${line}"
                    section_buf=""
                else
                    [[ -n "${current_header}" ]] && section_buf+="${line}"$'\n'
                fi
            done < "${bak}/SKILL.md"
            # Flush last section
            if [[ -n "${current_header}" ]] && ! grep -qF "${current_header}" "${dst}/SKILL.md"; then
                printf '\n<!-- Preserved from previous installation -->\n%s\n%s\n' \
                    "${current_header}" "${section_buf}" >> "${dst}/SKILL.md"
            fi
        fi
        rm -rf "${bak}" 2>/dev/null || true
        log_ok "Merged: ${BOLD}${skill}${NC} (custom sections preserved)"
    fi
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: auth
# ═════════════════════════════════════════════════════════════════════════════
# Pre-flight check: verify the configured AI provider CLI is installed and
# authenticated before running skeleton init, run, or any agent-spawning command.
#
# Usage: skeleton auth [--dir=DIR] [--provider=PROVIDER]
#
# If --provider is omitted, reads provider from config/skeleton.yaml in DIR.
# ═════════════════════════════════════════════════════════════════════════════
cmd_auth() {
    local _dir="." _provider=""

    for arg in "$@"; do
        case "${arg}" in
            --dir=*)      _dir="${arg#--dir=}" ;;
            --provider=*) _provider="${arg#--provider=}" ;;
            -h|--help)
                echo "Usage: skeleton auth [--dir=DIR] [--provider=PROVIDER]"
                echo ""
                echo "Verify agent provider auth before running skeleton commands."
                echo "If no --provider, reads config/skeleton.yaml in DIR."
                echo ""
                echo "Providers: claude | copilot | codex | router_http (alias: 9router | router)"
                return 0 ;;
        esac
    done

    [[ -z "${_provider}" ]] && _provider="$(_detect_provider_for_dir "${_dir}")"

    # Normalise 9router / router → router_http
    case "${_provider}" in
        9router|router) _provider="router_http" ;;
    esac

    log_info "Auth check — provider: ${BOLD}${_provider}${NC}"
    echo ""

    local _ok=true

    case "${_provider}" in
        claude)
            if ! command -v claude &>/dev/null; then
                log_error "claude CLI not found."
                echo ""
                echo "  Install Claude Code:"
                echo "    https://claude.ai/code"
                echo "    or: npm install -g @anthropic-ai/claude-code"
                _ok=false
            else
                log_ok "claude CLI: $(command -v claude)"
                if claude auth status &>/dev/null 2>&1; then
                    log_ok "claude: authenticated"
                else
                    log_warn "claude: not authenticated (or check not supported by this version)"
                    echo ""
                    echo "  Run: claude auth login"
                fi
            fi
            ;;
        copilot)
            if ! command -v copilot &>/dev/null; then
                log_error "copilot CLI not found."
                echo ""
                echo "  Install GitHub Copilot CLI:"
                echo "    npm install -g @githubnext/github-copilot-cli"
                echo "    or: gh extension install github/gh-copilot"
                _ok=false
            else
                log_ok "copilot CLI: $(command -v copilot)"
                if command -v gh &>/dev/null; then
                    if gh auth status &>/dev/null 2>&1; then
                        log_ok "gh: authenticated"
                    else
                        log_warn "gh: not authenticated"
                        echo ""
                        echo "  Run: gh auth login"
                    fi
                else
                    log_warn "gh CLI not found — Copilot auth requires GitHub CLI"
                    echo "  Install: https://cli.github.com"
                fi
            fi
            ;;
        codex)
            if ! command -v codex &>/dev/null; then
                log_error "codex CLI not found."
                echo ""
                echo "  Install Codex CLI:"
                echo "    npm install -g @openai/codex"
                _ok=false
            else
                log_ok "codex CLI: $(command -v codex)"
                if [[ -n "${OPENAI_API_KEY:-}" ]]; then
                    log_ok "OPENAI_API_KEY: set"
                else
                    log_warn "OPENAI_API_KEY: not set"
                    echo ""
                    echo "  Export your key before running skeleton commands:"
                    echo "    export OPENAI_API_KEY=sk-..."
                fi
            fi
            ;;
        router_http)
            log_info "Checking 9router daemon at localhost:20128..."
            if curl -sf "http://localhost:20128/api/health" &>/dev/null 2>&1; then
                log_ok "9router: running"
            else
                log_error "9router: not responding at localhost:20128"
                echo ""
                echo "  Start 9router:"
                echo "    skeleton router install   # first time only (requires Node 22.13+)"
                echo "    skeleton router start"
                echo "    skeleton router status"
                _ok=false
            fi
            local _inject="${_dir}/router/inject-env.sh"
            if [[ -f "${_inject}" ]]; then
                log_ok "inject-env.sh: found (${_inject})"
            else
                log_warn "inject-env.sh: not found at ${_inject}"
                echo ""
                echo "  After starting 9router, open http://localhost:20128 → Connections"
                echo "  → add Claude → copy the token, then create ${_inject}:"
                echo "    export ANTHROPIC_BASE_URL=\"http://localhost:20128/v1\""
                echo "    export ANTHROPIC_API_KEY=\"<token>\""
                echo "    chmod 600 ${_inject}"
                echo ""
                echo "  Tip: if your project is elsewhere, use:"
                echo "    skeleton auth --provider=9router --dir=/path/to/your-project"
            fi
            ;;
        *)
            log_warn "Unknown provider '${_provider}' — no auth check implemented"
            ;;
    esac

    echo ""
    if [[ "${_ok}" == "true" ]]; then
        log_ok "Auth check passed. Ready to run skeleton commands."
    else
        log_error "Auth check failed. Fix the issues above before running 'skeleton init'."
        return 1
    fi
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: plan
# ═════════════════════════════════════════════════════════════════════════════
# Bridge between a2a-brainstorm (design phase) and skeleton run (execution).
#
# Two modes:
#   --from=PATH    Import an a2a-brainstorm plan.md and enrich it into
#                  skeleton's execution format (task IDs, deps, file ownership,
#                  acceptance criteria checkboxes). Recommended — a2a produces
#                  higher-quality design context than a single generate pass.
#
#   --source=PATH  Generate docs/PLAN.md from scratch using an architecture doc
#                  when no a2a session was run.
#
# Both modes write docs/PLAN.md, validate with bash -n, and print next steps.
cmd_plan() {
    local target_dir="."
    local a2a_plan=""
    local source_doc=""
    local output_doc="docs/PLAN.md"
    local dry_run=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*)    target_dir="${1#*=}"; shift ;;
            --dir)      target_dir="${2}"; shift 2 ;;
            --from=*)   a2a_plan="${1#*=}"; shift ;;
            --from)     a2a_plan="${2}"; shift 2 ;;
            --source=*) source_doc="${1#*=}"; shift ;;
            --source)   source_doc="${2}"; shift 2 ;;
            --output=*) output_doc="${1#*=}"; shift ;;
            --output)   output_doc="${2}"; shift 2 ;;
            --dry-run)  dry_run=true; shift ;;
            --no-agent) SKIP_AGENT=true; shift ;;
            -*)         die "Unknown option: $1" ;;
            *)          break ;;
        esac
    done

    target_dir="$(cd "${target_dir}" && pwd)"
    local output_path="${target_dir}/${output_doc}"

    # ── Guard: can't use both modes at once ──────────────────────────────────
    if [[ -n "${a2a_plan}" && -n "${source_doc}" ]]; then
        die "Use either --from or --source, not both."
    fi

    # ── Mode detection ────────────────────────────────────────────────────────
    local _mode=""
    if [[ -n "${a2a_plan}" ]]; then
        _mode="a2a-import"
    elif [[ -n "${source_doc}" ]]; then
        _mode="generate"
    else
        # Auto-detect: prefer a2a plan if present
        for _candidate in "docs/plan.md" "plan.md" "docs/a2a-plan.md"; do
            if [[ -f "${target_dir}/${_candidate}" ]]; then
                a2a_plan="${_candidate}"
                _mode="a2a-import"
                break
            fi
        done
        # Fall back to architecture doc
        if [[ -z "${_mode}" ]]; then
            for _candidate in "docs/architecture.md" "docs/ARCHITECTURE.md" \
                              "docs/spec.md" "docs/requirements.md" \
                              "docs/implementation_roadmap.md" "ARCHITECTURE.md"; do
                if [[ -f "${target_dir}/${_candidate}" ]]; then
                    source_doc="${_candidate}"
                    _mode="generate"
                    break
                fi
            done
        fi
        if [[ -z "${_mode}" ]]; then
            die "No a2a plan or architecture doc found.\n  Run 'a2a-brainstorm' to design first, then:\n    skeleton plan --from=path/to/plan.md\n  Or generate from an architecture doc:\n    skeleton plan --source=docs/architecture.md"
        fi
    fi

    # ── Guard: existing PLAN.md ──────────────────────────────────────────────
    if [[ -f "${output_path}" && "${dry_run}" != "true" ]]; then
        local _overwrite=""
        log_warn "${output_doc} already exists."
        read -r -p "  Overwrite? [y/N] " _overwrite
        [[ ! "${_overwrite}" =~ ^[Yy]$ ]] && { log_info "Aborted."; return 0; }
    fi

    # ── Mode: a2a-import ──────────────────────────────────────────────────────
    if [[ "${_mode}" == "a2a-import" ]]; then
        local a2a_path="${target_dir}/${a2a_plan}"
        [[ ! -f "${a2a_path}" ]] && die "a2a plan not found: ${a2a_path}"

        log_step "Importing a2a-brainstorm plan: ${BOLD}${a2a_plan}${NC}"
        log_info "  Enriching for skeleton execution format..."
        log_info "  Output: ${output_doc}"

        if [[ "${dry_run}" == "true" ]]; then
            log_info "  [dry-run] Would enrich ${a2a_plan} → ${output_doc}"
            log_info "  [dry-run] Adds: T-001 IDs, Depends:, Files: paths, Acceptance: checkboxes"
            return 0
        fi

        local _a2a_content
        _a2a_content="$(cat "${a2a_path}")"

        local _prompt
        _prompt="You are a senior engineering lead bridging the gap between architecture design and implementation execution.

The following PLAN.md was generated by a2a-brainstorm (a multi-agent architecture design tool). It contains rich architectural context, goal statements, tech stack, project structure, and task definitions. Your job is to reformat it into skeleton-parallel's execution format so the agentic loop CLI can run it directly.

=== a2a-brainstorm PLAN.md ===
${_a2a_content}
=== END ===

REFORMAT RULES:
1. Keep ALL content — Goal, Architecture Overview, Tech Stack, Project Structure sections stay as-is.
2. For every task/phase, add these fields in this exact order:
   **ID:** T-001 (sequential, T-001 format)
   **Depends:** T-XXX or none (based on the order/dependency in the original plan)
   **Estimated:** S, M, or L (based on task complexity)
   **Files:**
     - \`actual/path/from/structure.py\` — what this file does
     - \`tests/test_file.py\` — unit tests for this component
   **Acceptance:**
     - [ ] Specific functional criterion (not generic)
     - [ ] Integration criterion
     - [ ] Tests pass
3. Extract file paths from 'Files to create:', '**Files:**', or the project structure section.
4. Convert 'Validation:' / 'Acceptance:' bullet points into checkbox format (- [ ]).
5. Keep the task name, goal, and all implementation notes — enrich, don't truncate.
6. The first task must have Depends: none.
7. Task IDs are strictly sequential: T-001, T-002, T-003…

QUALITY BAR (skeleton-parallel's plan_parser.py requirements):
- Every task has ID, Depends, Files, and Acceptance sections.
- Every acceptance criterion is specific and verifiable (not 'works correctly').
- File paths are concrete (no 'path/to/file.py' placeholders — use real paths from the structure).

Output ONLY the PLAN.md content starting with '# PLAN.md' — no preamble, no explanation."

        _plan_spawn_agent "${target_dir}" "${_prompt}" "${output_path}"
        return $?
    fi

    # ── Mode: generate ────────────────────────────────────────────────────────
    local source_path="${target_dir}/${source_doc}"
    [[ ! -f "${source_path}" ]] && die "Architecture doc not found: ${source_path}"

    log_step "Generating PLAN.md from: ${BOLD}${source_doc}${NC}"
    log_info "  (Tip: run 'a2a-brainstorm' first for higher-quality plans)"
    log_info "  Output: ${output_doc}"

    if [[ "${dry_run}" == "true" ]]; then
        log_info "  [dry-run] Would spawn plan-management agent on ${source_doc}"
        log_info "  [dry-run] Would write: ${output_path}"
        return 0
    fi

    local _source_content
    _source_content="$(cat "${source_path}")"

    # Include sibling docs for context
    local _context_block=""
    for _doc in "${target_dir}/docs/"*.md; do
        [[ -f "${_doc}" && "${_doc}" != "${source_path}" ]] || continue
        _context_block+="
=== $(basename "${_doc}") (first 80 lines) ===
$(head -80 "${_doc}" 2>/dev/null)
"
    done

    local _prompt
    _prompt="You are a senior software architect. Read the architecture document and generate a complete, execution-ready docs/PLAN.md that skeleton-parallel's agentic loop CLI can run directly.

=== PRIMARY DOCUMENT: ${source_doc} ===
${_source_content}
${_context_block}

GENERATE A PLAN.md with this structure:

# PLAN.md — [Project Name] Implementation Plan

> **Status:** Ready for Implementation
> **Source:** ${source_doc}

## 1. Goal
[One concise paragraph: what the system does, why it exists, its scope boundary]

## 2. Architecture Overview
[2-3 sentence summary: language, key modules, data flow, deployment shape]

## 3. Tech Stack
\`\`\`
[key choices as a code block: language version, storage, key libraries, external APIs]
\`\`\`

## 4. Project Structure
\`\`\`
[directory tree from the architecture doc]
\`\`\`

## 5. Tasks

### Task 1: [Name from first Build Phase / module]
**ID:** T-001
**Depends:** none
**Estimated:** S|M|L
**Files:**
  - \`path/to/file.py\` — [specific purpose]
  - \`tests/test_file.py\` — unit tests
**Acceptance:**
  - [ ] [Specific functional criterion]
  - [ ] [Integration or data criterion]
  - [ ] Tests pass (pytest/equivalent)
  - [ ] No import errors

### Task 2: [Next phase]
**ID:** T-002
**Depends:** T-001
...

RULES:
1. Map each numbered Build Phase in the doc to one Task (split large phases into 2 tasks max).
2. First task: Depends: none. All others: Depends: T-XXX based on phase order.
3. Files: use REAL paths from the directory structure in the doc — no placeholders.
4. Acceptance: minimum 3 criteria, all specific and verifiable.
5. Output ONLY the PLAN.md content starting with '# PLAN.md'.
6. Tip: run a2a-brainstorm first for richer architectural context — this is a single-agent generation."

    _plan_spawn_agent "${target_dir}" "${_prompt}" "${output_path}"
    return $?
}

# ── _plan_spawn_agent ─────────────────────────────────────────────────────────
# Internal: spawn agent with given prompt, capture output to output_path.
# Used by both modes of cmd_plan.
_plan_spawn_agent() {
    local _work_dir="$1"
    local _prompt="$2"
    local _output_path="$3"

    if [[ "${SKIP_AGENT:-false}" == "true" ]]; then
        log_warn "--no-agent set: cannot generate without an agent."
        log_info "  Write ${_output_path} manually from the Build Phases in your architecture doc."
        return 1
    fi

    local _provider; _provider="$(_detect_provider_for_dir "${_work_dir}")"
    _require_agent_cli "${_provider}"

    local _agent_out; _agent_out="$(mktemp)"
    mkdir -p "$(dirname "${_output_path}")"

    log_step "Spawning plan-management agent (provider: ${_provider}, model: ${AGENT_MODEL})..."

    case "${_provider}" in
        claude)
            ( cd "${_work_dir}"
              unset ANTHROPIC_BASE_URL   # use claude CLI's own OAuth directly, not 9router
              claude -p "${_prompt}" \
                  --model="${AGENT_MODEL}" \
                  --allowedTools none \
                  2>&1
            ) > "${_agent_out}" || true
            ;;
        copilot)
            ( cd "${_work_dir}"
              copilot -p "${_prompt}" \
                  --agent=task-runner \
                  --model="${AGENT_MODEL}" \
                  --no-ask-user \
                  --allow-all-tools \
                  --autopilot \
                  2>/dev/null
            ) > "${_agent_out}" || true
            ;;
        codex)
            ( cd "${_work_dir}"
              if codex --help 2>&1 | grep -q -- '-p'; then
                  codex -a auto -m "${AGENT_MODEL}" -p "${_prompt}" 2>/dev/null
              else
                  printf '%s' "${_prompt}" | codex -a auto -m "${AGENT_MODEL}" 2>/dev/null
              fi
            ) > "${_agent_out}" || true
            ;;
        *)
            log_warn "Provider '${_provider}' — plan agent not implemented."
            log_info "  Switch provider in config/skeleton.yaml to claude, copilot, or codex."
            rm -f "${_agent_out}"
            return 1
            ;;
    esac

    if [[ ! -s "${_agent_out}" ]]; then
        rm -f "${_agent_out}"
        log_error "Agent produced no output."
        log_info "  Verify AGENT_MODEL is valid and provider CLI is authenticated."
        return 1
    fi

    # Reject output that is just a CLI error (no plan content found)
    if grep -qi "there's an issue with the selected model\|unknown model\|error:\|Rate limit" "${_agent_out}" 2>/dev/null \
        && ! grep -q "^# PLAN" "${_agent_out}" 2>/dev/null; then
        log_error "Agent returned an error instead of a plan:"
        head -3 "${_agent_out}" >&2
        rm -f "${_agent_out}"
        log_info "  Fix: check AGENT_MODEL is correct (e.g. claude-sonnet-4-6) and 9router is running."
        return 1
    fi

    # Extract PLAN.md content: strip any agent preamble before "# PLAN"
    if grep -q "^# PLAN" "${_agent_out}" 2>/dev/null; then
        awk '/^# PLAN/,0' "${_agent_out}" > "${_output_path}"
    else
        cp "${_agent_out}" "${_output_path}"
    fi
    rm -f "${_agent_out}"

    local _task_count
    _task_count="$(grep -c "^\*\*ID:\*\*\|^### Task" "${_output_path}" 2>/dev/null || echo 0)"
    log_ok "PLAN.md written: ${_output_path} (${_task_count} tasks)"
    printf '\n'
    log_info "  ${BOLD}Review${NC} ${_output_path} — verify task names, deps, file paths"
    log_info "  ${BOLD}skeleton doctor${NC} — validate project health"
    log_info "  ${BOLD}skeleton run --dry-run${NC} — preview execution plan"
    log_info "  ${BOLD}skeleton run --full${NC} — execute all tasks end-to-end"
    printf '\n'
}


cmd_autoskills() {
    local target_dir="."
    local dry_run=false
    local auto_yes=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dir=*)    target_dir="${1#*=}"; shift ;;
            --dir)      target_dir="${2}"; shift 2 ;;
            --dry-run)  dry_run=true; shift ;;
            --no-agent) SKIP_AGENT=true; shift ;;
            -y)         auto_yes=true; shift ;;
            -*)         die "Unknown option: $1" ;;
            *)          target_dir="$1"; shift ;;
        esac
    done

    target_dir="$(cd "${target_dir}" 2>/dev/null && pwd)" || die "Directory not found: ${target_dir}"

    echo ""
    echo -e "${BOLD}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}║  skeleton autoskills                         ║${NC}"
    echo -e "${BOLD}╚══════════════════════════════════════════════╝${NC}"
    echo ""
    log_info "Scanning: ${BOLD}${target_dir}${NC}"
    echo ""

    # ── Step 1: Language + feature detection ─────────────────────────────
    local detected_lang
    detected_lang="$(_detect_language "${target_dir}")"
    log_step "Detected language: ${detected_lang:-unknown}"

    local features=()

    if find "${target_dir}" -maxdepth 4 -name '*.sql' -not -path '*/.*' 2>/dev/null | grep -q .; then
        features+=("database")
    elif [[ -d "${target_dir}/database/migrations" ]] || [[ -d "${target_dir}/migrations" ]]; then
        features+=("database")
    fi

    local test_patterns=('*_test.go' 'test_*.py' '*_test.py' '*_test.ts' '*_test.js' '*_test.rs' '*Test.java')
    for pat in "${test_patterns[@]}"; do
        if find "${target_dir}" -maxdepth 6 -name "${pat}" -not -path '*/.*' 2>/dev/null | grep -q .; then
            features+=("tests"); break
        fi
    done

    if [[ -f "${target_dir}/Dockerfile" ]] || [[ -f "${target_dir}/docker-compose.yml" ]]; then
        features+=("docker")
    fi

    if find "${target_dir}" -maxdepth 3 \( -name 'openapi.yaml' -o -name 'openapi.json' -o -name '*.proto' \) 2>/dev/null | grep -q .; then
        features+=("api")
    fi

    if [[ -f "${target_dir}/docs/architecture.md" ]]; then
        features+=("pipeline")
    fi

    if [[ ${#features[@]} -gt 0 ]]; then
        log_ok "Detected features: ${features[*]}"
    else
        log_info "No special features detected"
    fi
    echo ""

    # ── Step 2: Agent analysis ────────────────────────────────────────────
    local recommendations_file="${target_dir}/.parallel-dev/autoskills-recommendations.txt"
    local domain_manifest="${target_dir}/.parallel-dev/domain-skills-manifest.txt"
    local -a rec_names=() rec_actions=() rec_reasons=()
    local -a domain_names=() domain_reasons=()
    local features_str="${features[*]+"${features[*]}"}"

    if _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]]; then
        log_step "Spawning agent to read and understand the codebase..."
        log_info "The agent will explore the project and recommend only skills that fit."
        echo ""
        _autoskills_agent_analyze "${target_dir}" "${detected_lang}" "${features_str}" "${recommendations_file}" || true
    fi

    # ── Step 2b: Domain-specific skill planning (manifest only — no files written yet) ──
    if _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]] && [[ "${dry_run}" != "true" ]]; then
        log_step "Spawning agent to identify domain-specific skills..."
        log_info "The agent will explore the project and plan custom skills — no files created until you confirm."
        echo ""
        _autoskills_agent_plan_domain "${target_dir}" "${detected_lang}" "${features_str}" "${domain_manifest}" || true
    fi

    # ── Step 3: Parse agent recommendations ──────────────────────────────
    if [[ -f "${recommendations_file}" ]]; then
        log_ok "Agent analysis complete — parsing recommendations..."
        while IFS='|' read -r name action reason; do
            # Skip blank lines and comments
            name="${name// /}"  # trim spaces
            [[ -z "${name}" || "${name}" =~ ^# ]] && continue
            action="${action,,}"
            action="${action// /}"
            [[ "${action}" != "install" && "${action}" != "merge" ]] && continue
            # Only include skills that exist in skeleton
            [[ ! -d "${SKELETON_ROOT}/.github/skills/${name}" ]] && continue
            rec_names+=("${name}")
            rec_actions+=("${action}")
            rec_reasons+=("${reason}")
        done < "${recommendations_file}"
    fi

    # ── Step 3b: Parse domain skill plan ──────────────────────────────────
    if [[ -f "${domain_manifest}" ]]; then
        while IFS='|' read -r name reason; do
            name="${name// /}"
            [[ -z "${name}" || "${name}" =~ ^# ]] && continue
            domain_names+=("${name}")
            domain_reasons+=("${reason}")
        done < "${domain_manifest}"
        if [[ ${#domain_names[@]} -gt 0 ]]; then
            log_ok "Domain skills planned: ${BOLD}${#domain_names[@]}${NC}"
        fi
    fi

    # ── Step 4: Fallback to static map if no agent output ─────────────────
    if [[ ${#rec_names[@]} -eq 0 ]]; then
        if _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]]; then
            log_warn "Agent produced no parseable recommendations — using static detection as fallback"
        else
            log_info "Copilot not available — using static skill detection"
        fi
        while IFS='|' read -r name action reason; do
            [[ -z "${name}" ]] && continue
            rec_names+=("${name}")
            rec_actions+=("${action}")
            rec_reasons+=("${reason}")
        done < <(_autoskills_static_map "${detected_lang}" "${target_dir}" "${features[@]+"${features[@]}"}")
    fi

    if [[ ${#rec_names[@]} -eq 0 ]] && [[ ${#domain_names[@]} -eq 0 ]]; then
        log_ok "No skills recommended — project is up to date or no matches found."
        echo ""
        return 0
    fi

    # ── Step 5: Show plan with reasons ────────────────────────────────────
    local total_skills=$(( ${#rec_names[@]} + ${#domain_names[@]} ))
    echo ""
    log_step "Recommended skills (${total_skills}):"
    echo ""
    for i in "${!rec_names[@]}"; do
        local action_label
        case "${rec_actions[$i]}" in
            install) action_label="${GREEN}[install]  ${NC}" ;;
            merge)   action_label="${CYAN}[merge]    ${NC}" ;;
            *)       action_label="[${rec_actions[$i]}]    " ;;
        esac
        echo -e "  ${action_label} ${BOLD}${rec_names[$i]}${NC}"
        echo -e "             ${rec_reasons[$i]}"
    done
    for i in "${!domain_names[@]}"; do
        echo -e "  ${MAGENTA}[generate] ${NC} ${BOLD}${domain_names[$i]}${NC}"
        echo -e "             ${domain_reasons[$i]}"
    done
    echo ""
    echo -e "  ${GREEN}[install]${NC}  = fresh copy from skeleton-parallel"
    echo -e "  ${CYAN}[merge]${NC}    = existing skill combined with skeleton version (custom sections preserved)"
    echo -e "  ${MAGENTA}[generate]${NC} = new domain-specific skill generated for this project"
    echo ""

    if [[ "${dry_run}" == true ]]; then
        log_info "Dry run complete. Use without --dry-run to install."
        echo ""
        return 0
    fi

    # ── Step 6: Confirmation ──────────────────────────────────────────────
    if [[ "${auto_yes}" != true ]]; then
        echo -e "${BOLD}Options:${NC}"
        local domain_note=""
        [[ ${#domain_names[@]} -gt 0 ]] && domain_note=" + generate ${#domain_names[@]} domain skills"
        echo -e "  ${GREEN}[y]${NC} Install all ${#rec_names[@]} skeleton skills${domain_note}"
        echo -e "  ${YELLOW}[i]${NC} Choose individually (confirm each skill)"
        echo -e "  ${RED}[n]${NC} Abort"
        echo ""
        printf "%b" "${BOLD}Proceed? [y/i/n]: ${NC}"
        read -r bulk_choice
        echo ""

        case "${bulk_choice,,}" in
            y|yes)
                # keep all
                ;;
            i|individual)
                local sel_names=() sel_actions=() sel_reasons=()
                for i in "${!rec_names[@]}"; do
                    local action_short="${rec_actions[$i]}"
                    printf "%b" "  ${BOLD}${rec_names[$i]}${NC} (${action_short}) — ${rec_reasons[$i]}"$'\n'
                    printf "%b" "  Install? [y/N]: "
                    read -r per_choice
                    if [[ "${per_choice,,}" == "y" ]]; then
                        sel_names+=("${rec_names[$i]}")
                        sel_actions+=("${rec_actions[$i]}")
                        sel_reasons+=("${rec_reasons[$i]}")
                    fi
                done
                if [[ ${#domain_names[@]} -gt 0 ]]; then
                    echo ""
                    printf "%b" "  ${MAGENTA}${#domain_names[@]} domain skill(s)${NC} planned for generation.\n"
                    printf "%b" "  Generate all domain skills? [y/N]: "
                    read -r domain_choice
                    if [[ "${domain_choice,,}" != "y" ]]; then
                        domain_names=()
                        domain_reasons=()
                    fi
                fi
                if [[ ${#sel_names[@]} -eq 0 ]] && [[ ${#domain_names[@]} -eq 0 ]]; then
                    log_info "Nothing selected. Aborted."
                    echo ""
                    return 0
                fi
                rec_names=("${sel_names[@]+"${sel_names[@]}"}") 
                rec_actions=("${sel_actions[@]+"${sel_actions[@]}"}") 
                rec_reasons=("${sel_reasons[@]+"${sel_reasons[@]}"}")
                ;;
            *)
                log_info "Aborted."
                echo ""
                return 0
                ;;
        esac
    fi

    # ── Step 7: Install / merge ───────────────────────────────────────────
    echo ""
    mkdir -p "${target_dir}/.github/skills"
    local installed=0 merged=0 generated=0 failed=0
    for i in "${!rec_names[@]}"; do
        case "${rec_actions[$i]}" in
            install)
                if _autoskills_install_skill "${rec_names[$i]}" "${target_dir}"; then
                    ((++installed))
                else
                    ((++failed))
                fi
                ;;
            merge)
                if _autoskills_merge_skill "${rec_names[$i]}" "${target_dir}"; then
                    ((++merged))
                else
                    ((++failed))
                fi
                ;;
        esac
    done

    # ── Step 7b: Generate domain skills (now that user has confirmed) ─────
    if [[ ${#domain_names[@]} -gt 0 ]] && _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]]; then
        echo ""
        log_step "Generating ${#domain_names[@]} domain-specific skill(s)..."
        _autoskills_agent_generate_domain "${target_dir}" "${detected_lang}" "${features_str}" "${domain_manifest}" || true
        # Count how many were actually created
        for name in "${domain_names[@]}"; do
            [[ -f "${target_dir}/.github/skills/${name}/SKILL.md" ]] && ((++generated)) || true
        done
    elif [[ ${#domain_names[@]} -gt 0 ]]; then
        log_warn "Copilot not available — domain skills not generated."
    fi

    echo ""
    log_ok "Done. ${BOLD}${installed}${NC} installed, ${BOLD}${merged}${NC} merged, ${BOLD}${generated}${NC} generated, ${BOLD}${failed}${NC} failed."
    if [[ ${merged} -gt 0 ]] && _check_copilot_available && [[ "${SKIP_AGENT:-false}" != "true" ]]; then
        log_info "Merge agents are running in the background."
        log_info "Check .parallel-dev/agent-logs/ for merge results."
    fi
    if [[ ${generated} -gt 0 ]]; then
        log_info "Domain skills are in .github/skills/ — review and customize them for this project."
    fi
    echo ""
}

# ═════════════════════════════════════════════════════════════════════════════
# COMMAND: version / help
# ═════════════════════════════════════════════════════════════════════════════
cmd_version() {
    echo "skeleton v${VERSION} (skeleton-parallel framework)"
}

cmd_help() {
    cat <<'EOF'

  skeleton — CLI for the skeleton-parallel framework (v1.1.0)

  USAGE:
    skeleton <command> [options]

  COMMANDS:
    auth [--provider=PROV]    Check provider CLI auth before running commands
    init <language>           Initialize a new project from template
    upgrade [--dir=DIR]       Upgrade existing repo with skeleton-parallel
    doctor [--dir=DIR]        Validate project health and wiring
    add skill <name>          Add a skill to current project
    add agent <name>          Add an agent to current project
    list [skills|agents|templates]  List available resources
    router <subcommand>       Manage 9router daemon (install|start|stop|status|health|oauth)
    plan [--from=PLAN]        Bridge a2a-brainstorm plan into skeleton execution format
    plan [--source=DOC]       Generate docs/PLAN.md from architecture doc (no a2a required)
    sync [--dir=DIR]          Force-sync all skills/agents/scripts from upstream
    autoskills [--dir=DIR]    Auto-detect stack and install matching skills
    version                   Show version
    help                      Show this help

  INIT OPTIONS:
    --name=NAME               Project name (default: directory name)
    --dir=DIR                 Target directory (default: ./<name>)
    --no-agent                Skip agent spawning

  UPGRADE OPTIONS:
    --dir=DIR                 Target directory (default: .)
    --mode=MODE               Force upgrade mode: replace, hybrid, or skip
    --no-agent                Skip Copilot agent spawning
    --no-analyze              Skip pre-upgrade Explore analysis (use existing context report if present)

  AGENT BEHAVIOR:
    By default, file-modifying commands (init, upgrade, doctor, sync, add,
    autoskills) spawn a Copilot CLI agent for validation or deep health check.
    Use --no-agent to disable agent spawning, or set SKIP_AGENT=true.
    Agent model: controlled by AGENT_MODEL env var (default: claude-sonnet-4-6).
    Agent logs are saved to .parallel-dev/agent-logs/.

  SUPPORTED LANGUAGES:
    go          Vertical slice architecture (handler/service/repository per feature)
    python      Modular monolith (module/feature/handler pattern)
    typescript  Modular monolith (module/feature pattern)
    nodejs      Modular monolith (Express/Fastify pattern)
    rust        Modular monolith (module/feature pattern)
    java        Modular monolith (module/feature pattern)

  EXAMPLES:
    skeleton auth                              # check default provider auth
    skeleton auth --provider=claude            # check Claude Code auth
    skeleton auth --provider=router_http       # check 9router health
    skeleton init go --name=my-service
    skeleton init python --name=trading-system --dir=~/projects/trading
    skeleton init nodejs --name=api-gateway --no-agent
    skeleton upgrade --dir=../existing-project
    skeleton upgrade --dir=../existing-project --mode=hybrid
    skeleton doctor
    skeleton add skill security-audit
    skeleton add agent test-builder
    skeleton list skills
    skeleton sync --dir=../my-project
    skeleton plan --from=docs/plan.md           # import a2a-brainstorm output
    skeleton plan --source=docs/architecture.md # generate without a2a
    skeleton plan --dry-run
    skeleton router install
    skeleton router start
    skeleton router status
    skeleton router oauth
    skeleton autoskills --dir=../existing-project --dry-run
    skeleton autoskills -y

  ENVIRONMENT VARIABLES:
    AGENT_MODEL               Model for agent CLI (default: claude-sonnet-4-6)
    SKIP_AGENT                Set to 'true' to disable agent spawning globally

EOF
}

# ═════════════════════════════════════════════════════════════════════════════
# MAIN ROUTER
# ═════════════════════════════════════════════════════════════════════════════
main() {
    if [[ $# -eq 0 ]]; then
        cmd_help
        exit 0
    fi

    local command="$1"
    shift

    case "${command}" in
        run)        exec "${SKELETON_ROOT}/scripts/skeleton-run.sh" "$@" ;;
        init)       cmd_init "$@" ;;
        upgrade)    cmd_upgrade "$@" ;;
        integrate)  cmd_integrate "$@" ;;
        doctor)     cmd_doctor "$@" ;;
        autoskills) cmd_autoskills "$@" ;;
        hooks)      cmd_hooks "$@" ;;
        add)        cmd_add "$@" ;;
        list)       cmd_list "$@" ;;
        sync)       cmd_sync "$@" ;;
        auth)       cmd_auth "$@" ;;
        plan)       cmd_plan "$@" ;;
        router)     bash "${SKELETON_ROOT}/router/wrap.sh" "$@" ;;
        version)    cmd_version ;;
        help|-h|--help) cmd_help ;;
        *)          die "Unknown command: ${command}\nRun 'skeleton help' for usage." ;;
    esac
}

main "$@"
